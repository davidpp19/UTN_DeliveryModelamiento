@model Delivery.Modelos.DTOs.CarritoSesionDto
@{
    ViewData["Title"] = "Mi Carrito";
}

<h1>Mi Carrito</h1>
<hr />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

@if (Model == null || !Model.Items.Any())
{
    <div class="alert alert-info">
        <h4>Tu carrito está vacío</h4>
        <p>Explora los restaurantes y agrega productos para comenzar tu pedido.</p>
        <a asp-controller="Home" asp-action="Index">Ver Restaurantes</a>
    </div>
}
else
{
    <p><strong>Restaurante:</strong> @Model.NombreRestaurante</p>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Precio Unitario</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
                <th>Acción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" alt="@item.NombreProducto" class="rounded me-2" style="width: 50px; height: 50px; object-fit: cover;" />
                            }
                            <span>@item.NombreProducto</span>
                        </div>
                    </td>
                    <td class="align-middle">$@item.PrecioUnitario.ToString("0.00")</td>
                    <td class="align-middle">@item.Cantidad</td>
                    <td class="align-middle">$@item.Subtotal.ToString("0.00")</td>
                    <td class="align-middle">
                        <form asp-action="Quitar" method="post" style="display:inline;">
                            <input type="hidden" name="productoId" value="@item.ProductoId" />
                            <button type="submit">Quitar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3"><strong>Total</strong></td>
                <td colspan="2"><strong>$@Model.Subtotal.ToString("0.00")</strong></td>
            </tr>
        </tfoot>
    </table>

    <form asp-action="Vaciar" method="post" style="display:inline;">
        <button type="submit">Vaciar Carrito</button>
    </form>

    <hr />

    @if (ViewBag.SinDireccion == true)
    {
        <div class="alert alert-warning">
            <strong>No tienes ninguna dirección de entrega registrada.</strong><br />
            Debes agregar una dirección antes de confirmar tu pedido.
        </div>
        <a asp-controller="ClienteDirecciones" asp-action="Create">Agregar Mi Primera Dirección</a>
    }
    else
    {
        <a asp-action="Checkout" class="btn btn-primary btn-lg">Proceder al Pago</a>
    }
}
