@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@{ ViewData["Title"] = "Mis Entregas"; }
<h1 class="my-4">Mis Entregas</h1>

<div class="table-responsive glass-card p-4 rounded-4 shadow-lg border-0 mt-3 table-scrollable">
    <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
        <thead class="border-bottom border-secondary">
            <tr>
                <th>NÂº Pedido</th>
                <th>Cliente</th>
                <th>Restaurante</th>
                <th>DirecciÃ³n</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td><strong>#@item.Id</strong></td>
                    <td>@(item.Usuario?.Nombre ?? "Cliente")</td>
                    <td>@(item.Restaurante?.Nombre ?? "Restaurante")</td>
                    <td>@(item.DireccionEntrega?.Calle ?? "Sin DirecciÃ³n")</td>
                    <td><span class="badge bg-secondary">@item.EstadoPedido</span></td>
                    <td>
                        <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-sm btn-warning btn-confirm" data-title="¿Confirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">
                            <i class="bi bi-arrow-repeat"></i> Estado
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                            <i class="bi bi-eye"></i> Mapa
                        </a>
                        <a asp-action="Cancelar" asp-route-id="@item.Id" class="btn btn-sm btn-danger btn-confirm" data-title="¿Eliminar registro?" data-text="Esta acción no se puede deshacer" data-danger="true" data-confirm="Sí, eliminar">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>



