@model Delivery.Modelos.Entidades.Repartidor
@{
    ViewData["Title"] = "Mi Perfil de Repartidor";
}

<div class="container mt-4">
    <h2>Mi Perfil de Repartidor</h2>
    <hr />

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">@TempData["Exito"]</div>
    }

    <form asp-action="CompletarPerfil" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm">
        <input type="hidden" name="id" value="@Model.UsuarioId" />

        <div class="mb-3">
            <label class="form-label">Dirección Actual</label>
            <input type="text" name="direccion" class="form-control" value="@Model.Direccion" />
            <small class="text-muted">La dirección desde donde sueles operar o vives.</small>
        </div>

        <div class="mb-3">
            <label class="form-label">Datos Adicionales / Horarios Disponibles</label>
            <textarea name="datosAdicionales" class="form-control" rows="3">@Model.DatosAdicionales</textarea>
        </div>

        <hr />
        <h4>Foto de Perfil</h4>
        <div class="row mt-3">
            <div class="col-md-6 mb-3">
                @if (Model.Usuario != null && !string.IsNullOrEmpty(Model.Usuario.FotoPerfilUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.Usuario.FotoPerfilUrl" alt="Foto de perfil" class="img-thumbnail rounded-circle" style="width: 150px; height: 150px; object-fit: cover;" />
                    </div>
                }
                <input type="file" name="fotoPerfil" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <small class="text-muted">Formatos: JPG, PNG, WEBP. Máx: 5MB.</small>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
            <a asp-controller="DashboardRepartidor" asp-action="Index" class="btn btn-outline-secondary">Volver al Dashboard</a>
        </div>
    </form>
</div>
