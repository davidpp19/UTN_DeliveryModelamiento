@model Delivery.Modelos.Entidades.Pedido
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{ ViewData["Title"] = "Detalles Pedido"; }

<div class="container mt-4">
    <h2>Detalles del Pedido #@Model.Id</h2>
    <hr />

    <div class="row">
        <!-- Columna Izquierda: Info General -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Información General</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Restaurante</dt>
                        <dd class="col-sm-8">@(Model.Restaurante?.Nombre ?? "N/A")</dd>

                        <dt class="col-sm-4">Fecha Pedido</dt>
                        <dd class="col-sm-8">@Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Estado</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info text-dark">@Model.EstadoPedido.ToString()</span>
                        </dd>

                        <dt class="col-sm-4">Dirección</dt>
                        <dd class="col-sm-8">
                            @(Model.DireccionEntrega?.Calle) @(Model.DireccionEntrega?.Numero)
                            <br /><small class="text-muted">@(Model.DireccionEntrega?.Referencia)</small>
                        </dd>

                        <dt class="col-sm-4">Cliente</dt>
                        <dd class="col-sm-8">@(Model.Usuario?.Nombre) @(Model.Usuario?.Apellidos)</dd>
                        
                        @if (!string.IsNullOrWhiteSpace(Model.Notas))
                        {
                            <dt class="col-sm-4">Notas</dt>
                            <dd class="col-sm-8">@Model.Notas</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Acciones del Pedido</h5>
                </div>
                <div class="card-body">
                    <a asp-action="CambiarEstado" asp-route-id="@Model.Id" class="btn btn-warning mb-3 w-100">Actualizar Estado</a>
                    
                    <button class="btn btn-primary w-100" id="btnCompartirUbicacion">Empezar a Compartir Ubicación (GPS)</button>
                    <small class="text-muted mt-2 d-block">Presiona para que el cliente pueda ver tu ubicación en tiempo real mientras vas en camino.</small>
                    <div id="gpsStatus" class="mt-2 text-info"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Ruta de Entrega</h5>
                </div>
                <div class="card-body p-0">
                    <div id="map" style="height: 400px; width: 100%;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a>
    </div>
</div>

@section Scripts {
    <!-- Leaflet CSS y JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        var map = L.map('map').setView([0.3517, -78.1222], 14);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var restLat = @(Model.Restaurante?.Latitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
        var restLng = @(Model.Restaurante?.Longitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
        var cliLat = @(Model.DireccionEntrega?.Latitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
        var cliLng = @(Model.DireccionEntrega?.Longitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");

        // Custom icons usando SVG en línea (para evitar bloqueos de imágenes externas)
        var houseSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><path fill="#28a745" d="M12 3L2 12h3v8h14v-8h3L12 3zm0 2.7l6 5.3v7h-4v-5H10v5H6v-7l6-5.3z"/></svg>`;
        var cliIcon = L.divIcon({
            html: houseSvg,
            className: '',
            iconSize: [36, 36],
            iconAnchor: [18, 36]
        });
        
        var restSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36"><path fill="#dc3545" d="M11 9H9V2H7v7H5V2H3v7c0 2.1 1.6 3.8 3.6 4v9h1.8v-9C10.4 12.8 12 11.1 12 9V2h-1v7zm5-7v9h-2v11h2v-11h2V2h-2z"/></svg>`;
        var restIcon = L.divIcon({
            html: restSvg,
            className: '',
            iconSize: [36, 36],
            iconAnchor: [18, 36]
        });

        if (restLat !== 0 && cliLat !== 0) {
            restMarker = L.marker([restLat, restLng], { icon: restIcon }).addTo(map).bindPopup('Restaurante');
            cliMarker = L.marker([cliLat, cliLng], { icon: cliIcon }).addTo(map).bindPopup('Lugar de Entrega (Cliente)');

            // Draw route with OSRM
            fetch(`https://router.project-osrm.org/route/v1/driving/${restLng},${restLat};${cliLng},${cliLat}?overview=full&geometries=geojson`)
                .then(res => res.json())
                .then(data => {
                    if (data.routes && data.routes.length > 0) {
                        var route = data.routes[0].geometry.coordinates;
                        var latLngs = route.map(coord => [coord[1], coord[0]]);
                        L.polyline(latLngs, { color: 'blue', weight: 4 }).addTo(map);
                        
                        try {
                            map.fitBounds(L.polyline(latLngs).getBounds());
                        } catch (e) {
                            console.error("Error al encuadrar ruta inicial:", e);
                        }
                    }
                });
        }

        // Repartidor icon
        var repIcon = L.icon({
            iconUrl: 'https://cdn-icons-png.flaticon.com/512/2972/2972185.png', // Moto icon
            iconSize: [32, 32],
            iconAnchor: [16, 32]
        });

        // SignalR setup
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('@(Configuration["ApiSettings:BaseUrl"] ?? Configuration["ApiUrl"] ?? "https://localhost:7087")'.replace(/\/$/, "") + "/notificacionesHub")
            .withAutomaticReconnect()
            .build();

        connection.start().then(function () {
            console.log("Conectado a SignalR");
        }).catch(err => console.error(err));

        let watchId = null;

        document.getElementById('btnCompartirUbicacion').addEventListener('click', function() {
            if (watchId !== null) {
                navigator.geolocation.clearWatch(watchId);
                watchId = null;
                this.innerText = "Empezar a Compartir Ubicación (GPS)";
                this.classList.remove('btn-danger');
                this.classList.add('btn-primary');
                document.getElementById('gpsStatus').innerText = "Transmisión detenida.";
                return;
            }

            if (navigator.geolocation) {
                this.innerText = "Detener Transmisión de Ubicación";
                this.classList.remove('btn-primary');
                this.classList.add('btn-danger');
                document.getElementById('gpsStatus').innerText = "Buscando ubicación...";

                watchId = navigator.geolocation.watchPosition(function(position) {
                    var lat = position.coords.latitude;
                    var lng = position.coords.longitude;
                    
                    document.getElementById('gpsStatus').innerText = `Enviando... Lat: ${lat.toFixed(5)}, Lng: ${lng.toFixed(5)}`;

                    if (repMarker) {
                        repMarker.setLatLng([lat, lng]);
                    } else {
                        repMarker = L.marker([lat, lng], { icon: repIcon }).addTo(map).bindPopup('Tú');
                    }
                    map.setView([lat, lng], 16); // Siempre seguir al repartidor

                    // Calcular ruta dinámica desde la moto hasta el cliente
                    if (cliLat !== 0 && cliLng !== 0) {
                        fetch(`https://router.project-osrm.org/route/v1/driving/${lng},${lat};${cliLng},${cliLat}?overview=full&geometries=geojson`)
                            .then(res => res.json())
                            .then(data => {
                                if (data.routes && data.routes.length > 0) {
                                    var routeData = data.routes[0];
                                    var routeCoords = routeData.geometry.coordinates;
                                    var latLngs = routeCoords.map(coord => [coord[1], coord[0]]);

                                    if (window.currentDynamicRoute) {
                                        map.removeLayer(window.currentDynamicRoute);
                                    }
                                    
                                    window.currentDynamicRoute = L.polyline(latLngs, { color: 'purple', weight: 5, opacity: 0.8 }).addTo(map);
                                    
                                    const distanciaKm = (routeData.distance / 1000).toFixed(1);
                                    const tiempoMin = Math.ceil(routeData.duration / 60);
                                    document.getElementById('gpsStatus').innerText = `Enviando... (A ${distanciaKm}km / ~${tiempoMin} min del cliente)`;
                                }
                            }).catch(e => console.error("OSRM Error:", e));
                    }

                    if (connection.state === signalR.HubConnectionState.Connected) {
                        connection.invoke("EnviarUbicacionRepartidor", "@Model.Id", lat, lng, @Model.RepartidorId)
                            .catch(err => console.error("Error al enviar ubicación: " + err));
                    }
                }, function(error) {
                    document.getElementById('gpsStatus').innerText = "Error obteniendo GPS: " + error.message;
                }, {
                    enableHighAccuracy: true,
                    maximumAge: 10000,
                    timeout: 5000
                });
            } else {
                alert("Geolocalización no soportada por este navegador.");
            }
        });

        // Auto-start GPS if status is EnCamino
        @if (Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.EnCamino)
        {
            <text>
            setTimeout(function() {
                if (watchId === null) {
                    document.getElementById('btnCompartirUbicacion').click();
                }
            }, 1500); // Dar tiempo a que SignalR conecte
            </text>
        }
    </script>
}
