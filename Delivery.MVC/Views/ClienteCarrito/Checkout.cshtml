@model Delivery.Modelos.DTOs.CarritoSesionDto
@{
    ViewData["Title"] = "Checkout";
}

<div class="container mt-4">
    <h2>Proceso de Pago (Simulación)</h2>
    <hr />

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        <div class="col-md-5 order-md-2 mb-4">
            <h4 class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">Tu Carrito</span>
                <span class="badge badge-secondary badge-pill">@Model.Items.Count</span>
            </h4>
            <ul class="list-group mb-3">
                @foreach (var item in Model.Items)
                {
                    <li class="list-group-item d-flex justify-content-between lh-condensed">
                        <div>
                            <h6 class="my-0">@item.NombreProducto</h6>
                            <small class="text-muted">Cantidad: @item.Cantidad</small>
                        </div>
                        <span class="text-muted">$@item.Subtotal.ToString("0.00")</span>
                    </li>
                }
                <li class="list-group-item d-flex justify-content-between lh-condensed bg-light">
                    <div>
                        <h6 class="my-0">Costo de Envío</h6>
                        <small class="text-muted" id="distanciaInfo">Seleccione dirección</small>
                    </div>
                    <span class="text-success" id="costoEnvioUI">$0.00</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Total (USD)</span>
                    <strong id="totalUI">$@Model.Subtotal.ToString("0.00")</strong>
                </li>
            </ul>
            <input type="hidden" id="subtotalValue" value="@Model.Subtotal" />
        </div>
        
        <div class="col-md-7 order-md-1">
            <form asp-action="Confirmar" method="post" id="checkoutForm" enctype="multipart/form-data" onsubmit="return validarFormulario(event)">
                <h4 class="mb-3">Dirección de Entrega</h4>
                <div class="mb-3">
                    <label for="direccionId">Selecciona tu Dirección</label>
                    <select class="form-control" id="direccionId" name="direccionId" asp-items="ViewBag.Direcciones" required>
                        <option value="">-- Selecciona una dirección --</option>
                    </select>
                </div>

                <hr class="mb-4">

                <h4 class="mb-3">Método de Pago</h4>

                <div class="d-block my-3">
                    <div class="custom-control custom-radio">
                        <input id="efectivo" name="metodoPago" type="radio" class="custom-control-input" value="Efectivo" checked required onchange="togglePaymentSections()">
                        <label class="custom-control-label" for="efectivo">Efectivo (Al recibir el pedido)</label>
                    </div>
                    <div class="custom-control custom-radio">
                        <input id="tarjeta" name="metodoPago" type="radio" class="custom-control-input" value="Tarjeta" required onchange="togglePaymentSections()">
                        <label class="custom-control-label" for="tarjeta">Tarjeta de Crédito / Débito</label>
                    </div>
                    <div class="custom-control custom-radio">
                        <input id="transferencia" name="metodoPago" type="radio" class="custom-control-input" value="Transferencia" required onchange="togglePaymentSections()">
                        <label class="custom-control-label" for="transferencia">Transferencia Bancaria</label>
                    </div>
                </div>

                <!-- SECCIÓN TARJETA -->
                <div id="seccionTarjeta" style="display:none;" class="card p-3 mb-4 bg-light">
                    <h5>Detalles de la Tarjeta</h5>
                    <div id="tarjetaError" class="alert alert-danger" style="display: none;"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="titular">Nombre en la tarjeta</label>
                            <input type="text" class="form-control" id="titular" name="titular" placeholder="EJ. JUAN PEREZ">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="numeroTarjeta">Número de tarjeta <span id="tarjetaTipo" class="badge bg-secondary ms-2"></span></label>
                            <input type="text" class="form-control" id="numeroTarjeta" name="numeroTarjeta" placeholder="XXXX XXXX XXXX XXXX" oninput="formatearTarjeta(this)">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label for="expiracion">Expiración</label>
                            <input type="text" class="form-control" id="expiracion" name="expiracion" placeholder="MM/AA" maxlength="5" oninput="formatearExpiracion(this)">
                        </div>
                        <div class="col-md-3 mb-3">
                            <label for="cvv">CVV</label>
                            <input type="text" class="form-control" id="cvv" name="cvv" placeholder="123" maxlength="4" oninput="this.value = this.value.replace(/[^0-9]/g, '');">
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN TRANSFERENCIA -->
                <div id="seccionTransferencia" style="display:none;" class="card p-3 mb-4 bg-light">
                    <h5>Datos para Transferencia</h5>
                    <p>Por favor, realiza la transferencia a la siguiente cuenta y adjunta el comprobante (JPG, PNG, PDF).</p>
                    <ul>
                        <li><strong>Banco:</strong> Banco RayoExpres</li>
                        <li><strong>Beneficiario:</strong> RayoExpres S.A.</li>
                        <li><strong>RUC:</strong> 0999999999001</li>
                        <li><strong>Tipo de Cuenta:</strong> Corriente</li>
                        <li><strong>Número de cuenta:</strong> 220045678901</li>
                    </ul>
                    <div class="mb-3">
                        <label for="comprobante" class="form-label">Subir Comprobante</label>
                        <input class="form-control" type="file" id="comprobante" name="comprobante" accept=".jpg,.png,.pdf">
                    </div>
                </div>

                <hr class="mb-4">
                <button class="btn btn-primary btn-lg btn-block" type="submit" id="btnSubmit">Confirmar Pedido</button>
            </form>
        </div>
    </div>
</div>

<script>
    function togglePaymentSections() {
        var metodo = document.querySelector('input[name="metodoPago"]:checked').value;
        var seccionTarjeta = document.getElementById('seccionTarjeta');
        var seccionTransferencia = document.getElementById('seccionTransferencia');
        
        seccionTarjeta.style.display = 'none';
        seccionTransferencia.style.display = 'none';
        
        document.getElementById('numeroTarjeta').removeAttribute('required');
        document.getElementById('expiracion').removeAttribute('required');
        document.getElementById('cvv').removeAttribute('required');
        document.getElementById('comprobante').removeAttribute('required');

        if (metodo === 'Tarjeta') {
            seccionTarjeta.style.display = 'block';
            document.getElementById('numeroTarjeta').setAttribute('required', 'required');
            document.getElementById('expiracion').setAttribute('required', 'required');
            document.getElementById('cvv').setAttribute('required', 'required');
        } else if (metodo === 'Transferencia') {
            seccionTransferencia.style.display = 'block';
            document.getElementById('comprobante').setAttribute('required', 'required');
        }
    }

    document.getElementById('direccionId').addEventListener('change', function() {
        var dirId = this.value;
        if (!dirId) {
            document.getElementById('costoEnvioUI').innerText = '$0.00';
            document.getElementById('distanciaInfo').innerText = 'Seleccione dirección';
            actualizarTotal(0);
            return;
        }

        fetch('/ClienteCarrito/CalcularCostoEnvio?direccionId=' + dirId)
            .then(res => res.json())
            .then(data => {
                if (data && data.exito) {
                    var costo = data.costo;
                    document.getElementById('costoEnvioUI').innerText = '$' + costo.toFixed(2);
                    if (data.distancia) {
                        document.getElementById('distanciaInfo').innerText = data.distancia + ' km apróx.';
                    } else {
                        document.getElementById('distanciaInfo').innerText = 'Tarifa base';
                    }
                    actualizarTotal(costo);
                }
            })
            .catch(err => console.error(err));
    });

    function actualizarTotal(costoEnvio) {
        var sub = parseFloat(document.getElementById('subtotalValue').value.replace(',', '.'));
        var tot = sub + parseFloat(costoEnvio);
        document.getElementById('totalUI').innerText = '$' + tot.toFixed(2);
    }

    function formatearTarjeta(input) {
        let value = input.value.replace(/\D/g, '');
        let tipo = '';
        let maxLength = 16;

        if (value.startsWith('34') || value.startsWith('37')) {
            tipo = 'Amex';
            maxLength = 15;
        } else if (value.startsWith('4')) {
            tipo = 'Visa';
        } else if (value.startsWith('5')) {
            tipo = 'Mastercard';
        } else if (value.startsWith('6')) {
            tipo = 'Discover';
        }

        document.getElementById('tarjetaTipo').innerText = tipo;
        value = value.substring(0, maxLength);

        let formatted = '';
        if (tipo === 'Amex') {
            if (value.length > 4) {
                formatted += value.substring(0, 4) + ' ';
                if (value.length > 10) {
                    formatted += value.substring(4, 10) + ' ' + value.substring(10, 15);
                } else {
                    formatted += value.substring(4, 10);
                }
            } else {
                formatted = value;
            }
        } else {
            formatted = value.replace(/(\d{4})(?=\d)/g, '$1 ');
        }
        
        input.value = formatted;
    }

    function formatearExpiracion(input) {
        let value = input.value.replace(/\D/g, '');
        if (value.length > 2) {
            value = value.substring(0, 2) + '/' + value.substring(2, 4);
        }
        input.value = value;
    }

    function luhnCheck(num) {
        let arr = (num + '').split('').reverse().map(x => parseInt(x));
        let sum = arr.reduce((acc, val, i) => i % 2 !== 0 ? acc + (val * 2 > 9 ? val * 2 - 9 : val * 2) : acc + val, 0);
        return sum % 10 === 0;
    }

    function validarFormulario(e) {
        var metodo = document.querySelector('input[name="metodoPago"]:checked').value;
        if (metodo === 'Tarjeta') {
            var num = document.getElementById('numeroTarjeta').value.replace(/\D/g, '');
            var exp = document.getElementById('expiracion').value;
            var cvv = document.getElementById('cvv').value;
            var err = document.getElementById('tarjetaError');
            err.style.display = 'none';

            if (num.length < 15 || !luhnCheck(num)) {
                err.innerText = "Número de tarjeta inválido (Luhn).";
                err.style.display = 'block';
                return false;
            }

            var parts = exp.split('/');
            if (parts.length !== 2) {
                err.innerText = "Expiración inválida. Usa MM/AA.";
                err.style.display = 'block';
                return false;
            }
            
            var m = parseInt(parts[0], 10);
            var y = parseInt("20" + parts[1], 10);
            if (m < 1 || m > 12) {
                err.innerText = "Mes de expiración inválido.";
                err.style.display = 'block';
                return false;
            }

            var now = new Date();
            var expDate = new Date(y, m - 1);
            if (expDate < new Date(now.getFullYear(), now.getMonth())) {
                err.innerText = "La tarjeta ha expirado.";
                err.style.display = 'block';
                return false;
            }

            if (cvv.length < 3) {
                err.innerText = "CVV inválido.";
                err.style.display = 'block';
                return false;
            }
        }
        return true;
    }
    
    window.onload = togglePaymentSections;
</script>
