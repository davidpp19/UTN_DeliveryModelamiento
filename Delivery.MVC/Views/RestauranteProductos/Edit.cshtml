@model Delivery.Modelos.Entidades.Producto
@{ ViewData["Title"] = "Editar Producto"; }
<h1 class="my-4">Editar Producto</h1><hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RestauranteId" />
            <input type="hidden" asp-for="CreadoEn" />
            
            @if (ViewBag.TieneCategorias != null && !(bool)ViewBag.TieneCategorias)
            {
                <div class="alert alert-warning">
                    <strong>Â¡AtenciÃ³n!</strong> No has creado ninguna categorÃ­a. 
                    <a asp-controller="RestauranteCategorias" asp-action="Create" class="alert-link">Crea una categorÃ­a primero</a>.
                </div>
            }

            <div class="mb-3">
                <label asp-for="CategoriaId" class="form-label">CategorÃ­a</label>
                <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias" required>
                    <option value="">-- Seleccione una CategorÃ­a --</option>
                </select>
                <span asp-validation-for="CategoriaId" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label">Nombre del Producto</label>
                <input asp-for="Nombre" class="form-control" required />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label">DescripciÃ³n</label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Precio" class="form-label">Precio ($)</label>
                <input asp-for="Precio" type="number" step="0.01" class="form-control" required />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label class="form-label">Imagen del Producto</label>
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.ImagenUrl" alt="Imagen actual" class="img-thumbnail" style="max-height: 100px;" />
                    </div>
                }
                <input type="hidden" asp-for="ImagenUrl" />
                <input type="file" name="imagen" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <small class="text-muted">Deje vacÃ­o si desea conservar la imagen actual.</small>
            </div>
            
            <div class="mb-3 form-check">
                <input asp-for="Disponible" class="form-check-input" />
                <label class="form-check-label" asp-for="Disponible">Â¿EstÃ¡ disponible?</label>
                <span asp-validation-for="Disponible" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="TiempoPreparacion" class="form-label">Tiempo de PreparaciÃ³n (Minutos)</label>
                <input asp-for="TiempoPreparacion" type="number" class="form-control" />
                <span asp-validation-for="TiempoPreparacion" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-warning btn-confirm" data-title="¿Confirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>
<div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver al catÃ¡logo</a>
</div>

