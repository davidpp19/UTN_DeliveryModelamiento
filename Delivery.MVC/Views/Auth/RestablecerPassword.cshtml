@{
    ViewData["Title"] = "Restablecer Contraseña";
    var email = ViewBag.Email as string;
}

<div class="row justify-content-center my-5" data-aos="fade-up">
    <div class="col-md-6 col-lg-5">
        <div class="card glass-card">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock text-primary mb-3" style="font-size: 3.5rem;"></i>
                    <h3 class="fw-bold text-light">Restablecer Contraseña</h3>
                </div>
                
                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-info text-center glass-card" style="background: rgba(13, 202, 240, 0.1); border: 1px solid rgba(13, 202, 240, 0.3);">@TempData["Mensaje"]</div>
                }

                <p class="text-muted text-center mb-4">Ingresa el código enviado a <strong class="text-info">@email</strong> y tu nueva contraseña.</p>

                <form asp-action="RestablecerPassword" method="post">
                    <input type="hidden" name="email" value="@email" />
                    
                    <div class="mb-3">
                        <label class="form-label text-light">Código de Recuperación</label>
                        <input type="text" name="codigo" class="form-control text-center text-primary" 
                               placeholder="123456" maxlength="6" style="letter-spacing: 5px; font-weight: bold; font-size: 1.25rem;" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-light">Nueva Contraseña</label>
                        <input type="password" name="nuevaContrasena" class="form-control" required />
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-liquid btn-liquid-primary btn-lg">Guardar Nueva Contraseña</button>
                    </div>
                </form>
                
                <div class="mt-4 text-center">
                    <div id="res-reenviar" class="text-success mt-3" style="display:none; font-weight: bold;"></div>
                    <div id="err-reenviar" class="text-danger mt-3" style="display:none; font-weight: bold;"></div>
                </div>
            </div>
        </div>
    </div>
</div>


