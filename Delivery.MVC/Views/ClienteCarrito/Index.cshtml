@model Delivery.Modelos.Entidades.Pedido
@{
    ViewData["Title"] = "Mi Carrito";
}

<div class="container mt-4">
    <h1 class="mb-4 text-danger"><i class="bi bi-cart"></i> Mi Carrito</h1>

    @if (Model == null || !Model.Detalles.Any())
    {
        <div class="alert alert-info text-center">
            <h4>Tu carrito está vacío</h4>
            <p>Explora nuestros restaurantes y agrega productos deliciosos.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">Explorar Restaurantes</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Productos en el Carrito</h5>
                    </div>
                    <ul class="list-group list-group-flush">
                        @foreach (var detalle in Model.Detalles)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <h6 class="my-0">@(detalle.Producto?.Nombre ?? "Producto Desconocido")</h6>
                                    <small class="text-muted">Cantidad: @detalle.Cantidad</small>
                                </div>
                                <div class="d-flex align-items-center">
                                    <span class="text-muted me-3">$@detalle.Subtotal.ToString("0.00")</span>
                                    <form asp-action="Quitar" method="post">
                                        <input type="hidden" name="detallePedidoId" value="@detalle.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">Resumen del Pedido</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <span>$@Model.Subtotal.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Costo de Envío</span>
                            <span>$@Model.CostoEnvio.ToString("0.00")</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-3 fw-bold">
                            <span>Total</span>
                            <span class="text-danger">$@Model.Total.ToString("0.00")</span>
                        </div>

                        <form asp-action="Confirmar" method="post">
                            <div class="mb-3">
                                <label for="direccionId" class="form-label">Dirección de Entrega</label>
                                <select name="direccionId" class="form-select" asp-items="ViewBag.Direcciones" required>
                                    <option value="">Selecciona una dirección...</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-danger w-100 fw-bold">Confirmar Compra</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
