@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.DTOs.CarritoSesionDto
@{
    ViewData["Title"] = Localizer["CheckoutTitulo"];
}

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    #mapaCheckout {
        height: 350px;
        width: 100%;
        border-radius: 8px;
        margin-top: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        z-index: 1; /* Para no sobreponer navbars */
    }
    .search-container {
        position: relative;
        margin-bottom: 15px;
    }
    #listaResultados {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1000;
        background: white;
        border: 1px solid #ccc;
        border-radius: 4px;
        max-height: 200px;
        overflow-y: auto;
        display: none;
    }
    .resultado-item {
        padding: 10px;
        cursor: pointer;
        border-bottom: 1px solid #eee;
    }
    .resultado-item:hover {
        background-color: #f8f9fa;
    }
</style>

<div class="container mt-5 mb-5" data-aos="fade-up">
    <div class="d-flex align-items-center mb-4 border-bottom border-secondary pb-3">
        <i class="bi bi-credit-card fs-1 text-primary me-3"></i>
        <h2 class="mb-0 text-light">@Localizer["ProcesoPago"]</h2>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger glass-card" style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.3);">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="row">
        <!-- Resumen de Costos -->
        <div class="col-md-5 order-md-2 mb-4">
            <h4 class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-info"><i class="bi bi-cart3"></i> @Localizer["TuCarrito"]</span>
                <span class="badge bg-primary rounded-pill px-3">@Model.Items.Count</span>
            </h4>
            <div class="card glass-card border-0 mb-3">
                <ul class="list-group list-group-flush bg-transparent">
                    @foreach (var item in Model.Items)
                    {
                        <li class="list-group-item d-flex justify-content-between lh-condensed bg-transparent border-secondary text-light">
                            <div>
                                <h6 class="my-0 fw-bold">@item.NombreProducto</h6>
                                <small class="text-muted">@Localizer["Cantidad"] @item.Cantidad</small>
                            </div>
                            <span class="text-success">$@item.Subtotal.ToString("0.00")</span>
                        </li>
                    }
                    
                    <li class="list-group-item d-flex justify-content-between bg-transparent border-secondary text-light mt-2 pt-3">
                        <h6 class="my-0 text-muted">@Localizer["Subtotal"]</h6>
                        <strong id="subtotalUI">$@Model.Subtotal.ToString("0.00")</strong>
                    </li>

                    <li class="list-group-item bg-transparent border-secondary text-light">
                        <div class="d-flex justify-content-between">
                            <h6 class="my-0 text-muted">@Localizer["DistanciaTiempo"]</h6>
                            <strong id="distanciaInfo" class="text-info">@Localizer["Pendiente"]</strong>
                        </div>
                        <small class="text-muted" id="tiempoInfo">@Localizer["SeleccioneDireccionMapa"]</small>
                    </li>
                    <li class="list-group-item d-flex justify-content-between lh-condensed bg-transparent border-secondary text-light">
                        <div>
                            <h6 class="my-0 text-muted">@Localizer["CostoEnvio"]</h6>
                        </div>
                        <span class="text-warning fw-bold" id="costoEnvioUI">@Localizer["Pendiente"]</span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between lh-condensed bg-success text-white border-0" id="descuentoRow" style="display:none !important;">
                        <div>
                            <h6 class="my-0"><i class="bi bi-tags"></i> @Localizer["CuponAplicado"]</h6>
                            <small id="codigoCuponAplicadoUI"></small>
                        </div>
                        <span id="descuentoUI" class="fw-bold">-$0.00</span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between bg-transparent border-top border-secondary pt-3 mt-1 text-light">
                        <span class="fs-5">@Localizer["TotalUSD"]</span>
                        <strong id="totalUI" class="text-primary fs-4">$@Model.Subtotal.ToString("0.00")</strong>
                    </li>
                </ul>
            </div>
            
            <input type="hidden" id="subtotalValue" value="@Model.Subtotal" />
            <input type="hidden" id="descuentoValue" value="0" />
            
            <div class="card glass-card p-3 mb-4 border-0">
                <label class="form-label text-light fw-bold"><i class="bi bi-ticket-perforated text-warning"></i> ¿Tienes un cupón?</label>
                <div class="input-group">
                    <select class="form-select bg-dark text-light border-secondary" id="cuponInput" asp-items="ViewBag.Cupones">
                        <option value="">@Localizer["SeleccionarCupon"]</option>
                    </select>
                    <button type="button" class="btn btn-outline-warning" onclick="aplicarCupon()">@Localizer["AplicarCuponBtn"]</button>
                </div>
                <small id="cuponMensaje" class="form-text mt-2" style="display:none;"></small>
            </div>
            
            <div class="alert alert-info glass-card border-info text-light" style="background: rgba(13, 202, 240, 0.1);">
                <i class="bi bi-info-circle-fill text-info me-2"></i><strong>@Localizer["TarifaEnvioTag"]</strong> @Localizer["TarifaEnvioDesc"]
            </div>
        </div>
        
        <!-- Formulario -->
        <div class="col-md-7 order-md-1">
            <form asp-action="Confirmar" method="post" id="checkoutForm" enctype="multipart/form-data" onsubmit="return validarFormulario(event)">
                <input type="hidden" id="cuponCodigoForm" name="cuponCodigo" value="" />
                
                <h4 class="mb-4 text-warning border-bottom border-secondary pb-2"><i class="bi bi-geo-alt"></i> @Localizer["DireccionEntrega"]</h4>
                
                <div class="mb-4">
                    <label for="selectDireccion" class="form-label text-light">@Localizer["TusDirecciones"]</label>
                    <select class="form-select bg-dark text-light border-secondary" id="selectDireccion" name="direccionId" asp-items="ViewBag.Direcciones">
                        <option value="0">@Localizer["UsarOtraDireccion"]</option>
                    </select>
                </div>

                <div class="search-container" id="buscadorContainer">
                    <input type="text" id="buscadorDireccion" class="form-control bg-dark text-light border-secondary" placeholder="@Localizer["BuscarCallePlaceHolder"]" autocomplete="off">
                    <div id="listaResultados" class="bg-dark border-secondary text-light"></div>
                </div>

                <div class="card overflow-hidden border-0 shadow-lg mb-2">
                    <div id="mapaCheckout"></div>
                </div>
                <small class="text-muted d-block mt-1 mb-4"><i class="bi bi-info-circle"></i> @Localizer["ArrastrarMarcadorDesc"]</small>

                <!-- Campos ocultos y opcionales para la nueva dirección -->
                <div id="nuevaDireccionCampos" style="display:none;" class="card glass-card p-4 mb-4 border-info">
                    <h5 class="text-info mb-3"><i class="bi bi-card-text"></i> @Localizer["DetallesUbicacion"]</h5>
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label text-light">@Localizer["CalleAvenidaDetectada"]</label>
                            <input type="text" class="form-control bg-dark text-light border-secondary" id="nuevaCalle" name="nuevaCalle" readonly>
                        </div>
                    </div>
                    
                    <div class="form-check form-switch mb-3 mt-2">
                        <input type="checkbox" class="form-check-input" id="guardarDireccion" name="guardarDireccion" value="true">
                        <label class="form-check-label text-light fw-bold" for="guardarDireccion">@Localizer["GuardarDireccionParaCompras"]</label>
                    </div>

                    <div id="camposGuardado" style="display:none;">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light">@Localizer["AliasEjemplo"]</label>
                                <input type="text" class="form-control" name="nuevoAlias" placeholder="@Localizer["CasaPlaceholder"]">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light">@Localizer["Referencia"]</label>
                                <input type="text" class="form-control" name="nuevaReferencia" placeholder="@Localizer["FrenteParquePlaceholder"]">
                            </div>
                        </div>
                    </div>
                </div>

                <input type="hidden" id="nuevaCiudad" name="nuevaCiudad" value="">
                <input type="hidden" id="nuevaLatitud" name="nuevaLatitudStr">
                <input type="hidden" id="nuevaLongitud" name="nuevaLongitudStr">

                <h4 class="mb-4 mt-5 text-primary border-bottom border-secondary pb-2"><i class="bi bi-wallet2"></i> @Localizer["MetodoPago"]</h4>

                <div class="d-flex flex-column gap-3 my-4">
                    <div class="form-check custom-radio-glass">
                        <input id="efectivo" name="metodoPago" type="radio" class="form-check-input" value="Efectivo" checked required onchange="togglePaymentSections()">
                        <label class="form-check-label text-light w-100" for="efectivo">
                            <i class="bi bi-cash-coin text-success fs-5 me-2"></i> @Localizer["EfectivoDesc"]
                        </label>
                    </div>
                    <div class="form-check custom-radio-glass">
                        <input id="tarjeta" name="metodoPago" type="radio" class="form-check-input" value="Tarjeta" required onchange="togglePaymentSections()">
                        <label class="form-check-label text-light w-100" for="tarjeta">
                            <i class="bi bi-credit-card-2-front text-info fs-5 me-2"></i> @Localizer["TarjetaDesc"]
                        </label>
                    </div>
                    <div class="form-check custom-radio-glass">
                        <input id="transferencia" name="metodoPago" type="radio" class="form-check-input" value="Transferencia" required onchange="togglePaymentSections()">
                        <label class="form-check-label text-light w-100" for="transferencia">
                            <i class="bi bi-bank text-warning fs-5 me-2"></i> @Localizer["TransferenciaDesc"]
                        </label>
                    </div>
                </div>

                <!-- SECCIÓN TARJETA -->
                <div id="seccionTarjeta" style="display:none;" class="card glass-card p-4 mb-4">
                    <h5 class="text-info mb-4"><i class="bi bi-credit-card"></i> @Localizer["DetallesTarjeta"]</h5>
                    <div id="tarjetaError" class="alert alert-danger" style="display: none;"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="titular" class="form-label text-light">@Localizer["NombreTarjeta"]</label>
                            <input type="text" class="form-control" id="titular" name="titular" placeholder="@Localizer["EjemploJuanPerez"]">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="numeroTarjeta" class="form-label text-light">@Localizer["NumeroTarjeta"] <span id="tarjetaTipo" class="badge bg-primary ms-2"></span></label>
                            <input type="text" class="form-control" id="numeroTarjeta" name="numeroTarjeta" placeholder="XXXX XXXX XXXX XXXX" oninput="formatearTarjeta(this)">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="expiracion" class="form-label text-light">@Localizer["Expiracion"]</label>
                            <input type="text" class="form-control text-center" id="expiracion" name="expiracion" placeholder="MM/AA" maxlength="5" oninput="formatearExpiracion(this)">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="cvv" class="form-label text-light">@Localizer["CVV"]</label>
                            <input type="password" class="form-control text-center" id="cvv" name="cvv" placeholder="***" maxlength="4" oninput="this.value = this.value.replace(/[^0-9]/g, '');">
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN TRANSFERENCIA -->
                <div id="seccionTransferencia" style="display:none;" class="card glass-card p-4 mb-4">
                    <h5 class="text-warning mb-3"><i class="bi bi-bank"></i> @Localizer["DatosTransferencia"]</h5>
                    <p class="text-muted">@Localizer["TransferenciaInstrucciones"]</p>
                    <div class="bg-dark p-3 rounded mb-4 border border-secondary">
                        <ul class="list-unstyled text-light mb-0" style="line-height: 2;">
                            <li><i class="bi bi-building text-secondary me-2"></i><strong>@Localizer["BancoTag"]</strong> Banco RayoExpres</li>
                            <li><i class="bi bi-person text-secondary me-2"></i><strong>@Localizer["BeneficiarioTag"]</strong> RayoExpres S.A.</li>
                            <li><i class="bi bi-file-earmark-text text-secondary me-2"></i><strong>@Localizer["RUCTag"]</strong> 0999999999001</li>
                            <li><i class="bi bi-card-list text-secondary me-2"></i><strong>@Localizer["TipoCuentaTag"]</strong> Corriente</li>
                            <li><i class="bi bi-hash text-secondary me-2"></i><strong>@Localizer["NumCuentaTag"]</strong> <span class="text-info fs-5 fw-bold">220045678901</span></li>
                        </ul>
                    </div>
                    <div class="mb-3">
                        <label for="comprobante" class="form-label text-light"><i class="bi bi-upload"></i> @Localizer["SubirComprobante"]</label>
                        <input class="form-control bg-dark text-light border-secondary" type="file" id="comprobante" name="comprobante" accept=".jpg,.png,.pdf">
                    </div>
                </div>

                <div class="d-grid mt-5">
                    <button class="btn btn-liquid btn-liquid-primary btn-lg" type="submit" id="btnSubmit">
                        <i class="bi bi-check2-circle"></i> @Localizer["ConfirmarPagarBtn"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        var map;
        var marker = null;

        var customIcon = L.icon({
            iconUrl: 'https://cdn-icons-png.flaticon.com/512/149/149059.png',
            iconSize: [38, 38],
            iconAnchor: [19, 38]
        });

        // Inicialización
        document.addEventListener("DOMContentLoaded", function () {
            togglePaymentSections();

            var serverDecimalSeparator = '@System.Globalization.CultureInfo.CurrentCulture.NumberFormat.NumberDecimalSeparator';
            map = L.map('mapaCheckout').setView([-1.8312, -78.1834], 6);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors',
                maxZoom: 19
            }).addTo(map);

            // Si el cliente tiene direcciones, seleccionar la primera
            var selectDir = document.getElementById('selectDireccion');
            if (selectDir.options.length > 1) {
                selectDir.selectedIndex = 1;
                // Forzar el evento change para cargar la ubicacion
                var event = new Event('change');
                selectDir.dispatchEvent(event);
            } else {
                // Solicitar ubicación si no hay direcciones
                solicitarUbicacion();
            }

            // Checkbox guardar direccion
            document.getElementById('guardarDireccion').addEventListener('change', function() {
                document.getElementById('camposGuardado').style.display = this.checked ? 'block' : 'none';
            });
        });

        function agregarOMoverMarcador(lat, lng) {
            if (!marker) {
                marker = L.marker([lat, lng], {
                    icon: customIcon,
                    draggable: true
                }).addTo(map);

                marker.on('dragend', function (e) {
                    var position = marker.getLatLng();
                    actualizarCamposUbicacion(position.lat, position.lng);
                    obtenerNombreCalle(position.lat, position.lng);
                    calcularCostoEnvio(0, position.lat, position.lng); // 0 indica nueva dirección
                    document.getElementById('selectDireccion').value = "0";
                });
            } else {
                marker.setLatLng([lat, lng]);
            }
        }

        function solicitarUbicacion() {
            if ("geolocation" in navigator) {
                navigator.geolocation.getCurrentPosition(function (position) {
                    var lat = position.coords.latitude;
                    var lng = position.coords.longitude;
                    map.setView([lat, lng], 15);
                    agregarOMoverMarcador(lat, lng);
                    actualizarCamposUbicacion(lat, lng);
                    obtenerNombreCalle(lat, lng);
                    calcularCostoEnvio(0, lat, lng);
                }, function (error) {
                    console.log("Geolocalización denegada o error", error);
                    mostrarMensajeSeleccioneUbicacion();
                }, {
                    enableHighAccuracy: true,
                    timeout: 10000,
                    maximumAge: 0
                });
            } else {
                mostrarMensajeSeleccioneUbicacion();
            }
        }

        function mostrarMensajeSeleccioneUbicacion() {
            var costoUI = document.getElementById('costoEnvioUI');
            costoUI.innerText = 'Seleccione una ubicación en el mapa para calcular el costo del envío.';
            costoUI.classList.remove('text-success');
            costoUI.classList.add('text-danger');
            costoUI.style.fontSize = '0.85em';
            costoUI.style.textAlign = 'right';
            costoUI.style.maxWidth = '180px';
            
            document.getElementById('distanciaInfo').innerText = 'Pendiente';
            document.getElementById('tiempoInfo').innerText = 'Seleccione dirección en el mapa';
            
            var sub = parseFloat(document.getElementById('subtotalValue').value.replace(',', '.'));
            document.getElementById('totalUI').innerText = '$' + sub.toFixed(2);
        }

        // Cambio de dirección en el Select
        document.getElementById('selectDireccion').addEventListener('change', function () {
            var dirId = this.value;
            if (dirId !== "0") {
                document.getElementById('nuevaDireccionCampos').style.display = 'none';
                document.getElementById('buscadorContainer').style.display = 'none';
                
                // Pedir coordenadas al backend para la direccion existente
                fetch('/ClienteCarrito/CalcularCostoEnvio?direccionId=' + dirId)
                    .then(res => res.json())
                    .then(data => {
                        if (data && data.exito) {
                            actualizarResumenEnvio(data.costo, data.distancia, data.tiempo);
                        }
                    });
                
                // Nota: Para mover el mapa, necesitamos las coordenadas de la dirección guardada. 
                // Lo ideal sería que CalcularCostoEnvio también las devuelva, pero como el usuario 
                // ya la seleccionó, el mapa es secundario o podríamos añadir data-lat y data-lng a las options.
            } else {
                document.getElementById('nuevaDireccionCampos').style.display = 'block';
                document.getElementById('buscadorContainer').style.display = 'block';
                var lat = document.getElementById('nuevaLatitud').value;
                if (!lat) {
                    solicitarUbicacion();
                } else {
                    if (marker) {
                        var pos = marker.getLatLng();
                        calcularCostoEnvio(0, pos.lat, pos.lng);
                    }
                }
            }
        });

        function actualizarCamposUbicacion(lat, lng) {
            document.getElementById('nuevaLatitud').value = lat.toFixed(8).replace(',', '.');
            document.getElementById('nuevaLongitud').value = lng.toFixed(8).replace(',', '.');
        }

        // Búsqueda de Direcciones (Nominatim)
        var timerBusqueda;
        document.getElementById('buscadorDireccion').addEventListener('input', function (e) {
            clearTimeout(timerBusqueda);
            var query = e.target.value;
            if (query.length < 3) {
                document.getElementById('listaResultados').style.display = 'none';
                return;
            }

            timerBusqueda = setTimeout(function () {
                fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=5&countrycodes=EC`)
                    .then(res => res.json())
                    .then(data => {
                        var lista = document.getElementById('listaResultados');
                        lista.innerHTML = '';
                        if (data.length > 0) {
                            data.forEach(item => {
                                var div = document.createElement('div');
                                div.className = 'resultado-item';
                                div.innerText = item.display_name;
                                div.onclick = function () {
                                    seleccionarUbicacion(item.lat, item.lon, item.display_name);
                                };
                                lista.appendChild(div);
                            });
                            lista.style.display = 'block';
                        } else {
                            lista.style.display = 'none';
                        }
                    });
            }, 500);
        });

        document.addEventListener('click', function(e) {
            if (e.target.id !== 'buscadorDireccion') {
                document.getElementById('listaResultados').style.display = 'none';
            }
        });

        function seleccionarUbicacion(lat, lng, nombreCompleto) {
            var latFloat = parseFloat(lat);
            var lngFloat = parseFloat(lng);
            
            map.setView([latFloat, lngFloat], 16);
            agregarOMoverMarcador(latFloat, lngFloat);
            
            document.getElementById('buscadorDireccion').value = nombreCompleto;
            document.getElementById('listaResultados').style.display = 'none';
            document.getElementById('nuevaCalle').value = nombreCompleto.split(',')[0];
            
            actualizarCamposUbicacion(latFloat, lngFloat);
            calcularCostoEnvio(0, latFloat, lngFloat);
            
            document.getElementById('selectDireccion').value = "0";
            document.getElementById('nuevaDireccionCampos').style.display = 'block';
        }

        function obtenerNombreCalle(lat, lng) {
            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
                .then(res => res.json())
                .then(data => {
                    if (data && data.display_name) {
                        document.getElementById('nuevaCalle').value = data.address.road || data.display_name.split(',')[0];
                        if (data.address.city || data.address.town) {
                            document.getElementById('nuevaCiudad').value = data.address.city || data.address.town;
                        }
                    }
                })
                .catch(err => console.log(err));
        }

        function calcularCostoEnvio(dirId, lat, lon) {
            var url = '/ClienteCarrito/CalcularCostoEnvio?direccionId=' + dirId;
            if (lat !== undefined && lon !== undefined) {
                url += '&lat=' + lat + '&lon=' + lon;
            }
            
            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if (data && data.exito) {
                        actualizarResumenEnvio(data.costo, data.distancia, data.tiempo);
                    }
                })
                .catch(err => console.error(err));
        }

        function actualizarResumenEnvio(costo, distancia, tiempo) {
            var costoUI = document.getElementById('costoEnvioUI');
            costoUI.innerText = '$' + costo.toFixed(2);
            costoUI.classList.remove('text-danger');
            costoUI.classList.add('text-success');
            costoUI.style.fontSize = '';
            costoUI.style.textAlign = '';
            costoUI.style.maxWidth = '';
            
            if (distancia) {
                document.getElementById('distanciaInfo').innerText = distancia.toFixed(1) + ' km';
            } else {
                document.getElementById('distanciaInfo').innerText = 'Tarifa base';
            }

            if (tiempo) {
                document.getElementById('tiempoInfo').innerText = 'Tiempo aprox: ' + Math.ceil(tiempo) + ' min';
            } else {
                document.getElementById('tiempoInfo').innerText = '';
            }

            recalcularTotal();
        }

        function recalcularTotal() {
            var sub = parseFloat(document.getElementById('subtotalValue').value.replace(',', '.'));
            
            var costoEnvioTexto = document.getElementById('costoEnvioUI').innerText.replace('$', '').replace(',', '.');
            var costoEnvio = isNaN(parseFloat(costoEnvioTexto)) ? 1.50 : parseFloat(costoEnvioTexto);
            
            var descuento = parseFloat(document.getElementById('descuentoValue').value);
            
            var total = sub + costoEnvio - descuento;
            if (total < 0) total = 0;
            
            document.getElementById('totalUI').innerText = '$' + total.toFixed(2);
        }

        function aplicarCupon() {
            var codigo = document.getElementById('cuponInput').value;
            var mensaje = document.getElementById('cuponMensaje');
            var formInput = document.getElementById('cuponCodigoForm');
            var descValue = document.getElementById('descuentoValue');
            var descRow = document.getElementById('descuentoRow');
            var descUI = document.getElementById('descuentoUI');

            if (!codigo) {
                mensaje.className = "form-text mt-2 text-danger";
                mensaje.innerText = "Ingresa un código.";
                mensaje.style.display = "block";
                return;
            }

            // AJAX call
            fetch('/ClienteCarrito/AplicarCupon', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: new URLSearchParams({ codigo: codigo })
            })
            .then(res => res.json())
            .then(data => {
                if (data.exito) {
                    mensaje.className = "form-text mt-2 text-success fw-bold";
                    mensaje.innerText = data.mensaje;
                    
                    formInput.value = codigo;
                    descValue.value = data.descuento;
                    descUI.innerText = "-$" + parseFloat(data.descuento).toFixed(2);
                    document.getElementById('codigoCuponAplicadoUI').innerText = codigo;
                    descRow.style.setProperty("display", "flex", "important");
                    
                    recalcularTotal();
                } else {
                    mensaje.className = "form-text mt-2 text-danger fw-bold";
                    mensaje.innerText = data.mensaje;
                    
                    formInput.value = "";
                    descValue.value = 0;
                    descRow.style.setProperty("display", "none", "important");
                    
                    recalcularTotal();
                }
                mensaje.style.display = "block";
            })
            .catch(err => {
                mensaje.className = "form-text mt-2 text-danger";
                mensaje.innerText = "Error al validar el cupón.";
                mensaje.style.display = "block";
            });
        }

        function togglePaymentSections() {
            var inputActivo = document.querySelector('input[name="metodoPago"]:checked');
            var metodo = inputActivo ? inputActivo.value : 'Efectivo';
            
            var seccionTarjeta = document.getElementById('seccionTarjeta');
            var seccionTransferencia = document.getElementById('seccionTransferencia');
            
            seccionTarjeta.style.display = 'none';
            seccionTransferencia.style.display = 'none';
            
            document.getElementById('numeroTarjeta').removeAttribute('required');
            document.getElementById('expiracion').removeAttribute('required');
            document.getElementById('cvv').removeAttribute('required');
            document.getElementById('comprobante').removeAttribute('required');

            if (metodo === 'Tarjeta') {
                seccionTarjeta.style.display = 'block';
                document.getElementById('numeroTarjeta').setAttribute('required', 'required');
                document.getElementById('expiracion').setAttribute('required', 'required');
                document.getElementById('cvv').setAttribute('required', 'required');
            } else if (metodo === 'Transferencia') {
                seccionTransferencia.style.display = 'block';
                document.getElementById('comprobante').setAttribute('required', 'required');
            }
        }

        // Lógicas de tarjeta (Mantenidas del original)
        function formatearTarjeta(input) {
            let value = input.value.replace(/\D/g, '');
            let tipo = '';
            let maxLength = 16;

            if (value.startsWith('34') || value.startsWith('37')) { tipo = 'Amex'; maxLength = 15; }
            else if (value.startsWith('4')) { tipo = 'Visa'; }
            else if (value.startsWith('5')) { tipo = 'Mastercard'; }
            else if (value.startsWith('6')) { tipo = 'Discover'; }

            document.getElementById('tarjetaTipo').innerText = tipo;
            value = value.substring(0, maxLength);

            let formatted = '';
            if (tipo === 'Amex') {
                if (value.length > 4) {
                    formatted += value.substring(0, 4) + ' ';
                    if (value.length > 10) {
                        formatted += value.substring(4, 10) + ' ' + value.substring(10, 15);
                    } else {
                        formatted += value.substring(4, 10);
                    }
                } else { formatted = value; }
            } else {
                formatted = value.replace(/(\d{4})(?=\d)/g, '$1 ');
            }
            input.value = formatted;
        }

        function formatearExpiracion(input) {
            let value = input.value.replace(/\D/g, '');
            if (value.length > 2) {
                value = value.substring(0, 2) + '/' + value.substring(2, 4);
            }
            input.value = value;
        }

        function luhnCheck(num) {
            let arr = (num + '').split('').reverse().map(x => parseInt(x));
            let sum = arr.reduce((acc, val, i) => i % 2 !== 0 ? acc + (val * 2 > 9 ? val * 2 - 9 : val * 2) : acc + val, 0);
            return sum % 10 === 0;
        }

        function validarFormulario(e) {
            // Validar que haya dirección si se elige el mapa
            var dirId = document.getElementById('selectDireccion').value;
            if (dirId === "0") {
                var lat = document.getElementById('nuevaLatitud').value;
                if (!lat) {
                    alert("Por favor, selecciona una ubicación en el mapa.");
                    return false;
                }
            }

            var inputActivo = document.querySelector('input[name="metodoPago"]:checked');
            var metodo = inputActivo ? inputActivo.value : 'Efectivo';
            
            if (metodo === 'Tarjeta') {
                var num = document.getElementById('numeroTarjeta').value.replace(/\D/g, '');
                var exp = document.getElementById('expiracion').value;
                var cvv = document.getElementById('cvv').value;
                var err = document.getElementById('tarjetaError');
                err.style.display = 'none';

                if (num.length < 15 || !luhnCheck(num)) {
                    err.innerText = "Número de tarjeta inválido (Luhn).";
                    err.style.display = 'block';
                    return false;
                }

                var parts = exp.split('/');
                if (parts.length !== 2) {
                    err.innerText = "Expiración inválida. Usa MM/AA.";
                    err.style.display = 'block';
                    return false;
                }
                
                var m = parseInt(parts[0], 10);
                var y = parseInt("20" + parts[1], 10);
                if (m < 1 || m > 12) {
                    err.innerText = "Mes de expiración inválido.";
                    err.style.display = 'block';
                    return false;
                }

                var now = new Date();
                var expDate = new Date(y, m - 1);
                if (expDate < new Date(now.getFullYear(), now.getMonth())) {
                    err.innerText = "La tarjeta ha expirado.";
                    err.style.display = 'block';
                    return false;
                }

                if (cvv.length < 3) {
                    err.innerText = "CVV inválido.";
                    err.style.display = 'block';
                    return false;
                }
            }
            return true;
        }
    </script>
}
