@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["PanelRepartidorTitle"];
    var repartidor = ViewBag.Repartidor as Delivery.Modelos.Entidades.Repartidor;
    var pedidosRecientes = ViewBag.PedidosRecientes as System.Collections.Generic.List<Delivery.Modelos.Entidades.Pedido>;
}

<h1>@Localizer["PanelRepartidorTitle"]</h1>
<p>@Localizer["BienvenidoRepartidorMsg"]</p>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

@if (ViewBag.Estado == "Pendiente" || ViewBag.Estado == "Rechazado")
{
    <div class="alert alert-warning mt-4">
        <h4><i class="bi bi-exclamation-triangle"></i> @string.Format(Localizer["CuentaEstadoTitle"].Value, ViewBag.Estado)</h4>
        @if (ViewBag.Estado == "Pendiente")
        {
            <p>@Localizer["CuentaPendienteMsg"]</p>
        }
        else
        {
            <p>@Localizer["CuentaRechazadaMsg"]</p>
        }
    </div>
}
else
{
    <h4 class="mt-4 mb-3 text-primary">@Localizer["ResumenDashboard"]</h4>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        <div class="col" data-aos="fade-up" data-aos-delay="100">
            <div class="card glass-card h-100 text-center p-3">
                <i class="bi bi-box-seam text-primary fs-1 mb-2"></i>
                <h5 class="text-light">@Localizer["TotalEntregasDashboard"]</h5>
                <h2 class="fw-bold" style="color: #a78bfa;">@ViewBag.TotalEntregados</h2>
            </div>
        </div>
        <div class="col" data-aos="fade-up" data-aos-delay="200">
            <div class="card glass-card h-100 text-center p-3">
                <i class="bi bi-bicycle text-success fs-1 mb-2"></i>
                <h5 class="text-light">@Localizer["PedidosActivosDashboard"]</h5>
                <h2 class="fw-bold text-success">@ViewBag.PedidosActivos</h2>
            </div>
        </div>
        @if (repartidor != null)
        {
            <div class="col" data-aos="fade-up" data-aos-delay="300">
                <div class="card glass-card h-100 text-center p-3">
                    <i class="bi bi-star-fill text-warning fs-1 mb-2"></i>
                    <h5 class="text-light">@Localizer["CalificacionDashboard"]</h5>
                    <h2 class="fw-bold text-warning">@(repartidor.CalificacionPromedio?.ToString("0.0") ?? Localizer["SinCalificaciones"].Value)</h2>
                </div>
            </div>
            <div class="col" data-aos="fade-up" data-aos-delay="400">
                <div class="card glass-card h-100 text-center p-3">
                    <i class="bi bi-shield-check text-info fs-1 mb-2"></i>
                    <h5 class="text-light">@Localizer["EstadoDashboard"]</h5>
                    <h2 class="fw-bold text-info">@repartidor.EstadoAprobacion</h2>
                </div>
            </div>
        }
    </div>

    <hr style="border-color: var(--glass-border);" />

    <div class="d-flex flex-wrap gap-3 mb-4">
        <a asp-controller="RepartidorPedidos" asp-action="Index" class="btn btn-liquid btn-liquid-primary flex-grow-1">@Localizer["VerMisPedidosAsignados"]</a>
        <a asp-controller="RepartidorPerfil" asp-action="Index" class="btn btn-liquid flex-grow-1">@Localizer["MiPerfil"]</a>
        <a asp-controller="RepartidorUbicacion" asp-action="Index" class="btn btn-liquid flex-grow-1">@Localizer["ActualizarUbicacion"]</a>
    </div>

    <div class="d-flex flex-wrap gap-3 mt-4">
        <!-- UML: Status Control Form -> Toggle Status -->
        <form asp-controller="DashboardRepartidor" asp-action="ToggleStatus" method="post" class="d-inline flex-grow-1">
            <button type="submit" class="btn btn-liquid w-100">
                @Localizer["CambiarDisponibilidadBtn"] (@Localizer["EstadoActualLBL"]: @(repartidor?.Estado.ToString() ?? "Activo"))
            </button>
        </form>

        <!-- UML: Incident Report Form -->
        <a asp-controller="RepartidorIncidentes" asp-action="Reportar" class="btn btn-liquid flex-grow-1" style="--liquid-bg: #f59e0b; --liquid-bg-hover: #d97706;">
            <i class="bi bi-exclamation-triangle"></i> @Localizer["ReportarIncidenteBtn"]
        </a>

        <!-- UML: ViewEarnings -> Calculate_Commission -->
        <a asp-controller="DashboardRepartidor" asp-action="Ganancias" class="btn btn-liquid flex-grow-1" style="--liquid-bg: #10b981; --liquid-bg-hover: #059669;">
            <i class="bi bi-wallet2"></i> @Localizer["MisGananciasBtn"]
        </a>
    </div>

    <hr style="border-color: var(--glass-border);" class="my-5" />

    <h4 class="mb-4 text-primary">@Localizer["UltimosPedidos"]</h4>
    @if (pedidosRecientes == null || !pedidosRecientes.Any())
    {
        <p class="text-muted">@Localizer["NoPedidosAsignados"]</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var pedido in pedidosRecientes)
            {
                <div class="col" data-aos="fade-up">
                    <div class="card glass-card h-100">
                        <div class="card-body">
                            <h5 class="card-title text-primary fw-bold">@Localizer["PedidoNum"] #@pedido.Id</h5>
                            <p class="card-text text-light"><strong>@Localizer["RestauranteTh"]:</strong> @(pedido.Restaurante?.Nombre ?? Localizer["RestauranteTh"].Value)</p>
                            <p class="card-text text-light"><strong>@Localizer["EstadoTh"]:</strong> <span class="badge bg-info">@pedido.EstadoPedido</span></p>
                            <p class="card-text text-muted small"><i class="bi bi-clock"></i> @pedido.FechaPedido.ToLocalTime().ToString("g")</p>
                        </div>
                        <div class="card-footer border-top-0 bg-transparent d-flex gap-2">
                            <a asp-controller="RepartidorPedidos" asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-sm btn-outline-info flex-grow-1">@Localizer["VerBtn"]</a>
                            <a asp-controller="RepartidorPedidos" asp-action="CambiarEstado" asp-route-id="@pedido.Id" class="btn btn-sm btn-outline-primary flex-grow-1">@Localizer["CambiarEstadoBtn"]</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
