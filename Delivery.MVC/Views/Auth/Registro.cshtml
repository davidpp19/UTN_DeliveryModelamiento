@model Delivery.Modelos.DTOs.RegistroDto
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["RegistroClienteTitulo"];
}

<div class="row justify-content-center mt-5 mb-5" data-aos="fade-up">
    <div class="col-md-8 col-lg-6">
        <div class="card glass-card">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus fs-1 text-primary mb-2"></i>
                    <h3 class="fw-bold text-light">@Localizer["CreaTuCuenta"]</h3>
                    <p class="text-muted">Únete como cliente y disfruta de los mejores restaurantes.</p>
                </div>
                
                <form asp-action="Registro" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label text-light">@Localizer["Nombres"]</label>
                            <input asp-for="Nombre" class="form-control" placeholder="@Localizer["NombresPlaceholder"]" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Apellidos" class="form-label text-light">@Localizer["Apellidos"]</label>
                            <input asp-for="Apellidos" class="form-control" placeholder="@Localizer["ApellidosPlaceholder"]" />
                            <span asp-validation-for="Apellidos" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-light">@Localizer["CorreoElectronico"]</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="@Localizer["EmailPlaceholder"]" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label text-light">@Localizer["Telefono"]</label>
                        <input asp-for="Telefono" class="form-control" type="tel" placeholder="0987654321" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Cedula" class="form-label text-light">@Localizer["Cedula"]</label>
                        <input asp-for="Cedula" class="form-control" placeholder="1712345678" />
                        <span asp-validation-for="Cedula" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FechaNacimiento" class="form-label text-light">Fecha de Nacimiento</label>
                        <input asp-for="FechaNacimiento" class="form-control" type="date" />
                        <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label text-light">@Localizer["Contrasena"]</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="@Localizer["PasswordPlaceholder"]" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label text-light">@Localizer["ConfirmarContrasena"]</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="@Localizer["PasswordPlaceholder"]" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-liquid btn-liquid-primary btn-lg">@Localizer["Registrarse"]</button>
                    </div>
                </form>
                
                <hr style="border-color: var(--glass-border);" class="my-4" />
                <div class="text-center">
                    <span class="text-muted">@Localizer["YaTienesCuenta"] </span>
                    <a asp-action="Login" class="text-primary fw-bold text-decoration-none">@Localizer["IniciarSesion"]</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
