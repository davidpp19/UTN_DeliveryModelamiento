@model Delivery.Modelos.Entidades.Usuario
@{
    ViewData["Title"] = "Registro de Usuario";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="text-center mb-4 text-primary">Crea tu cuenta en RayoExpres</h3>
                <form asp-action="Registro" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label">Nombres</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Juan" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Apellidos" class="form-label">Apellidos</label>
                            <input asp-for="Apellidos" class="form-control" placeholder="Pérez" />
                            <span asp-validation-for="Apellidos" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Correo Electrónico</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="juan@correo.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label">Teléfono</label>
                        <input asp-for="Telefono" class="form-control" type="tel" placeholder="0987654321" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PasswordHash" class="form-label">Contraseña</label>
                        <input asp-for="PasswordHash" class="form-control" type="password" placeholder="********" />
                        <span asp-validation-for="PasswordHash" class="text-danger"></span>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Registrarse</button>
                    </div>
                </form>
                <div class="mt-4 text-center">
                    <span>¿Ya tienes cuenta? </span>
                    <a asp-action="Login" class="text-decoration-none fw-bold">Inicia Sesión</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
