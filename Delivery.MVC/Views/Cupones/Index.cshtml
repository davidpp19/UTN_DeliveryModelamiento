@model IEnumerable<Delivery.Modelos.Entidades.Cupon>
@{ ViewData["Title"] = "Cupones"; }
<h1 class="my-4">Cupones</h1>
<p><a asp-action="Create" class="btn btn-primary">Crear Nuevo</a></p>
<div class="table-responsive">
<table class="table table-striped table-hover align-middle">
<thead class="table-dark"><tr>
<th>Código</th>
<th>Tipo/Valor</th>
<th>Estado</th>
<th>Vence</th>
<th>Usos</th>
<th>Público</th>
<th>Acciones</th></tr></thead><tbody>
@foreach (var item in Model) {<tr>
<td><span class="badge bg-secondary">@item.Codigo</span></td>
<td>@item.TipoDescuento: @(item.TipoDescuento == Delivery.Modelos.Enums.TipoDescuentoEnum.Porcentaje ? item.ValorDescuento + "%" : "$" + item.ValorDescuento)</td>
<td>
    @if(item.Activo && System.DateTime.UtcNow <= item.FechaFin) {
        <span class="badge bg-success">Activo</span>
    } else if (!item.Activo) {
        <span class="badge bg-danger">Inactivo</span>
    } else {
        <span class="badge bg-warning text-dark">Vencido</span>
    }
</td>
<td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
<td>@item.UsosActuales / @(item.LimiteUsos?.ToString() ?? "∞")</td>
<td>@(item.EsPublico ? "Sí" : "No")</td>
<td>
<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="bi bi-pencil"></i> Editar</a>
<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Eliminar</a>
</td></tr>}
</tbody></table></div>
