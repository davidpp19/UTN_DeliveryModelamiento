@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@{ ViewData["Title"] = Localizer["GestionPedidos"]; }
<div class="container-fluid mt-4" data-aos="fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold m-0"><i class="bi bi-receipt me-2"></i> @Localizer["TodosLosPedidos"]</h1>
    </div>

    <div class="table-responsive table-scrollable glass-card p-4 rounded-4 shadow-lg border-0">
        <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
            <thead class="border-bottom border-secondary">
                <tr>
                    <th class="text-uppercase text-muted small fw-bold">ID</th>
                    <th class="text-uppercase text-muted small fw-bold">Cliente</th>
                    <th class="text-uppercase text-muted small fw-bold">Restaurante</th>
                    <th class="text-uppercase text-muted small fw-bold">Repartidor</th>
                    <th class="text-uppercase text-muted small fw-bold">@Localizer["EstadoTag"]</th>
                    <th class="text-uppercase text-muted small fw-bold">@Localizer["TotalTag"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr class="glass-row">
                        <td class="text-light fw-bold">#@item.Id</td>
                        <td>
                            <span class="text-light"><i class="bi bi-person text-primary me-1"></i> @(item.Usuario?.Nombre ?? "ID: " + item.UsuarioId) @(item.Usuario?.Apellidos ?? "")</span>
                        </td>
                        <td>
                            <span class="text-light"><i class="bi bi-shop text-success me-1"></i> @(item.Restaurante?.Nombre ?? "ID: " + item.RestauranteId)</span>
                        </td>
                        <td>
                            @if(item.RepartidorId.HasValue) {
                                <span class="text-light"><i class="bi bi-bicycle text-info me-1"></i> ID: @item.RepartidorId</span>
                            } else {
                                <span class="text-muted fst-italic">Sin asignar</span>
                            }
                        </td>
                        <td>
                            @if (item.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.Entregado)
                            {
                                <span class="badge bg-success text-white p-2 rounded-pill shadow-sm"><i class="bi bi-check2-circle me-1"></i> Entregado</span>
                            }
                            else if (item.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.Cancelado)
                            {
                                <span class="badge bg-danger text-white p-2 rounded-pill shadow-sm"><i class="bi bi-x-circle me-1"></i> Cancelado</span>
                            }
                            else
                            {
                                <span class="badge bg-primary text-white p-2 rounded-pill shadow-sm"><i class="bi bi-arrow-repeat me-1"></i> @item.EstadoPedido</span>
                            }
                        </td>
                        <td class="text-success fw-bold">
                            $@item.Total.ToString("0.00")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



