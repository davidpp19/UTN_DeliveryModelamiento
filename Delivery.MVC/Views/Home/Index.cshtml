@model Delivery.MVC.Models.HomeViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Inicio"];
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
    var isCliente = isAuthenticated && User.IsInRole("Cliente");
}

@if (isCliente)
{
    <!-- HOME CLIENTE -->
    <div class="container mt-4">
        <div class="alert alert-primary" role="alert">
            <h4>@Localizer["HolaUsuario", User.Identity?.Name ?? ""]</h4>
            <p>@Localizer["MensajeBienvenida"]</p>
        </div>

        @if (Model.Cupones.Any())
        {
            <h5>@Localizer["TusCuponesActivos"]</h5>
            <div class="d-flex flex-row overflow-auto gap-3 pb-2 mb-4">
                @foreach (var cupon in Model.Cupones)
                {
                    <div class="card border-success" style="min-width: 220px;">
                        <div class="card-body text-center">
                            <h5 class="card-title">@cupon.Codigo</h5>
                            <p>@(cupon.TipoDescuento == Delivery.Modelos.Enums.TipoDescuentoEnum.Porcentaje ? $"{cupon.ValorDescuento}%" : $"${cupon.ValorDescuento}") @Localizer["DeDescuento"]</p>
                        </div>
                    </div>
                }
            </div>
        }

        <h3 id="restaurantes" data-aos="fade-up">@Localizer["RestaurantesDisponibles"]</h3>
        @if (Model.RestaurantesDestacados.Any())
        {
            <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
                @foreach (var res in Model.RestaurantesDestacados)
                {
                    <div class="col" data-aos="fade-up" data-aos-delay="100">
                        <div class="card glass-card h-100">
                            <img src="@res.LogoUrl" class="card-img-top glass-img" alt="@res.Nombre" 
                                 onerror="this.src='https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&q=80'" />
                            <div class="card-body">
                                <h5 class="card-title text-primary">@res.Nombre</h5>
                                <p class="text-muted mb-1">@res.Categoria</p>
                                <p class="small text-muted mb-1"><i class="bi bi-geo-alt"></i> @res.Calle, @res.Ciudad</p>
                                @if (res.HoraApertura.HasValue && res.HoraCierre.HasValue)
                                {
                                    <p class="small text-muted mb-1"><i class="bi bi-clock"></i> @Localizer["Horario"]: @res.HoraApertura?.ToString(@"hh\:mm") — @res.HoraCierre?.ToString(@"hh\:mm")</p>
                                }
                                <p class="small text-muted"><i class="bi bi-bicycle"></i> @Localizer["Envio"]: $1.50 (Base)</p>
                            </div>
                            <div class="card-footer bg-transparent border-0 text-center pb-3">
                                <a class="btn btn-liquid btn-liquid-primary w-100" asp-action="Restaurante" asp-route-id="@res.Id">@Localizer["VerMenu"]</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p>@Localizer["NoHayRestaurantes"]</p>
        }

        <h3 class="mb-3">@Localizer["ProductosPopulares"]</h3>
        @if (Model.ProductosDestacados.Any())
        {
            <div class="row row-cols-2 row-cols-md-4 g-4 mb-5">
                @foreach (var prod in Model.ProductosDestacados)
                {
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-body">
                                <h6>@prod.Nombre</h6>
                                <p class="text-success">$@prod.Precio.ToString("0.00")</p>
                                <form asp-controller="ClienteCarrito" asp-action="Agregar" method="post">
                                    <input type="hidden" name="productoId" value="@prod.Id" />
                                    <input type="hidden" name="cantidad" value="1" />
                                    <input type="hidden" name="restauranteId" value="@prod.RestauranteId" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">@Localizer["AgregarAlCarrito"]</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <!-- HOME PÚBLICO (visitante, admin, repartidor, restaurante) -->
    <div class="p-5 mb-4 rounded-3 text-center mt-3" style="background: radial-gradient(circle at center, rgba(168, 85, 247, 0.15) 0%, transparent 70%); border: 1px solid rgba(255,255,255,0.05);" data-aos="zoom-in">
        <div class="container-fluid py-5">
            <img src="~/img/logo.png" alt="RayoExpres Logo" style="height: 120px; object-fit: contain; margin-bottom: 20px; mix-blend-mode: screen;" />
            <p class="col-md-8 mx-auto fs-4 text-muted mt-3">@Localizer["TituloHero"]</p>
            <p class="lead text-light">@Localizer["SubtituloHero"]</p>
            <div class="mt-5">
                @if (!isAuthenticated)
                {
                    <a asp-controller="Auth" asp-action="SeleccionTipoRegistro" class="btn btn-liquid btn-liquid-primary btn-lg me-3 px-5 py-3 fs-5">@Localizer["RegistrateAhora"]</a>
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-liquid btn-lg px-5 py-3 fs-5">@Localizer["IniciarSesion"]</a>
                }
                else
                {
                    var dashboardController = User.IsInRole("Admin") ? "DashboardAdministrador" :
                                              User.IsInRole("Repartidor") ? "DashboardRepartidor" :
                                              User.IsInRole("Restaurante") ? "DashboardRestaurante" : "Home";
                    <a asp-controller="@dashboardController" asp-action="Index" class="btn btn-liquid btn-liquid-primary btn-lg px-5 py-3">@Localizer["IrAMiPanel"]</a>
                }
            </div>
        </div>
    </div>

    <div class="container mt-5">
        <div class="row text-center mb-5" id="beneficios">
            <div class="col-md-4">
                <h4>@Localizer["EntregasRapidasTitle"]</h4>
                <p class="text-muted">@Localizer["EntregasRapidasDesc"]</p>
            </div>
            <div class="col-md-4">
                <h4>@Localizer["PagosSegurosTitle"]</h4>
                <p class="text-muted">@Localizer["PagosSegurosDesc"]</p>
            </div>
            <div class="col-md-4">
                <h4>@Localizer["MejoresLocalesTitle"]</h4>
                <p class="text-muted">@Localizer["MejoresLocalesDesc"]</p>
            </div>
        </div>

        <hr />

        <div id="como-funciona" class="my-5" data-aos="fade-up">
            <h3 class="text-center mb-5 fw-bold" style="color: #a78bfa;">@Localizer["ComoFuncionaTitle"]</h3>
            <div class="row text-center g-4">
                <div class="col-md-3" data-aos="fade-up" data-aos-delay="100">
                    <div class="p-4 glass-card h-100">
                        <h2 class="display-4 fw-bold" style="color: rgba(255,255,255,0.1)">1</h2>
                        <h5 class="text-light">@Localizer["BuscaTitle"]</h5>
                        <p class="small text-muted">@Localizer["BuscaDesc"]</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="fade-up" data-aos-delay="200">
                    <div class="p-4 glass-card h-100">
                        <h2 class="display-4 fw-bold" style="color: rgba(255,255,255,0.1)">2</h2>
                        <h5 class="text-light">@Localizer["PideTitle"]</h5>
                        <p class="small text-muted">@Localizer["PideDesc"]</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="fade-up" data-aos-delay="300">
                    <div class="p-4 glass-card h-100">
                        <h2 class="display-4 fw-bold" style="color: rgba(255,255,255,0.1)">3</h2>
                        <h5 class="text-light">@Localizer["PagaTitle"]</h5>
                        <p class="small text-muted">@Localizer["PagaDesc"]</p>
                    </div>
                </div>
                <div class="col-md-3" data-aos="fade-up" data-aos-delay="400">
                    <div class="p-4 glass-card h-100">
                        <h2 class="display-4 fw-bold" style="color: rgba(255,255,255,0.1)">4</h2>
                        <h5 class="text-light">@Localizer["DisfrutaTitle"]</h5>
                        <p class="small text-muted">@Localizer["DisfrutaDesc"]</p>
                    </div>
                </div>
            </div>
        </div>

        <hr />

        @* ──── TODOS LOS RESTAURANTES (vista pública) ──── *@
        <div id="restaurantes" class="my-5">
            <h3 class="mb-4 text-center">@Localizer["RestaurantesAliadosTitle"]</h3>

            @if (Model.TodosRestaurantes.Any())
            {
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @foreach (var res in Model.TodosRestaurantes)
                    {
                        <div class="col" data-aos="fade-up" data-aos-delay="100">
                            <div class="card glass-card h-100">
                                <img src="@res.LogoUrl"
                                     class="card-img-top glass-img"
                                     alt="@res.Nombre"
                                     onerror="this.src='https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&q=80'" />
                                <div class="card-body">
                                    <h5 class="card-title" style="color: #a78bfa;">@res.Nombre</h5>
                                    <p class="text-muted small mb-1">@res.Categoria</p>
                                    <p class="small text-muted mb-1"><i class="bi bi-geo-alt"></i> @res.Calle, @res.Ciudad</p>
                                    @if (res.HoraApertura.HasValue && res.HoraCierre.HasValue)
                                    {
                                        <p class="small text-muted mb-1"><i class="bi bi-clock"></i> Horario: @res.HoraApertura?.ToString(@"hh\:mm") — @res.HoraCierre?.ToString(@"hh\:mm")</p>
                                    }
                                    <p class="small text-muted"><i class="bi bi-bicycle"></i> Costo envío: $1.50 (Base)</p>
                                </div>
                                <div class="card-footer bg-transparent border-0 text-center pb-3">
                                    <a class="btn btn-liquid w-100" asp-controller="Auth" asp-action="Login">@Localizer["IniciaSesionVerMenu"]</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-secondary text-center">@Localizer["NoRestaurantesDisponibles"]</div>
            }
        </div>
    </div>
}
