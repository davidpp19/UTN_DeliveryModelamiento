@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.Entidades.Resena
@{
    ViewData["Title"] = Localizer["CalificarPedido"];
}

<h1 class="my-4"><i class="bi bi-star-fill text-warning"></i> @Localizer["CalificarPedido"] #@Model.PedidoId</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Calificar" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="RestauranteId" />
            <input type="hidden" asp-for="PedidoId" />

            <div class="mb-3">
                <label asp-for="CalificacionRestaurante" class="form-label">@Localizer["CalificacionEstrellasTag"]</label>
                <select asp-for="CalificacionRestaurante" class="form-select">
                    <option value="5">@Localizer["CincoExcelente"]</option>
                    <option value="4">@Localizer["CuatroMuyBueno"]</option>
                    <option value="3">@Localizer["TresBueno"]</option>
                    <option value="2">@Localizer["DosRegular"]</option>
                    <option value="1">@Localizer["UnoMalo"]</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="ComentarioRestaurante" class="form-label">@Localizer["ComentarioOpcionalTag"]</label>
                <textarea asp-for="ComentarioRestaurante" class="form-control" rows="3" placeholder="@Localizer["QueTeParecioComidaPlaceholder"]"></textarea>
                <span asp-validation-for="ComentarioRestaurante" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-warning fw-bold">@Localizer["EnviarCalificacionBtn"]</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">@Localizer["CancelarBtn"]</a>
            </div>
        </form>
    </div>
</div>
