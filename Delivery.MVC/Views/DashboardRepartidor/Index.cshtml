@{
    ViewData["Title"] = "Panel de Repartidor";
    var repartidor = ViewBag.Repartidor as Delivery.Modelos.Entidades.Repartidor;
    var pedidosRecientes = ViewBag.PedidosRecientes as System.Collections.Generic.List<Delivery.Modelos.Entidades.Pedido>;
}

<h1>Panel de Repartidor</h1>
<p>Bienvenido. Gestiona tus entregas y actualiza tu estado.</p>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

@if (ViewBag.Estado == "Pendiente" || ViewBag.Estado == "Rechazado")
{
    <div class="alert alert-warning mt-4">
        <h4><i class="bi bi-exclamation-triangle"></i> Cuenta @ViewBag.Estado</h4>
        @if (ViewBag.Estado == "Pendiente")
        {
            <p>Tu solicitud ha sido enviada correctamente. Un administrador revisará tu información y aprobará o rechazará tu cuenta. Mientras tanto podrás ingresar al sistema, pero tus funciones permanecerán bloqueadas.</p>
        }
        else
        {
            <p>Tu solicitud ha sido rechazada por un administrador. Revisa tus notificaciones para conocer el motivo. No podrás operar en la plataforma.</p>
        }
    </div>
}
else
{
    <h4>Resumen</h4>
    <table class="table table-bordered" style="max-width: 500px;">
        <tr>
            <th>Total Entregas Completadas</th>
            <td>@ViewBag.TotalEntregados</td>
        </tr>
        <tr>
            <th>Pedidos Activos</th>
            <td>@ViewBag.PedidosActivos</td>
        </tr>
        @if (repartidor != null)
        {
            <tr>
                <th>Calificación</th>
                <td>@(repartidor.CalificacionPromedio?.ToString("0.0") ?? "Sin calificaciones")</td>
            </tr>
            <tr>
                <th>Estado</th>
                <td>@repartidor.EstadoAprobacion</td>
            </tr>
        }
    </table>

    <hr />

    <h4>Mis Notificaciones Recientes</h4>
    @if (ViewBag.Notificaciones != null && ((IEnumerable<Delivery.Modelos.Entidades.Notificacion>)ViewBag.Notificaciones).Any())
    {
        <ul class="list-group mb-4">
            @foreach (var noti in (IEnumerable<Delivery.Modelos.Entidades.Notificacion>)ViewBag.Notificaciones)
            {
                <li class="list-group-item">
                    <strong>@noti.Titulo</strong><br />
                    <small class="text-muted">@noti.CreadaEn.ToLocalTime().ToString("g")</small>
                    <p class="mb-0">@noti.Mensaje</p>
                </li>
            }
        </ul>
    }
    else
    {
        <p>No tienes notificaciones.</p>
    }

    <hr />

    <h4>Acciones Rápidas</h4>
    <a asp-controller="RepartidorPedidos" asp-action="Index">Ver Mis Pedidos Asignados</a>
    <span>|</span> <a asp-controller="RepartidorUbicacion" asp-action="Index">Actualizar Mi Ubicación</a>

    <hr />

    <h4>Últimos 5 Pedidos</h4>
    @if (pedidosRecientes == null || !pedidosRecientes.Any())
    {
        <p>No tienes pedidos asignados aún.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Pedido #</th>
                    <th>Restaurante</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pedido in pedidosRecientes)
                {
                    <tr>
                        <td>@pedido.Id</td>
                        <td>@(pedido.Restaurante?.Nombre ?? "Restaurante")</td>
                        <td>@pedido.EstadoPedido</td>
                        <td>@pedido.FechaPedido.ToLocalTime().ToString("g")</td>
                        <td>
                            <a asp-controller="RepartidorPedidos" asp-action="Details" asp-route-id="@pedido.Id">Ver</a>
                            |
                            <a asp-controller="RepartidorPedidos" asp-action="CambiarEstado" asp-route-id="@pedido.Id">Cambiar Estado</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
