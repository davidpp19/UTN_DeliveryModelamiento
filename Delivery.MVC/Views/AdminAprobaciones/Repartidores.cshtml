@model IEnumerable<Delivery.Modelos.DTOs.RepartidorPendienteDto>
@{
    ViewData["Title"] = "Aprobaciones de Repartidores";
}

<div class="container mt-4">
    <h2>Solicitudes de Repartidores Pendientes</h2>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">No hay solicitudes pendientes en este momento.</div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Cédula</th>
                    <th>Vehículo / Placa</th>
                    <th>Licencia</th>
                    <th>Foto Licencia</th>
                    <th>Fecha Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Nombres) @(item.Apellidos)</td>
                        <td>@item.Email</td>
                        <td>@item.Cedula</td>
                        <td>@item.TipoVehiculo - @item.Placa</td>
                        <td>@item.LicenciaConducir</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.FotoLicenciaUrl))
                            {
                                <a href="@item.FotoLicenciaUrl" target="_blank">
                                    <img src="@item.FotoLicenciaUrl" alt="Licencia" style="max-height: 50px; max-width: 80px;" />
                                </a>
                            }
                            else
                            {
                                <span>No aplica</span>
                            }
                        </td>
                        <td>@item.CreadoEn.ToString("dd/MM/yyyy")</td>
                        <td>
                            <form method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" asp-action="AprobarRepartidor" class="btn btn-sm btn-success mb-1">Aprobar</button>
                                
                                <div class="input-group input-group-sm mt-1">
                                    <input type="text" name="motivoRechazo" class="form-control" placeholder="Motivo de rechazo" required />
                                    <button type="submit" asp-action="RechazarRepartidor" class="btn btn-danger">Rechazar</button>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
