@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@{ ViewData["Title"] = Localizer["PedidosTitle"]; }
<h1 class="my-4">@Localizer["PedidosTitle"]</h1>
<p><a asp-action="Create" class="btn btn-primary">@Localizer["CrearNuevoBtn"]</a></p>
<div class="table-responsive">
<table class="table table-striped table-hover align-middle">
<thead class="table-dark"><tr>
<th>Id</th>
<th>Cliente</th>
<th>Restaurante</th>
<th>Repartidor</th>
<th>Dirección</th>
<th>@Localizer["AccionesTag"]</th></tr></thead><tbody>
@foreach (var item in Model) {<tr>
<td>@Html.DisplayFor(modelItem => item.Id)</td>
<td>@(item.Usuario?.Nombre + " " + item.Usuario?.Apellidos)</td>
<td>@(item.Restaurante?.Nombre)</td>
<td>@(item.Repartidor?.Usuario != null ? item.Repartidor.Usuario.Nombre + " " + item.Repartidor.Usuario.Apellidos : "Pendiente")</td>
<td>@(item.DireccionEntrega?.Calle + " " + item.DireccionEntrega?.Numero)</td>
<td>
<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">@Localizer["EditarBtn"]</a>
<a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">@Localizer["DetallesBtn"]</a>
<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">@Localizer["EliminarBtn"]</a>
</td></tr>}
</tbody></table></div>
