@{
    ViewData["Title"] = "Verificar Cuenta";
    var email = ViewBag.Email as string;
}

<div class="row justify-content-center my-5" data-aos="fade-up">
    <div class="col-md-6 col-lg-5">
        <div class="card glass-card">
            <div class="card-body p-5 text-center">
                <i class="bi bi-envelope-check text-primary mb-3" style="font-size: 3.5rem;"></i>
                <h3 class="fw-bold text-light mb-4">Verificación de Correo</h3>
                
                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-info glass-card" style="background: rgba(13, 202, 240, 0.1); border: 1px solid rgba(13, 202, 240, 0.3);">@TempData["Mensaje"]</div>
                }

                <p class="text-muted mb-4">Ingresa el código de 6 dígitos enviado a <strong class="text-info">@email</strong></p>

                <form asp-action="VerificarEmail" method="post">
                    <input type="hidden" name="email" value="@email" />
                    
                    <div class="mb-4">
                        <input type="text" name="codigo" class="form-control form-control-lg text-center text-primary" 
                               placeholder="123456" maxlength="6" style="letter-spacing: 5px; font-weight: bold; font-size: 1.25rem;" required />
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-liquid btn-liquid-primary btn-lg">Verificar Cuenta</button>
                    </div>
                </form>

                <hr style="border-color: var(--glass-border);" class="my-4" />
                <div class="mt-4">
                    <form asp-action="ReenviarCodigo" method="post" id="form-reenviar">
                        <input type="hidden" name="email" value="@email" />
                        <button type="submit" class="btn btn-outline-info rounded-pill px-4">¿No recibiste el código? Reenviar</button>
                    </form>
                    
                    <div id="res-reenviar" class="text-success mt-3" style="display:none; font-weight: bold;"></div>
                    <div id="err-reenviar" class="text-danger mt-3" style="display:none; font-weight: bold;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('form-reenviar').addEventListener('submit', function (e) {
            e.preventDefault();
            manejarEnvio(this, '¿No recibiste el código por correo? Reenviar', 'Reenviando al correo...', 'Código reenviado');
        });

        function manejarEnvio(form, originalText, loadingText, successText) {
            const btn = form.querySelector('button');
            const resDiv = document.getElementById('res-reenviar');
            const errDiv = document.getElementById('err-reenviar');
            
            btn.disabled = true;
            btn.innerHTML = loadingText;
            resDiv.style.display = 'none';
            errDiv.style.display = 'none';

            fetch(form.action || form.getAttribute('action') || '@Url.Action("ReenviarCodigo", "Auth")', {
                method: 'POST',
                body: new FormData(form)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    resDiv.innerText = data.mensaje;
                    resDiv.style.display = 'block';
                    btn.innerHTML = successText;
                } else {
                    errDiv.innerText = data.mensaje;
                    errDiv.style.display = 'block';
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            })
            .catch(err => {
                errDiv.innerText = "Error de conexión al enviar el código.";
                errDiv.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = originalText;
            });
        }
    </script>
}
