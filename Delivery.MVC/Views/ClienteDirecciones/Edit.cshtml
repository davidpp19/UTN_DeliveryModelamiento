@model Delivery.Modelos.Entidades.Direccion
@{ ViewData["Title"] = "Editar Dirección"; }

<h1>Editar Dirección</h1>
<hr />

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="UsuarioId" />

    <div>
        <label asp-for="Alias">Alias (Casa, Trabajo, Universidad…)</label>
        <input asp-for="Alias" placeholder="Ej: Casa" />
        <span asp-validation-for="Alias" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Calle">Calle Principal</label>
        <input asp-for="Calle" placeholder="Ej: Av. 17 de Julio" />
        <span asp-validation-for="Calle" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Numero">Número</label>
        <input asp-for="Numero" placeholder="Ej: 5-32" />
        <span asp-validation-for="Numero" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Ciudad">Ciudad</label>
        <input asp-for="Ciudad" placeholder="Ej: Ibarra" />
        <span asp-validation-for="Ciudad" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Referencia">Referencia</label>
        <input asp-for="Referencia" placeholder="Ej: Frente al parque central" />
        <span asp-validation-for="Referencia" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Latitud">Latitud (opcional)</label>
        <input asp-for="Latitud" />
        <span asp-validation-for="Latitud" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Longitud">Longitud (opcional)</label>
        <input asp-for="Longitud" />
        <span asp-validation-for="Longitud" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="EsPrincipal">¿Es mi dirección principal?</label>
        <input asp-for="EsPrincipal" type="checkbox" />
    </div>

    <br />
    <button type="submit">Actualizar Dirección</button>
    <a asp-action="Index">Cancelar</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
