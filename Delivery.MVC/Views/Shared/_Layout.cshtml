<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RayoExpres</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">RayoExpres</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @* ─── MENÚ IZQUIERDO POR ROL ─── *@
                    <ul class="navbar-nav flex-grow-1">

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @* ── CLIENTE ── *@
                            if (User.IsInRole("Cliente"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Restaurantes</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteCarrito" asp-action="Index">Mi Carrito</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteHistorialPedidos" asp-action="Index">Mis Pedidos</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteDirecciones" asp-action="Index">Mis Direcciones</a></li>
                            }
                            @* ── ADMINISTRADOR ── *@
                            else if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownAdmin" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        Administración
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="navbarDropdownAdmin">
                                        <li><a class="dropdown-item" asp-controller="DashboardAdministrador" asp-action="Index">Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminUsuarios" asp-action="Index">Usuarios</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminRestaurantes" asp-action="Index">Restaurantes</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminRepartidores" asp-action="Index">Repartidores</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminProductos" asp-action="Index">Productos</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminPedidos" asp-action="Index">Pedidos</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminCupones" asp-action="Index">Cupones</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-warning" asp-controller="AdminAprobaciones" asp-action="Repartidores">Sol. Repartidores</a></li>
                                        <li><a class="dropdown-item text-warning" asp-controller="AdminAprobaciones" asp-action="Restaurantes">Sol. Restaurantes</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Auditorias" asp-action="Index">Auditoría</a></li>
                                    </ul>
                                </li>
                            }
                            @* ── RESTAURANTE ── *@
                            else if (User.IsInRole("Restaurante"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="DashboardRestaurante" asp-action="Index">Dashboard</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RestauranteProductos" asp-action="Index">Productos</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RestaurantePedidos" asp-action="Index">Pedidos</a></li>
                            }
                            @* ── REPARTIDOR ── *@
                            else if (User.IsInRole("Repartidor"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="DashboardRepartidor" asp-action="Index">Dashboard</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RepartidorPedidos" asp-action="Index">Mis Entregas</a></li>
                            }
                        }
                        else
                        {
                            @* ── VISITANTE ── *@
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                            <li class="nav-item"><a class="nav-link" href="#como-funciona">Cómo Funciona</a></li>
                            <li class="nav-item"><a class="nav-link" href="#restaurantes">Restaurantes</a></li>
                        }
                    </ul>

                    @* ─── BARRA DE BÚSQUEDA — Solo visible para Clientes ─── *@
                    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Cliente"))
                    {
                        <form class="d-flex me-3" asp-controller="Home" asp-action="Buscar" method="get">
                            <input class="form-control me-2" type="search" placeholder="Buscar pizza, sushi..." name="q" value="@ViewBag.Query" />
                            <button class="btn btn-outline-primary" type="submit">Buscar</button>
                        </form>
                    }

                    @* ─── MENÚ DERECHO (usuario / login) ─── *@
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold d-flex align-items-center" href="#" id="navbarUser" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @{
                                        var fotoPerfilClaim = User.FindFirst("FotoPerfilUrl")?.Value;
                                        var avatarUrl = !string.IsNullOrEmpty(fotoPerfilClaim) ? fotoPerfilClaim : "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(User.Identity.Name ?? "U") + "&background=random";
                                    }
                                    <img src="@avatarUrl" alt="Avatar" class="rounded-circle me-2" style="width: 30px; height: 30px; object-fit: cover;" />
                                    <span>Hola, @User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarUser">
                                    @if (User.IsInRole("Cliente"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="ClientePerfil" asp-action="CompletarPerfil">Mi Perfil</a></li>
                                    }
                                    else if (User.IsInRole("Restaurante"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="RestaurantePerfil" asp-action="CompletarPerfil">Perfil del Restaurante</a></li>
                                    }
                                    else if (User.IsInRole("Repartidor"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="RepartidorPerfil" asp-action="CompletarPerfil">Mi Perfil de Repartidor</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">Cerrar Sesión</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary me-2" asp-controller="Auth" asp-action="Login">Iniciar Sesión</a>
                            </li>
                            <li class="nav-item">
                                @* Registrarse lleva a la pantalla de selección de tipo de cuenta *@
                                <a class="btn btn-primary" asp-controller="Auth" asp-action="SeleccionTipoRegistro">Registrarse</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 - RayoExpres - El servicio de delivery más rápido.
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
