@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["VerificarCuentaDriverTitle"];
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4><i class="bi bi-shield-check"></i> @Localizer["VerificacionCuenta"]</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        @Localizer["SimulacionUMLMensaje"]
                    </div>

                    <form asp-action="VerificarCodigo" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label for="code" class="form-label">@Localizer["EnterVerificationCode"]</label>
                            <input type="text" name="code" id="code" class="form-control form-control-lg text-center" placeholder="X X X X X X" required />
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">@Localizer["VerificarRegistrarBtn"]</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancelar"]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
