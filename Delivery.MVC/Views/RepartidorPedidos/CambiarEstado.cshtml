@model Delivery.Modelos.Entidades.Pedido
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Cambiar Estado del Pedido";
}

<h1 class="my-4">Cambiar Estado del Pedido #@Model.Id</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <dl class="row mb-4">
            <dt class="col-sm-4">Dirección</dt>
            <dd class="col-sm-8">@(Model.DireccionEntrega?.Calle), @(Model.DireccionEntrega?.Ciudad)</dd>
            
            <dt class="col-sm-4">Total</dt>
            <dd class="col-sm-8">$@Model.Total.ToString("0.00")</dd>
            
            <dt class="col-sm-4">Estado Actual</dt>
            <dd class="col-sm-8"><span class="badge bg-primary">@Model.EstadoPedido</span></dd>
        </dl>

        @if (ViewBag.EstadosPermitidos == null || ((List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.EstadosPermitidos).Count == 0)
        {
            <div class="alert alert-info">
                <strong>Información:</strong> El pedido está en estado <strong>@Model.EstadoPedido</strong>. Ya no puedes cambiar el estado (aún no está listo para recoger, o ya fue entregado).
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        }
        else
        {
            <form asp-action="CambiarEstado" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label for="nuevoEstado" class="form-label">Siguiente Estado</label>
                    <select name="nuevoEstado" id="nuevoEstado" class="form-select" asp-items="ViewBag.EstadosPermitidos">
                    </select>
                </div>
                
                <div class="mb-3">
                    <button type="submit" class="btn btn-warning">Actualizar Estado</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancelar</a>
                </div>
            </form>
        }
    </div>
    
    @if (Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.ListoParaRecoger || Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.EnCamino)
    {
        <!-- Columna Derecha: Mapa de Navegación -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Navegación GPS</h5>
                    <span id="gps-status" class="badge bg-secondary">Buscando señal...</span>
                </div>
                <div class="card-body p-0">
                    <div id="map" style="height: 400px; width: 100%;"></div>
                </div>
                <div class="card-footer bg-light">
                    <small class="text-muted">La ubicación se transmite automáticamente al cliente mientras esta pantalla esté abierta.</small>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <!-- Leaflet CSS y JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        var map = L.map('map').setView([0.3517, -78.1222], 14);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var restLat = @(Model.Restaurante?.Latitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
        var restLng = @(Model.Restaurante?.Longitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
        var cliLat = @(Model.DireccionEntrega?.Latitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
        var cliLng = @(Model.DireccionEntrega?.Longitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");

        var restMarker, cliMarker, myMarker;

        if (restLat !== 0 && cliLat !== 0) {
            restMarker = L.marker([restLat, restLng]).addTo(map).bindPopup('Restaurante');
            cliMarker = L.marker([cliLat, cliLng]).addTo(map).bindPopup('Destino del Cliente');
            
            // Draw route with OSRM (Restaurante to Cliente)
            fetch(`https://router.project-osrm.org/route/v1/driving/${restLng},${restLat};${cliLng},${cliLat}?overview=full&geometries=geojson`)
                .then(res => res.json())
                .then(data => {
                    if (data.routes && data.routes.length > 0) {
                        var route = data.routes[0].geometry.coordinates;
                        var latLngs = route.map(coord => [coord[1], coord[0]]);
                        L.polyline(latLngs, { color: 'blue', weight: 4 }).addTo(map);
                        map.fitBounds(L.polyline(latLngs).getBounds());
                    }
                }).catch(err => console.error(err));
        }

        // Repartidor icon
        var repIcon = L.icon({
            iconUrl: 'https://cdn-icons-png.flaticon.com/512/2972/2972185.png', // Moto icon
            iconSize: [32, 32],
            iconAnchor: [16, 32]
        });

        const connection = new signalR.HubConnectionBuilder()
            .withUrl('@Configuration["ApiSettings:BaseUrl"]'.replace(/\/$/, "") + "/notificacionesHub")
            .withAutomaticReconnect()
            .build();

        connection.start().then(function () {
            console.log("Conectado a SignalR para emitir tracking");
        }).catch(err => console.error("Error SignalR:", err));

        // GPS Tracking
        @if (Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.ListoParaRecoger || Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.EnCamino)
        {
            <text>
            let lastTransmitTime = 0;
            let watchId = null;

            if ("geolocation" in navigator) {
                watchId = navigator.geolocation.watchPosition(function (position) {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    
                    document.getElementById('gps-status').className = 'badge bg-success';
                    document.getElementById('gps-status').innerText = 'Transmitiendo';

                    // Update map marker instantly
                    if (myMarker) {
                        myMarker.setLatLng([lat, lng]);
                    } else {
                        myMarker = L.marker([lat, lng], { icon: repIcon }).addTo(map).bindPopup('Mi Ubicación');
                        map.setView([lat, lng], 15);
                    }

                    // Throttle transmission to SignalR/DB to every 10 seconds max
                    const now = Date.now();
                    if (now - lastTransmitTime > 10000) {
                        if (connection.state === signalR.HubConnectionState.Connected) {
                            connection.invoke("EnviarUbicacionRepartidor", "@Model.Id", lat, lng, @(Model.RepartidorId ?? 0))
                                .then(() => { lastTransmitTime = now; })
                                .catch(err => console.error("Error al emitir ubicación:", err));
                        }
                    }

                }, function (error) {
                    console.error("GPS Error:", error);
                    document.getElementById('gps-status').className = 'badge bg-danger';
                    document.getElementById('gps-status').innerText = 'GPS Desactivado';
                }, {
                    enableHighAccuracy: true,
                    maximumAge: 10000,
                    timeout: 5000
                });
            } else {
                document.getElementById('gps-status').className = 'badge bg-danger';
                document.getElementById('gps-status').innerText = 'GPS No Soportado';
            }
            </text>
        }
    </script>
}
