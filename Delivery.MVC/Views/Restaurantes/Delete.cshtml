@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.Entidades.Restaurante
@{ ViewData["Title"] = Localizer["EliminarRestauranteTitle"]; }
<h1 class="my-4 text-danger">@Localizer["ConfirmarEliminarMsg"]</h1><hr />
<dl class="row">
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Id)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Nombre)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Nombre)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Descripcion)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Descripcion)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Categoria)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Categoria)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Calle)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Calle)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Ciudad)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Ciudad)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Latitud)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Latitud)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Longitud)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Longitud)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Telefono)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Telefono)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.LogoUrl)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.LogoUrl)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.HoraApertura)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.HoraApertura)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.HoraCierre)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.HoraCierre)</dd>

<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Estado)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Estado)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.AprobadoPor)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.AprobadoPor)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.FechaAprobacion)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.FechaAprobacion)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Abierto)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Abierto)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreadoPor)</dt>
<dd class="col-sm-9">@(Model.UsuarioCreador?.Nombre + " " + Model.UsuarioCreador?.Apellidos)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreadoEn)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.CreadoEn)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.ActualizadoEn)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.ActualizadoEn)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.UsuarioAprobador)</dt>
<dd class="col-sm-9">@(Model.UsuarioAprobador?.Nombre + " " + Model.UsuarioAprobador?.Apellidos)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Categorias)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Categorias)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Productos)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Productos)</dd>
</dl>
<form asp-action="Delete">
<input type="hidden" asp-for="Id" />
<button type="submit" class="btn btn-danger btn-confirm" data-title="żEliminar registro?" data-text="Esta acción no se puede deshacer" data-danger="true" data-confirm="Sí, eliminar">@Localizer["EliminarConfirmadoBtn"]</button>
<a asp-action="Index" class="btn btn-outline-secondary ms-2">@Localizer["CancelarBtn"]</a>
</form>

