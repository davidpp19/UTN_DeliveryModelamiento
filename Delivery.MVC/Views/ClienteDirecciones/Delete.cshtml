@model Delivery.Modelos.Entidades.Direccion
@{ ViewData["Title"] = "Eliminar Dirección"; }

<h1>Eliminar Dirección</h1>
<p>¿Estás seguro de que deseas eliminar esta dirección?</p>
<hr />

<dl>
    <dt>Alias</dt>
    <dd>@Model.Alias</dd>

    <dt>Dirección</dt>
    <dd>@Model.Calle @Model.Numero</dd>

    <dt>Ciudad</dt>
    <dd>@Model.Ciudad</dd>

    <dt>Referencia</dt>
    <dd>@Model.Referencia</dd>

    <dt>Dirección Principal</dt>
    <dd>@(Model.EsPrincipal ? "Sí" : "No")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Confirmar Eliminación</button>
    <a asp-action="Index">Cancelar</a>
</form>
