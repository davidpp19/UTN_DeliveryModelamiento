@model Delivery.Modelos.DTOs.CarritoSesionDto
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["MiCarrito"];
}

<h1>@Localizer["MiCarrito"]</h1>
<hr />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

@if (Model == null || !Model.Items.Any())
{
    <div class="alert alert-info">
        <h4>@Localizer["CarritoVacio"]</h4>
        <p>@Localizer["CarritoVacioDesc"]</p>
        <a asp-controller="Home" asp-action="Index">@Localizer["VerRestaurantesBtn"]</a>
    </div>
}
else
{
    <p><strong>@Localizer["RestauranteTag"]:</strong> @Model.NombreRestaurante</p>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>@Localizer["ProductoCol"]</th>
                <th>@Localizer["PrecioUnitarioCol"]</th>
                <th>@Localizer["CantidadCol"]</th>
                <th>@Localizer["SubtotalCol"]</th>
                <th>@Localizer["AccionCol"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" alt="@item.NombreProducto" class="rounded me-2" style="width: 50px; height: 50px; object-fit: cover;" />
                            }
                            <span>@item.NombreProducto</span>
                        </div>
                    </td>
                    <td class="align-middle">$@item.PrecioUnitario.ToString("0.00")</td>
                    <td class="align-middle">@item.Cantidad</td>
                    <td class="align-middle">$@item.Subtotal.ToString("0.00")</td>
                    <td class="align-middle">
                        <form asp-action="Quitar" method="post" style="display:inline;">
                            <input type="hidden" name="productoId" value="@item.ProductoId" />
                            <button type="submit">@Localizer["QuitarBtn"]</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3"><strong>@Localizer["TotalCol"]</strong></td>
                <td colspan="2"><strong>$@Model.Subtotal.ToString("0.00")</strong></td>
            </tr>
        </tfoot>
    </table>

    <form asp-action="Vaciar" method="post" style="display:inline;">
        <button type="submit">@Localizer["VaciarCarritoBtn"]</button>
    </form>

    <hr />

    @if (ViewBag.SinDireccion == true)
    {
        <div class="alert alert-warning">
            <strong>@Localizer["SinDireccionAlert"]</strong><br />
            @Localizer["SinDireccionDesc"]
        </div>
        <a asp-controller="ClienteDirecciones" asp-action="Create">@Localizer["AgregarDireccionBtn"]</a>
    }
    else
    {
        <a asp-action="Checkout" class="btn btn-primary btn-lg">@Localizer["ProcederPagoBtn"]</a>
    }
}
