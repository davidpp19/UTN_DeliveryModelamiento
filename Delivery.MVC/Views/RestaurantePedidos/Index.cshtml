@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@{ ViewData["Title"] = "Pedidos Recibidos"; }
<h1 class="my-4">Pedidos Recibidos</h1>

<div class="table-responsive mt-3">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>N° Pedido</th>
                <th>Cliente</th>
                <th>Repartidor</th>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>#@item.Id</td>
                <td>@(item.Usuario?.Nombre + " " + item.Usuario?.Apellidos)</td>
                <td>@(item.RepartidorId.HasValue ? "Asignado" : "Pendiente")</td>
                <td><span class="badge bg-secondary">@item.EstadoPedido</span></td>
                <td>@item.FechaPedido.ToLocalTime().ToString("g")</td>
                <td>$@item.Total.ToString("0.00")</td>
                <td>
                    <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Cambiar Estado</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalles</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
