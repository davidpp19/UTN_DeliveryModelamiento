@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = "Mis Ganancias";
}

<div class="container mt-4">
    <h2><i class="bi bi-wallet2 text-success"></i> Mis Ganancias (ViewEarnings)</h2>
    <hr />

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card bg-light shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title text-muted">ShowUpdatedBalance()</h5>
                    <h2 class="text-success">$@ViewBag.GananciasTotales?.ToString("0.00")</h2>
                    <p class="card-text">Total de comisiones por @ViewBag.TotalPedidos pedidos entregados.</p>
                </div>
            </div>
        </div>
    </div>

    <h4>Detalle de Pedidos Entregados</h4>
    @if (Model != null && Model.Any())
    {
        <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
            <thead class="border-bottom border-secondary">
                <tr>
                    <th>ID Pedido</th>
                    <th>Fecha</th>
                    <th>Total Pedido</th>
                    <th>Comisión Estimada</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>$@item.Total.ToString("0.00")</td>
                        <td class="text-success">
                            <!-- Estimado del 10% según CalculateComission default -->
                            $@((item.Total * 0.10m).ToString("0.00"))
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            No tienes pedidos entregados aún.
        </div>
    }
    
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Volver al Panel</a>
    </div>
</div>


