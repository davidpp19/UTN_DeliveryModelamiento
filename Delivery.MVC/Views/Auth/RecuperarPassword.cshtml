@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="text-center mb-4 text-primary">Recuperar Contraseña</h3>
                
                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success text-center">
                        @ViewBag.Message
                    </div>
                    <div class="text-center mt-3">
                        <a asp-action="Login" class="btn btn-outline-primary">Volver al Inicio de Sesión</a>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mb-4">
                        Ingresa tu correo electrónico y te enviaremos las instrucciones para restablecer tu contraseña.
                    </p>
                    <form asp-action="RecuperarPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label for="email" class="form-label">Correo Electrónico</label>
                            <input type="email" id="email" name="email" class="form-control" placeholder="ejemplo@correo.com" required />
                        </div>
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">Enviar Instrucciones</button>
                        </div>
                    </form>
                    <div class="mt-4 text-center">
                        <a asp-action="Login" class="text-decoration-none">Cancelar y volver</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
