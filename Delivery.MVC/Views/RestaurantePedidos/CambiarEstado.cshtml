@model Delivery.Modelos.Entidades.Pedido
@{
    ViewData["Title"] = "Cambiar Estado del Pedido";
}

<h1 class="my-4">Cambiar Estado del Pedido #@Model.Id</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <dl class="row mb-4">
            <dt class="col-sm-4">Cliente</dt>
            <dd class="col-sm-8">@(Model.Usuario?.Nombre) @(Model.Usuario?.Apellidos)</dd>
            
            <dt class="col-sm-4">Total</dt>
            <dd class="col-sm-8">$@Model.Total.ToString("0.00")</dd>
            
            <dt class="col-sm-4">Estado Actual</dt>
            <dd class="col-sm-8"><span class="badge bg-primary">@Model.EstadoPedido</span></dd>
        </dl>

        <form asp-action="CambiarEstado" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="mb-3">
                <label for="nuevoEstado" class="form-label">Nuevo Estado</label>
                <select name="nuevoEstado" id="nuevoEstado" class="form-select">
                    <!-- Solo estados permitidos para el restaurante -->
                    <option value="Pendiente">Pendiente</option>
                    <option value="Aceptado">Aceptado</option>
                    <option value="EnPreparacion">En Preparación</option>
                    <option value="ListoParaRepartidor">Listo para Repartidor</option>
                    <option value="Cancelado">Cancelado</option>
                </select>
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-warning">Actualizar Estado</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>
