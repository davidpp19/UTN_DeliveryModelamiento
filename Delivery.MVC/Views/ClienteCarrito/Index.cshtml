@model Delivery.Modelos.Entidades.Pedido
@{
    ViewData["Title"] = "Mi Carrito";
}

<h1>Mi Carrito</h1>
<hr />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

@if (Model == null || !Model.Detalles.Any())
{
    <div class="alert alert-info">
        <h4>Tu carrito está vacío</h4>
        <p>Explora nuestros restaurantes y agrega productos.</p>
        <a asp-controller="Home" asp-action="Index">Ver Restaurantes</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <h4>Productos en el Carrito</h4>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in Model.Detalles)
                    {
                        <tr>
                            <td>@(detalle.Producto?.Nombre ?? "Producto Desconocido")</td>
                            <td>@detalle.Cantidad</td>
                            <td>$@detalle.Subtotal.ToString("0.00")</td>
                            <td>
                                <form asp-action="Quitar" method="post">
                                    <input type="hidden" name="detallePedidoId" value="@detalle.Id" />
                                    <button type="submit">Quitar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <p><strong>Subtotal:</strong> $@Model.Subtotal.ToString("0.00")</p>
            <p><strong>Costo de Envío:</strong> $@Model.CostoEnvio.ToString("0.00")</p>
            <p><strong>Total:</strong> $@Model.Total.ToString("0.00")</p>
        </div>

        <div class="col-md-4">
            <h4>Confirmar Pedido</h4>

            @if (ViewBag.SinDireccion == true)
            {
                <div class="alert alert-warning">
                    <strong>No tienes ninguna dirección registrada.</strong><br />
                    Debes agregar una dirección de entrega antes de confirmar tu pedido.
                </div>
                <a asp-controller="ClienteDirecciones" asp-action="Create">Agregar Dirección de Entrega</a>
            }
            else
            {
                <form asp-action="Confirmar" method="post">
                    <div>
                        <label for="direccionId">Dirección de Entrega</label>
                        <select name="direccionId" id="direccionId" asp-items="ViewBag.Direcciones" required>
                            <option value="">Selecciona una dirección...</option>
                        </select>
                    </div>
                    <br />
                    <button type="submit">Confirmar Pedido</button>
                </form>
            }
        </div>
    </div>
}
