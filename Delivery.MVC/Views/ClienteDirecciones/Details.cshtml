@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.Entidades.Direccion
@{ ViewData["Title"] = "Detalle de Dirección"; }

<h1>Detalle de Dirección</h1>
<hr />

<dl>
    <dt>@Localizer["AliasTag"]</dt>
    <dd>@Model.Alias</dd>

    <dt>Calle</dt>
    <dd>@Model.Calle @Model.Numero</dd>

    <dt>@Localizer["CiudadTag"]</dt>
    <dd>@Model.Ciudad</dd>

    <dt>@Localizer["ReferenciaTag"]</dt>
    <dd>@(Model.Referencia ?? "—")</dd>

    <dt>Dirección Principal</dt>
    <dd>@(Model.EsPrincipal ? "Sí" : "No")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">@Localizer["EditarBtn"]</a> |
<a asp-action="Index">Volver a mis direcciones</a>
