@model Delivery.Modelos.Entidades.Restaurante
@{
    ViewData["Title"] = "Completar Perfil del Restaurante";
}

<div class="container mt-4">
    <h2>Completar Perfil</h2>
    <hr />

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">@TempData["Exito"]</div>
    }

    <form asp-action="CompletarPerfil" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm">
        <input type="hidden" name="id" value="@Model.Id" />
        
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Teléfono de Contacto</label>
                <input type="text" name="telefono" class="form-control" value="@Model.Telefono" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Email de Contacto</label>
                <input type="email" name="email" class="form-control" value="@Model.Email" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea name="descripcion" class="form-control" rows="3">@Model.Descripcion</textarea>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Hora de Apertura (HH:MM)</label>
                <input type="time" name="horaApertura" class="form-control" value="@Model.HoraApertura?.ToString(@"hh\:mm")" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Hora de Cierre (HH:MM)</label>
                <input type="time" name="horaCierre" class="form-control" value="@Model.HoraCierre?.ToString(@"hh\:mm")" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Redes Sociales (Enlaces separados por comas)</label>
            <input type="text" name="redesSociales" class="form-control" value="@Model.RedesSociales" placeholder="ej. instagram.com/restaurante, facebook.com/restaurante" />
        </div>

        <hr />
        <h4>Imágenes del Restaurante</h4>
        <div class="row mt-3">
            <div class="col-md-6 mb-3">
                <label class="form-label">Logo del Restaurante</label>
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.LogoUrl" alt="Logo" class="img-thumbnail" style="max-height: 100px;" />
                    </div>
                }
                <input type="file" name="logo" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <small class="text-muted">Formatos: JPG, PNG, WEBP. Máx: 5MB.</small>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Imagen de Portada</label>
                @if (!string.IsNullOrEmpty(Model.PortadaUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.PortadaUrl" alt="Portada" class="img-thumbnail" style="max-height: 100px;" />
                    </div>
                }
                <input type="file" name="portada" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <small class="text-muted">Formatos: JPG, PNG, WEBP. Máx: 5MB.</small>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
            <a asp-controller="DashboardRestaurante" asp-action="Index" class="btn btn-outline-secondary">Volver al Dashboard</a>
        </div>
    </form>
</div>
