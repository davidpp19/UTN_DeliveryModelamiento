@model Delivery.Modelos.Entidades.Cupon
@{ ViewData["Title"] = "Crear Cupón"; }
<h1 class="my-4">Crear Cupón Global</h1><hr />
<div class="row"><div class="col-md-6">
<form asp-action="Create">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="mb-3">
<label asp-for="Codigo" class="form-label"></label>
<input asp-for="Codigo" class="form-control" style="text-transform:uppercase" required />
<span asp-validation-for="Codigo" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="Descripcion" class="form-label">Descripción</label>
<input asp-for="Descripcion" class="form-control" placeholder="Ej. Aplica para compras en fin de semana" required />
<span asp-validation-for="Descripcion" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="TipoDescuento" class="form-label">Tipo de Descuento</label>
<select asp-for="TipoDescuento" class="form-select">
    <option value="Porcentaje">Porcentaje</option>
    <option value="MontoFijo">Valor Fijo ($)</option>
</select>
<span asp-validation-for="TipoDescuento" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="ValorDescuento" class="form-label">Valor (Ej. 10 para 10% o $10)</label>
<input asp-for="ValorDescuento" class="form-control" type="number" step="0.01" required />
<span asp-validation-for="ValorDescuento" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="DescuentoMaximo" class="form-label">Descuento Máximo ($) (Solo para Porcentaje)</label>
<input asp-for="DescuentoMaximo" class="form-control" type="number" step="0.01" />
<span asp-validation-for="DescuentoMaximo" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="PedidoMinimo" class="form-label">Pedido Mínimo ($)</label>
<input asp-for="PedidoMinimo" class="form-control" type="number" step="0.01" />
<span asp-validation-for="PedidoMinimo" class="text-danger"></span></div>
<div class="mb-3">
<label class="form-label">Duración del Cupón</label>
<select name="duracionDias" class="form-select" required>
    <option value="7">7 Días</option>
    <option value="14">14 Días</option>
</select>
</div>
<div class="mb-3">
<label asp-for="LimiteUsos" class="form-label">Límite de Usos (0 o vacío = Sin límite)</label>
<input asp-for="LimiteUsos" class="form-control" type="number" />
<span asp-validation-for="LimiteUsos" class="text-danger"></span></div>
<div class="form-check mb-3">
<input asp-for="Activo" class="form-check-input" type="checkbox" checked />
<label asp-for="Activo" class="form-check-label">Cupón Activo</label>
</div>
<div class="form-check mb-3">
<input asp-for="EsPublico" class="form-check-input" type="checkbox" checked />
<label asp-for="EsPublico" class="form-check-label">Es Público (cualquiera puede registrarlo)</label>
</div>
<div class="mb-3"><button type="submit" class="btn btn-primary">Crear Cupón</button></div>
</form></div></div>
<div><a asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a></div>
