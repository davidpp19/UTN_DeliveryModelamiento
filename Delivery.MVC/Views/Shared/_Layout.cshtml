<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RayoExpres</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">RayoExpres</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="#como-funciona">Cómo Funciona</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="#beneficios">Beneficios</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var userName = User.Identity.Name;
                            var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
                            var dashboardAction = "Index";
                            var dashboardController = role switch
                            {
                                "Admin" => "DashboardAdministrador",
                                "Restaurante" => "DashboardRestaurante",
                                "Repartidor" => "DashboardRepartidor",
                                _ => "Home" // O Cliente
                            };

                            <li class="nav-item">
                                <span class="nav-link text-dark fw-bold me-3">Hola, @userName</span>
                            </li>
                            if (role != "Cliente")
                            {
                                <li class="nav-item">
                                    <a class="btn btn-outline-primary me-2" asp-controller="@dashboardController" asp-action="@dashboardAction">Mi Panel</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="btn btn-danger" asp-controller="Auth" asp-action="Logout">Cerrar Sesión</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary me-2" asp-controller="Auth" asp-action="Login">Iniciar Sesión</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-controller="Auth" asp-action="Registro">Registrarse</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 - RayoExpres - El servicio de delivery más rápido.
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
