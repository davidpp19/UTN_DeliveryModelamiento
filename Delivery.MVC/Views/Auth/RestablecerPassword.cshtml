@{
    ViewData["Title"] = "Restablecer Contraseña";
    var email = ViewBag.Email as string;
}

<div class="row justify-content-center my-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
                    <h3 class="mt-3">Restablecer Contraseña</h3>
                </div>
                
                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-info text-center">@TempData["Mensaje"]</div>
                }

                <p class="text-muted text-center">Ingresa el código enviado a <strong>@email</strong> y tu nueva contraseña.</p>

                <form asp-action="RestablecerPassword" method="post">
                    <input type="hidden" name="email" value="@email" />
                    
                    <div class="mb-3">
                        <label class="form-label">Código de Recuperación</label>
                        <input type="text" name="codigo" class="form-control text-center" 
                               placeholder="123456" maxlength="6" style="letter-spacing: 5px; font-weight: bold;" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Nueva Contraseña</label>
                        <input type="password" name="nuevaContrasena" class="form-control" required />
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg rounded-pill">Guardar Nueva Contraseña</button>
                </form>
                
                <div class="mt-4 text-center">
                    <form id="form-reenviar-sms">
                        <input type="hidden" name="email" value="@email" />
                        <button type="button" id="btn-enviar-sms" class="btn btn-outline-secondary btn-sm rounded-pill">
                            <i class="bi bi-phone"></i> ¿Prefieres recibirlo por SMS? Enviar al celular
                        </button>
                    </form>

                    <div id="res-reenviar" class="text-success mt-3" style="display:none; font-weight: bold;"></div>
                    <div id="err-reenviar" class="text-danger mt-3" style="display:none; font-weight: bold;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Firebase SDK (Compat Version) -->
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>

    <script>
        // Configuración de Firebase
        const firebaseConfig = {
            apiKey: "AIzaSyAzfxeMWxaM_TbbRIYFGaNvmtlUlHzm4R8",
            authDomain: "rayoexpres-108e5.firebaseapp.com",
            projectId: "rayoexpres-108e5",
            storageBucket: "rayoexpres-108e5.firebasestorage.app",
            messagingSenderId: "711656310378",
            appId: "1:711656310378:web:9fe716487592cc61ffac13",
            measurementId: "G-7TLE94D2QQ"
        };
        firebase.initializeApp(firebaseConfig);

        let confirmationResultObj = null;

        // --- LÓGICA DE FIREBASE PARA SMS ---
        document.addEventListener("DOMContentLoaded", function () {
            // Inicializar reCAPTCHA invisible de Firebase en el botón SMS
            window.recaptchaVerifier = new firebase.auth.RecaptchaVerifier('btn-enviar-sms', {
                'size': 'invisible'
            });

            const btnSms = document.getElementById('btn-enviar-sms');
            const resDiv = document.getElementById('res-reenviar');
            const errDiv = document.getElementById('err-reenviar');

            btnSms.addEventListener('click', function () {
                let telefono = '@ViewBag.Telefono';
                if (!telefono) {
                    errDiv.innerText = "No tienes un número de celular registrado.";
                    errDiv.style.display = 'block';
                    return;
                }
                
                // Formatear para Ecuador (opcionalmente dinámico)
                if (!telefono.startsWith('+')) {
                    if (telefono.startsWith('0')) {
                        telefono = '+593' + telefono.substring(1);
                    } else {
                        telefono = '+593' + telefono;
                    }
                }

                btnSms.disabled = true;
                btnSms.innerHTML = 'Enviando SMS...';
                resDiv.style.display = 'none';
                errDiv.style.display = 'none';

                firebase.auth().signInWithPhoneNumber(telefono, window.recaptchaVerifier)
                    .then((confirmationResult) => {
                        window.confirmationResultObj = confirmationResult;
                        resDiv.innerText = "Se ha enviado un código a tu celular por SMS.";
                        resDiv.style.display = 'block';
                        btnSms.innerHTML = 'SMS enviado';
                    }).catch((error) => {
                        errDiv.innerText = "Error de Firebase: " + error.message;
                        errDiv.style.display = 'block';
                        btnSms.disabled = false;
                        btnSms.innerHTML = '<i class="bi bi-phone"></i> ¿Prefieres recibirlo por SMS? Enviar al celular';
                        // Resetear reCAPTCHA si falla
                        window.recaptchaVerifier.render().then(function(widgetId) {
                            grecaptcha.reset(widgetId);
                        });
                    });
            });

            // Interceptar el formulario principal de verificación si se pidió SMS
            const formPrincipal = document.querySelector('form[asp-action="RestablecerPassword"]');
            formPrincipal.addEventListener('submit', function (e) {
                if (window.confirmationResultObj != null) {
                    e.preventDefault(); // Detenemos el submit normal para verificar con Firebase
                    const codigo = formPrincipal.querySelector('input[name="codigo"]').value;
                    const nuevaContrasena = formPrincipal.querySelector('input[name="nuevaContrasena"]').value;
                    
                    window.confirmationResultObj.confirm(codigo).then((result) => {
                        // Teléfono validado exitosamente en Firebase
                        // Ahora le avisamos a nuestro backend
                        const telefono = '@ViewBag.Telefono';
                        fetch('@Url.Action("RestablecerPasswordSms", "Auth")?telefono=' + encodeURIComponent(telefono) + '&nuevaContrasena=' + encodeURIComponent(nuevaContrasena), {
                            method: 'POST'
                        })
                        .then(res => res.json())
                        .then(data => {
                            if(data.success) {
                                window.location.href = '@Url.Action("Login", "Auth")';
                            } else {
                                alert("Error en el backend: " + data.mensaje);
                            }
                        });
                    }).catch((error) => {
                        alert("El código SMS ingresado es incorrecto.");
                    });
                }
            });
        });
    </script>
}
