@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Cupon>
@{ ViewData["Title"] = Localizer["CuponesTitle"]; }
<h1 class="my-4">@Localizer["CuponesTitle"]</h1>
<p><a asp-action="Create" class="btn btn-primary">@Localizer["CrearNuevoBtn"]</a></p>
<div class="table-responsive table-scrollable">
<table class="table skeleton-loader table-striped table-hover align-middle">
<thead class="table-dark"><tr>
<th>CÃ³digo</th>
<th>@Localizer["DescripcionTag"]</th>
<th>Tipo/Valor</th>
<th>Estado</th>
<th>Vence</th>
<th>Usos</th>
<th>PÃºblico</th>
<th>@Localizer["AccionesTag"]</th></tr></thead><tbody>
@foreach (var item in Model) {<tr>
<td><span class="badge bg-secondary">@item.Codigo</span></td>
<td>@item.Descripcion</td>
<td>@item.TipoDescuento: @(item.TipoDescuento == Delivery.Modelos.Enums.TipoDescuentoEnum.Porcentaje ? item.ValorDescuento + "%" + (item.DescuentoMaximo.HasValue ? $" (Max ${item.DescuentoMaximo})" : "") : "$" + item.ValorDescuento)</td>
<td>
    @if(item.Activo && System.DateTime.UtcNow <= item.FechaFin) {
        <span class="badge bg-success">Activo</span>
    } else if (!item.Activo) {
        <span class="badge bg-danger">Inactivo</span>
    } else {
        <span class="badge bg-warning text-dark">Vencido</span>
    }
</td>
<td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
<td>@item.UsosActuales / @(item.LimiteUsos?.ToString() ?? "â")</td>
<td>@(item.EsPublico ? "SÃ­" : "No")</td>
<td>
<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning btn-confirm" data-title="¿Confirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar"><i class="bi bi-pencil"></i> Editar</a>
<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger btn-confirm" data-title="¿Eliminar registro?" data-text="Esta acción no se puede deshacer" data-danger="true" data-confirm="Sí, eliminar"><i class="bi bi-trash"></i> Eliminar</a>
</td></tr>}
</tbody></table></div>


