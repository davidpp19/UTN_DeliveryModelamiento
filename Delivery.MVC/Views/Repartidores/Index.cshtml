@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Repartidor>
@{ ViewData["Title"] = Localizer["RepartidoresTitle"]; }
<h1 class="my-4">@Localizer["RepartidoresTitle"]</h1>
<p><a asp-action="Create" class="btn btn-primary">@Localizer["CrearNuevoBtn"]</a></p>
<div class="table-responsive">
<table class="table table-striped table-hover align-middle">
<thead class="table-dark"><tr>
<th>UsuarioId</th>
<th>LicenciaConducir</th>
<th>FotoLicenciaUrl</th>
<th>EstadoAprobacion</th>
<th>AprobadoPor</th>
<th>@Localizer["AccionesTag"]</th></tr></thead><tbody>
@foreach (var item in Model) {<tr>
<td>@Html.DisplayFor(modelItem => item.UsuarioId)</td>
<td>@Html.DisplayFor(modelItem => item.LicenciaConducir)</td>
<td>@Html.DisplayFor(modelItem => item.FotoLicenciaUrl)</td>
<td>@Html.DisplayFor(modelItem => item.EstadoAprobacion)</td>
<td>@Html.DisplayFor(modelItem => item.AprobadoPor)</td>
<td>
<a asp-action="Edit" asp-route-id="@item.UsuarioId" class="btn btn-sm btn-warning">@Localizer["EditarBtn"]</a>
<a asp-action="Details" asp-route-id="@item.UsuarioId" class="btn btn-sm btn-info text-white">@Localizer["DetallesBtn"]</a>
<a asp-action="Delete" asp-route-id="@item.UsuarioId" class="btn btn-sm btn-danger">@Localizer["EliminarBtn"]</a>
</td></tr>}
</tbody></table></div>
