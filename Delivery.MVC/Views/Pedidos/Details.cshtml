@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.Entidades.Pedido
@{ ViewData["Title"] = Localizer["DetallesPedidoTitle"]; }
<h1 class="my-4">@Localizer["DetallesPedidoTitle"]</h1><hr />
<dl class="row">
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Id)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>
<dt class="col-sm-3">Cliente</dt>
<dd class="col-sm-9">@(Model.Usuario?.Nombre + " " + Model.Usuario?.Apellidos)</dd>
<dt class="col-sm-3">Restaurante</dt>
<dd class="col-sm-9">@(Model.Restaurante?.Nombre)</dd>
<dt class="col-sm-3">Repartidor</dt>
<dd class="col-sm-9">@(Model.Repartidor?.Usuario != null ? Model.Repartidor.Usuario.Nombre + " " + Model.Repartidor.Usuario.Apellidos : "Pendiente")</dd>
<dt class="col-sm-3">DirecciĂłn</dt>
<dd class="col-sm-9">@(Model.DireccionEntrega?.Calle + " " + Model.DireccionEntrega?.Numero)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.EstadoPedido)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.EstadoPedido)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Subtotal)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Subtotal)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.CostoEnvio)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.CostoEnvio)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Total)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Total)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.TipoMetodoPago)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.TipoMetodoPago)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.MetodoPagoId)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.MetodoPagoId)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.CuponId)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.CuponId)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.MontoDescuento)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.MontoDescuento)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Notas)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Notas)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.FechaPedido)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.FechaPedido)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.FechaEntregaEstimada)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.FechaEntregaEstimada)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.FechaEntregaReal)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.FechaEntregaReal)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.ActualizadoEn)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.ActualizadoEn)</dd>

</dl>
<div><a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning btn-confirm" data-title="żConfirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">@Localizer["EditarBtn"]</a>
<a asp-action="Index" class="btn btn-outline-secondary ms-2">@Localizer["VolverListadoBtn"]</a></div>

