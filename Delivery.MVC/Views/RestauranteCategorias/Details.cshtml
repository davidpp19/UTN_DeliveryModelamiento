@model Delivery.Modelos.Entidades.CategoriaProducto
@{ ViewData["Title"] = "Detalles de Categoría"; }

<div class="container mt-4">
    <h1 class="mb-4">Detalles de Categoría</h1>
    <div class="card shadow-sm col-md-8">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Información</h5>
        </div>
        <div class="card-body">
            <p><strong>Restaurante:</strong> @ViewBag.RestauranteNombre</p>
            <p><strong>Nombre:</strong> @Model.Nombre</p>
            <p><strong>Descripción:</strong> @Model.Descripcion</p>
            <p><strong>Creado el:</strong> @Model.CreadoEn.ToLocalTime().ToString("g")</p>
        </div>
        <div class="card-footer">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Volver al listado</a>
        </div>
    </div>
</div>
