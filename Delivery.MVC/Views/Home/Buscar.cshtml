@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model dynamic
@{
    ViewData["Title"] = Localizer["ResultadosBusquedaTitle"];
    var restaurantes = Model.Restaurantes as List<Delivery.Modelos.Entidades.Restaurante>;
    var productos = Model.Productos as List<Delivery.Modelos.Entidades.Producto>;
}

<div class="container mt-5 mb-5" data-aos="fade-up">
    <div class="d-flex align-items-center mb-4 border-bottom border-secondary pb-3">
        <i class="bi bi-search fs-1 text-primary me-3"></i>
        <h2 class="mb-0 text-light">@Localizer["ResultadosPara", ViewBag.Query]</h2>
    </div>

    <h4 class="mt-4 mb-4 text-warning"><i class="bi bi-shop"></i> @Localizer["RestaurantesEncontrados", restaurantes?.Count ?? 0]</h4>
    @if (restaurantes != null && restaurantes.Any())
    {
        <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
            @foreach (var res in restaurantes)
            {
                <div class="col" data-aos="fade-up" data-aos-delay="100">
                    <div class="card glass-card h-100 p-3">
                        <div class="card-body text-center d-flex flex-column">
                            <div class="mb-3">
                                <i class="bi bi-shop-window text-danger" style="font-size: 3rem;"></i>
                            </div>
                            <h5 class="card-title text-light fw-bold">@res.Nombre</h5>
                            <span class="badge bg-primary mb-3 mx-auto">@res.Categoria</span>
                            <div class="mt-auto">
                                <a asp-action="Restaurante" asp-route-id="@res.Id" class="btn btn-liquid btn-liquid-primary w-100">@Localizer["VerMenu"]</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info glass-card text-center py-4" style="background: rgba(13, 202, 240, 0.1); border: 1px solid rgba(13, 202, 240, 0.3);">
            <i class="bi bi-emoji-frown fs-1 text-info d-block mb-2"></i>
            @Localizer["NoRestaurantesBusqueda"]
        </div>
    }

    <h4 class="mt-5 mb-4 text-info"><i class="bi bi-box-seam"></i> @Localizer["ProductosEncontrados", productos?.Count ?? 0]</h4>
    @if (productos != null && productos.Any())
    {
        <div class="row row-cols-2 row-cols-md-4 g-4 mb-4">
            @foreach (var prod in productos)
            {
                <div class="col" data-aos="fade-up" data-aos-delay="200">
                    <div class="card glass-card h-100 p-2">
                        <div class="card-body d-flex flex-column text-center">
                            <div class="mb-3">
                                <i class="bi bi-cup-hot text-warning" style="font-size: 2.5rem;"></i>
                            </div>
                            <h6 class="card-title text-light fw-bold mb-2">@prod.Nombre</h6>
                            <p class="text-success fs-5 fw-bold mb-2">$@prod.Precio.ToString("0.00")</p>
                            <p class="text-muted small flex-grow-1">Restaurante ID: @prod.RestauranteId</p>
                            
                            <form asp-controller="ClienteCarrito" asp-action="Agregar" method="post" class="mt-auto w-100">
                                <input type="hidden" name="ProductoId" value="@prod.Id" />
                                <input type="hidden" name="Cantidad" value="1" />
                                <input type="hidden" name="RestauranteId" value="@prod.RestauranteId" />
                                <button type="submit" class="btn btn-liquid w-100" style="--liquid-bg: var(--danger-neon); --liquid-bg-hover: #dc2626;"><i class="bi bi-cart-plus"></i> Agregar</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info glass-card text-center py-4" style="background: rgba(13, 202, 240, 0.1); border: 1px solid rgba(13, 202, 240, 0.3);">
            <i class="bi bi-search fs-1 text-info d-block mb-2"></i>
            @Localizer["NoProductosBusqueda"]
        </div>
    }
</div>
