@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.DTOs.RestaurantePendienteDto>
@{
    ViewData["Title"] = Localizer["AprobacionesRestaurantes"];
}

<div class="container-fluid mt-4" data-aos="fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold m-0"><i class="bi bi-shop me-2"></i> @Localizer["SolicitudesRestaurantesPendientes"]</h1>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">@Localizer["NoHaySolicitudesPendientes"]</div>
    }
    else
    {
        <div class="table-responsive table-scrollable glass-card p-4 rounded-4 shadow-lg border-0">
            <table class="table skeleton-loader table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
                <thead class="border-bottom border-secondary">
                    <tr>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["LogoTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["RestauranteTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["CategoriaTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["PropietarioTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["FechaRegistroTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold text-center">@Localizer["AccionesTag"]</th>
                    </tr>
                </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var logoUrl = !string.IsNullOrEmpty(item.LogoUrl) ? item.LogoUrl : "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(item.Nombre) + "&background=random";
                    var avatarPropietario = !string.IsNullOrEmpty(item.FotoPerfilUrl) ? item.FotoPerfilUrl : "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(item.NombresPropietario) + "&background=random";
                    var modalId = "modalRestaurante" + item.Id;
                    var modalRechazoId = "modalRechazo" + item.Id;

                    <tr class="glass-row">
                        <td>
                            <img src="@logoUrl" alt="Logo" class="rounded-circle border border-success" style="width: 40px; height: 40px; object-fit: cover;" />
                        </td>
                        <td class="text-light fw-bold">@item.Nombre</td>
                        <td><span class="badge bg-info text-dark rounded-pill">@item.Categoria</span></td>
                        <td class="text-light">
                            <img src="@avatarPropietario" alt="Avatar" class="rounded-circle me-1 border border-secondary" style="width: 25px; height: 25px; object-fit: cover;" />
                            @item.NombresPropietario
                        </td>
                        <td class="text-light">@item.CreadoEn.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <!-- BotĂłn Mostrar InformaciĂłn -->
                            <button type="button" class="btn btn-sm btn-info text-white me-1" data-bs-toggle="modal" data-bs-target="#@modalId">
                                <i class="bi bi-eye"></i> Mostrar informaciĂłn
                            </button>

                            <!-- Formulario Aprobar -->
                            <form method="post" asp-action="AprobarRestaurante" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-success me-1 btn-confirm" data-title="żAprobar solicitud?" data-text="Confirmar la aprobación de este registro" data-confirm="Sí, aprobar">
                                    <i class="bi bi-check-circle"></i> Aprobar
                                </button>
                            </form>
                            
                            <!-- BotĂłn Denegar -->
                            <button type="button" class="btn btn-sm btn-danger btn-confirm" data-title="żEliminar registro?" data-text="Esta acción no se puede deshacer" data-danger="true" data-confirm="Sí, eliminar" data-bs-toggle="modal" data-bs-target="#@modalRechazoId">
                                <i class="bi bi-x-circle"></i> Denegar
                            </button>
                        </td>
                    </tr>

                    <!-- Modal Mostrar InformaciĂłn -->
                    <div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)Label" aria-hidden="true">
                      <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title" id="@(modalId)Label">@Localizer["InfoRestauranteTitle"]</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                          </div>
                          <div class="modal-body">
                            <div class="row">
                                <div class="col-md-4 text-center mb-3">
                                    <img src="@logoUrl" alt="Logo" class="img-thumbnail rounded mb-2" style="width: 150px; height: 150px; object-fit: cover;" />
                                    <h5 class="mt-2">@item.Nombre</h5>
                                    <span class="badge bg-secondary">@item.Categoria</span>
                                </div>
                                <div class="col-md-8">
                                    <h6>@Localizer["DatosEstablecimientoTitle"]</h6>
                                    <p><strong>@Localizer["RUCTag"]:</strong> @item.Ruc</p>
                                    <p><strong>@Localizer["DireccionTag"]:</strong> @item.Calle, @item.Ciudad</p>
                                    <p><strong>@Localizer["TelefonoTag"]:</strong> @item.Telefono</p>
                                    <p><strong>@Localizer["EmailTag"]:</strong> @item.Email</p>
                                    <p><strong>@Localizer["DescripcionTag"]:</strong> @item.Descripcion</p>
                                    <hr />
                                    <h6>@Localizer["DatosPropietarioTitle"]</h6>
                                    <div class="d-flex align-items-center mb-2">
                                        <img src="@avatarPropietario" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                        <span><strong>@item.NombresPropietario @item.ApellidosPropietario</strong></span>
                                    </div>
                                    <p class="mb-0"><strong>@Localizer["EmailPropietarioTag"]:</strong> @item.EmailPropietario</p>
                                </div>
                            </div>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["CerrarBtn"]</button>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Modal Rechazar -->
                    <div class="modal fade" id="@modalRechazoId" tabindex="-1" aria-labelledby="@(modalRechazoId)Label" aria-hidden="true">
                      <div class="modal-dialog">
                        <div class="modal-content">
                          <form method="post" asp-action="RechazarRestaurante">
                              <div class="modal-header bg-danger text-white">
                                <h5 class="modal-title" id="@(modalRechazoId)Label">@Localizer["DenegarSolicitudTitle"]</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                              </div>
                              <div class="modal-body">
                                <p>@Localizer["SeguroDenegarSolicitudRest"] <strong>@item.Nombre</strong>?</p>
                                <input type="hidden" name="id" value="@item.Id" />
                                <div class="mb-3">
                                    <label class="form-label">@Localizer["MotivoRechazoObligatorio"]</label>
                                    <textarea name="motivoRechazo" class="form-control" rows="3" required></textarea>
                                </div>
                              </div>
                              <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["CancelarBtn"]</button>
                                <button type="submit" class="btn btn-danger btn-confirm" data-title="żEliminar registro?" data-text="Esta acción no se puede deshacer" data-danger="true" data-confirm="Sí, eliminar">@Localizer["ConfirmarDenegacionBtn"]</button>
                              </div>
                          </form>
                        </div>
                      </div>
                    </div>
                }
            </tbody>
        </table>
        </div>
    }
</div>



