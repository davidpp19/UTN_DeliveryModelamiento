@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.Entidades.Producto
@{ ViewData["Title"] = Localizer["EditarProductoTitle"]; }
<h1 class="my-4">@Localizer["EditarProductoTitle"]</h1><hr />
<div class="row"><div class="col-md-6">
<form asp-action="Edit">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" asp-for="Id" />
<div class="mb-3">
<label asp-for="RestauranteId" class="form-label"></label>
<select asp-for="RestauranteId" class="form-control" asp-items="ViewBag.RestauranteId"></select>
<span asp-validation-for="RestauranteId" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="CategoriaId" class="form-label"></label>
<select asp-for="CategoriaId" class="form-control" asp-items="ViewBag.CategoriaId"></select>
<span asp-validation-for="CategoriaId" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="Nombre" class="form-label"></label>
<input asp-for="Nombre" class="form-control" />
<span asp-validation-for="Nombre" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="Descripcion" class="form-label"></label>
<input asp-for="Descripcion" class="form-control" />
<span asp-validation-for="Descripcion" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="Precio" class="form-label"></label>
<input asp-for="Precio" class="form-control" />
<span asp-validation-for="Precio" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="ImagenUrl" class="form-label"></label>
<input asp-for="ImagenUrl" class="form-control" />
<span asp-validation-for="ImagenUrl" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="Disponible" class="form-label"></label>
<input asp-for="Disponible" class="form-check-input" type="checkbox" />
<span asp-validation-for="Disponible" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="TiempoPreparacion" class="form-label"></label>
<input asp-for="TiempoPreparacion" class="form-control" />
<span asp-validation-for="TiempoPreparacion" class="text-danger"></span></div>




<div class="mb-3"><button type="submit" class="btn btn-warning">@Localizer["ActualizarBtn"]</button></div>
</form></div></div>
<div><a asp-action="Index" class="btn btn-outline-secondary">@Localizer["VolverListadoBtn"]</a></div>
