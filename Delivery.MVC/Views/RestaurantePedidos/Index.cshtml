@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@{ ViewData["Title"] = "Pedidos Recibidos"; }
<h1 class="my-4">Pedidos Recibidos</h1>

<div class="table-responsive glass-card p-4 rounded-4 shadow-lg border-0 mt-3 table-scrollable mt-3">
    <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
        <thead class="border-bottom border-secondary">
            <tr>
                <th>NÂ° Pedido</th>
                <th>Cliente</th>
                <th>Repartidor</th>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>#@item.Id</td>
                <td>@(item.Usuario?.Nombre + " " + item.Usuario?.Apellidos)</td>
                <td>@(item.Repartidor?.Usuario != null ? item.Repartidor.Usuario.Nombre + " " + item.Repartidor.Usuario.Apellidos : "Pendiente")</td>
                <td><span class="badge bg-secondary">@item.EstadoPedido</span></td>
                <td>@item.FechaPedido.ToLocalTime().ToString("g")</td>
                <td>$@item.Total.ToString("0.00")</td>
                <td>
                    <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-sm btn-warning btn-confirm" data-title="¿Confirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">Cambiar Estado</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalles</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>



