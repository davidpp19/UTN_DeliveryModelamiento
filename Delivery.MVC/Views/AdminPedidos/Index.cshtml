@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@{ ViewData["Title"] = Localizer["GestionPedidos"]; }
<h1>@Localizer["TodosLosPedidos"]</h1>
<table class="table">
    <thead><tr><th>ID</th><th>@Localizer["ClienteIDTag"]</th><th>@Localizer["RestauranteIDTag"]</th><th>@Localizer["EstadoTag"]</th><th>@Localizer["TotalTag"]</th></tr></thead>
    <tbody>
        @foreach (var item in Model) {
            <tr><td>@item.Id</td><td>@item.UsuarioId</td><td>@item.RestauranteId</td><td>@item.EstadoPedido</td><td>$@item.Total</td></tr>
        }
    </tbody>
</table>
