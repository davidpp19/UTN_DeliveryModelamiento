@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.DTOs.RegistroRestauranteDto
@{
    ViewData["Title"] = Localizer["RegRestauranteTitulo"];
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <h2 class="text-center mb-4">@Localizer["RegRestauranteTitulo"]</h2>
        
        <form asp-action="Index" method="post" class="card shadow-sm p-4 w-100">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <!-- Columna Izquierda: Formulario -->
                <div class="col-md-6">
                    <h4 class="mb-3">@Localizer["DatosPropietario"]</h4>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NombrePropietario" class="form-label">@Localizer["Nombres"]</label>
                            <input asp-for="NombrePropietario" class="form-control" />
                            <span asp-validation-for="NombrePropietario" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ApellidosPropietario" class="form-label">@Localizer["Apellidos"]</label>
                            <input asp-for="ApellidosPropietario" class="form-control" />
                            <span asp-validation-for="ApellidosPropietario" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label">@Localizer["CorreoElectronico"]</label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Telefono" class="form-label">@Localizer["Telefono"]</label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="Cedula" class="form-label">@Localizer["Cedula"]</label>
                            <input asp-for="Cedula" class="form-control" />
                            <span asp-validation-for="Cedula" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label">@Localizer["Contrasena"]</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmarPassword" class="form-label">@Localizer["ConfirmarContrasena"]</label>
                            <input asp-for="ConfirmarPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmarPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h4 class="mb-3">@Localizer["DatosRestaurante"]</h4>

                    <div class="mb-3">
                        <label asp-for="NombreRestaurante" class="form-label">@Localizer["NombreRestaurante"]</label>
                        <input asp-for="NombreRestaurante" class="form-control" />
                        <span asp-validation-for="NombreRestaurante" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label">@Localizer["Descripcion"]</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="RUC" class="form-label">@Localizer["RUC"]</label>
                            <input asp-for="RUC" class="form-control" />
                            <span asp-validation-for="RUC" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Categoria" class="form-label">@Localizer["CategoriaEjemplo"]</label>
                            <input asp-for="Categoria" class="form-control" />
                            <span asp-validation-for="Categoria" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="HoraApertura" class="form-label">@Localizer["HoraApertura"]</label>
                            <input asp-for="HoraApertura" type="time" class="form-control" />
                            <span asp-validation-for="HoraApertura" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="HoraCierre" class="form-label">@Localizer["HoraCierre"]</label>
                            <input asp-for="HoraCierre" type="time" class="form-control" />
                            <span asp-validation-for="HoraCierre" class="text-danger"></span>
                        </div>
                    </div>

                </div>

                <!-- Columna Derecha: Mapa de Ubicación -->
                <div class="col-md-6">
                    <h4 class="mb-3">Ubicación del Restaurante</h4>
                    <p class="text-muted small">Busca en el mapa o haz clic para ubicar la dirección exacta de tu local.</p>

                    <div class="mb-3">
                        <label class="form-label">Buscar Lugar</label>
                        <div class="input-group">
                            <input type="text" id="buscador-mapa" class="form-control" placeholder="Ej: Ibarra, Parque Ciudad Blanca..." />
                            <button class="btn btn-primary" type="button" id="btn-buscar">Buscar</button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Calle" class="form-label">Dirección (Calle Principal)</label>
                        <input asp-for="Calle" id="calle-input" class="form-control" placeholder="Ej: Av. 17 de Julio" />
                        <span asp-validation-for="Calle" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Ciudad" class="form-label">@Localizer["Ciudad"]</label>
                        <input asp-for="Ciudad" id="ciudad-input" class="form-control" placeholder="Ej: Ibarra" />
                        <span asp-validation-for="Ciudad" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Latitud" class="form-label">Latitud</label>
                            <input asp-for="Latitud" id="lat-input" class="form-control bg-light" readonly />
                            <span asp-validation-for="Latitud" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Longitud" class="form-label">Longitud</label>
                            <input asp-for="Longitud" id="lng-input" class="form-control bg-light" readonly />
                            <span asp-validation-for="Longitud" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="map" style="height: 400px; width: 100%; border-radius: 8px; border: 1px solid #ccc; margin-bottom: 20px;"></div>
                </div>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary btn-lg">@Localizer["RegRestauranteBtn"]</button>
                <a asp-controller="Auth" asp-action="SeleccionTipoRegistro" class="btn btn-outline-secondary mt-2">Volver al área de registro</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <!-- Leaflet CSS y JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        // Inicializar mapa centrado en Ibarra, Ecuador por defecto
        var centerLat = document.getElementById('lat-input').value ? parseFloat(document.getElementById('lat-input').value) : 0.3517;
        var centerLng = document.getElementById('lng-input').value ? parseFloat(document.getElementById('lng-input').value) : -78.1222;
        var zoomLevel = document.getElementById('lat-input').value ? 16 : 14;

        var map = L.map('map').setView([centerLat, centerLng], zoomLevel);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var marker;
        if (document.getElementById('lat-input').value && document.getElementById('lng-input').value) {
            marker = L.marker([centerLat, centerLng]).addTo(map);
        }

        // Función para colocar marcador y extraer datos
        function onMapClick(e) {
            var lat = e.latlng.lat;
            var lng = e.latlng.lng;
            
            if (marker) {
                marker.setLatLng(e.latlng);
            } else {
                marker = L.marker(e.latlng).addTo(map);
            }

            document.getElementById('lat-input').value = lat.toFixed(8);
            document.getElementById('lng-input').value = lng.toFixed(8);

            // Reverse Geocoding (Nominatim API)
            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
                .then(response => response.json())
                .then(data => {
                    if(data && data.address) {
                        var address = data.address;
                        var calle = address.road || address.pedestrian || address.suburb || "";
                        var ciudad = address.city || address.town || address.village || address.county || "";
                        
                        if(calle) document.getElementById('calle-input').value = calle;
                        if(ciudad) document.getElementById('ciudad-input').value = ciudad;
                    }
                })
                .catch(err => console.log(err));
        }

        map.on('click', onMapClick);

        // Buscar lugares
        document.getElementById('btn-buscar').addEventListener('click', function() {
            var query = document.getElementById('buscador-mapa').value;
            if(!query) return;

            fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`)
                .then(response => response.json())
                .then(data => {
                    if(data && data.length > 0) {
                        var result = data[0];
                        var lat = parseFloat(result.lat);
                        var lon = parseFloat(result.lon);
                        
                        map.setView([lat, lon], 16);
                        
                        if (marker) {
                            marker.setLatLng([lat, lon]);
                        } else {
                            marker = L.marker([lat, lon]).addTo(map);
                        }

                        document.getElementById('lat-input').value = lat.toFixed(8);
                        document.getElementById('lng-input').value = lon.toFixed(8);
                        
                        // Parse name
                        var partes = result.display_name.split(',');
                        if(partes.length >= 1) document.getElementById('calle-input').value = partes[0].trim();
                        if(partes.length >= 2) document.getElementById('ciudad-input').value = partes[1].trim();
                    } else {
                        alert('Lugar no encontrado. Intenta con otros términos.');
                    }
                });
        });

        // Intentar obtener la ubicación actual del usuario si no hay datos previos
        // Intentar obtener la ubicación actual del usuario si no hay datos previos
        if (!document.getElementById('lat-input').value && navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function(position) {
                var lat = position.coords.latitude;
                var lng = position.coords.longitude;
                map.setView([lat, lng], 16);
                onMapClick({ latlng: L.latLng(lat, lng) });
            });
        }
    </script>
}
