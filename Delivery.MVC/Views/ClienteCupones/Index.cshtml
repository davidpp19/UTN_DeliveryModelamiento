@model IEnumerable<Delivery.Modelos.Entidades.Cupon>
@{
    ViewData["Title"] = "Cupones Disponibles";
}

<h1 class="my-4"><i class="bi bi-ticket-perforated"></i> Cupones de Descuento</h1>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">Actualmente no hay cupones disponibles.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var cupon in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-success">
                    <div class="card-header bg-success text-white text-center fw-bold fs-5">
                        @cupon.Codigo
                    </div>
                    <div class="card-body text-center">
                        <h4 class="text-success mb-3">
                            @if(cupon.TipoDescuento == Delivery.Modelos.Enums.TipoDescuentoEnum.Porcentaje)
                            {
                                <span>-@cupon.ValorDescuento.ToString("0.##")% OFF</span>
                            }
                            else
                            {
                                <span>-$@cupon.ValorDescuento.ToString("0.00")</span>
                            }
                        </h4>
                        <p class="small mb-0">Válido hasta: @cupon.FechaFin.ToLocalTime().ToString("d")</p>
                        @if(cupon.PedidoMinimo.HasValue)
                        {
                            <p class="small">Compra mínima: $@cupon.PedidoMinimo.Value.ToString("0.00")</p>
                        }
                    </div>
                    <div class="card-footer bg-white border-top-0 d-grid">
                        <button class="btn btn-outline-success" onclick="navigator.clipboard.writeText('@cupon.Codigo'); alert('¡Código copiado!');">Copiar Código</button>
                    </div>
                </div>
            </div>
        }
    </div>
}
