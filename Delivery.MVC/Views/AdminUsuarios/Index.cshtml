@model IEnumerable<Delivery.Modelos.Entidades.Usuario>
@{ ViewData["Title"] = "Gestión de Usuarios"; }
<h1>Usuarios del Sistema</h1>
<div class="alert alert-info">Esta es una vista básica de solo lectura para evitar errores 404.</div>
<table class="table">
    <thead><tr><th>ID</th><th>Nombre</th><th>Email</th></tr></thead>
    <tbody>
        @foreach (var item in Model) {
            <tr><td>@item.Id</td><td>@item.Nombre @item.Apellidos</td><td>@item.Email</td></tr>
        }
    </tbody>
</table>
