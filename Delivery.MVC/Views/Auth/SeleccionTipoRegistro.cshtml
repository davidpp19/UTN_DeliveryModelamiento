@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CrearCuentaTitulo"];
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5" data-aos="fade-down">
        <h1 class="display-5 text-primary fw-bold mb-3">@Localizer["CrearCuentaTitulo"]</h1>
        <p class="lead text-light">@Localizer["SeleccionaTipoCuenta"]</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col" data-aos="fade-up" data-aos-delay="100">
            <div class="card glass-card h-100 text-center p-4">
                <div class="card-body d-flex flex-column">
                    <i class="bi bi-person-heart fs-1 text-info mb-3"></i>
                    <h3 class="text-light fw-bold">@Localizer["SoyCliente"]</h3>
                    <p class="text-muted flex-grow-1">@Localizer["SoyClienteDesc"]</p>
                    <a asp-controller="Auth" asp-action="Registro" class="btn btn-liquid mt-3 w-100">@Localizer["RegCliente"]</a>
                </div>
            </div>
        </div>
        <div class="col" data-aos="fade-up" data-aos-delay="200">
            <div class="card glass-card h-100 text-center p-4">
                <div class="card-body d-flex flex-column">
                    <i class="bi bi-bicycle fs-1 text-warning mb-3"></i>
                    <h3 class="text-light fw-bold">@Localizer["SoyRepartidor"]</h3>
                    <p class="text-muted flex-grow-1">@Localizer["SoyRepartidorDesc"]</p>
                    <a asp-controller="RegistroRepartidor" asp-action="Index" class="btn btn-liquid mt-3 w-100">@Localizer["RegRepartidor"]</a>
                </div>
            </div>
        </div>
        <div class="col" data-aos="fade-up" data-aos-delay="300">
            <div class="card glass-card h-100 text-center p-4">
                <div class="card-body d-flex flex-column">
                    <i class="bi bi-shop fs-1 text-danger mb-3"></i>
                    <h3 class="text-light fw-bold">@Localizer["SoyRestaurante"]</h3>
                    <p class="text-muted flex-grow-1">@Localizer["SoyRestauranteDesc"]</p>
                    <a asp-controller="RegistroRestaurante" asp-action="Index" class="btn btn-liquid mt-3 w-100">@Localizer["RegRestaurante"]</a>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5" data-aos="fade-in">
        <hr style="border-color: var(--glass-border); width: 50%; margin: 0 auto 2rem auto;" />
        <p class="text-muted">
            @Localizer["YaTienesCuenta"] 
            <a asp-controller="Auth" asp-action="Login" class="text-primary fw-bold text-decoration-none">@Localizer["IniciarSesion"]</a>
        </p>
    </div>
</div>
