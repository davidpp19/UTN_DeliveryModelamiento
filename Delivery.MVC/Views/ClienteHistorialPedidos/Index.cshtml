@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@{
    ViewData["Title"] = "Historial de Pedidos";
}

<h1 class="my-4"><i class="bi bi-clock-history"></i> Mi Historial de Pedidos</h1>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">Aún no tienes pedidos en tu historial.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var pedido in Model)
        {
            <div class="col">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <strong>Pedido #@pedido.Id</strong>
                        <span class="badge bg-secondary">@pedido.EstadoPedido</span>
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><i class="bi bi-calendar"></i> @pedido.FechaPedido.ToLocalTime().ToString("g")</p>
                        <p class="mb-1"><i class="bi bi-shop"></i> @(pedido.Restaurante?.Nombre ?? "Restaurante Desconocido")</p>
                        <p class="mb-3"><i class="bi bi-cash"></i> Total: $@pedido.Total.ToString("0.00")</p>
                        
                        <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-sm btn-outline-primary">Ver Detalles</a>
                        
                        @if (pedido.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.Entregado)
                        {
                            <a asp-action="Calificar" asp-route-id="@pedido.Id" class="btn btn-sm btn-warning ms-2"><i class="bi bi-star"></i> Calificar</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
