@model IEnumerable<Delivery.Modelos.Entidades.Producto>
@{ ViewData["Title"] = "Gestión de Productos"; }
<h1>Todos los Productos</h1>
<table class="table">
    <thead><tr><th>ID</th><th>Nombre</th><th>Restaurante ID</th><th>Precio</th></tr></thead>
    <tbody>
        @foreach (var item in Model) {
            <tr><td>@item.Id</td><td>@item.Nombre</td><td>@item.RestauranteId</td><td>$@item.Precio</td></tr>
        }
    </tbody>
</table>
