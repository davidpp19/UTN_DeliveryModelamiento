@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["PanelAdministrador"];
}

<div class="container mt-4">
    <h1 class="mb-4 text-primary"><i class="bi bi-speedometer2"></i> @Localizer["PanelAdministracion"]</h1>
    <p class="lead">@Localizer["BienvenidoCentroControl"]</p>
    <hr />

    <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
        <div class="col">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["UsuariosCardTitle"]</h5>
                    <p class="card-text">@Localizer["GestionaUsuariosDesc"]</p>
                    <a asp-controller="Usuarios" asp-action="Index" class="btn btn-primary">@Localizer["IrAUsuariosBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-success">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["RestaurantesCardTitle"]</h5>
                    <p class="card-text">@Localizer["AdministraRestaurantesDesc"]</p>
                    <a asp-controller="Restaurantes" asp-action="Index" class="btn btn-success">@Localizer["IrARestaurantesBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-info">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["ProductosCardTitle"]</h5>
                    <p class="card-text">@Localizer["ControlGeneralCatalogoDesc"]</p>
                    <a asp-controller="Productos" asp-action="Index" class="btn btn-info text-white">@Localizer["IrAProductosBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-warning">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["CategoriasCardTitle"]</h5>
                    <p class="card-text">@Localizer["GestionCategoriasDesc"]</p>
                    <a asp-controller="CategoriasProducto" asp-action="Index" class="btn btn-warning">@Localizer["IrACategoriasBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-danger">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["PedidosCardTitle"]</h5>
                    <p class="card-text">@Localizer["VisualizaPedidosDesc"]</p>
                    <a asp-controller="Pedidos" asp-action="Index" class="btn btn-danger">@Localizer["IrAPedidosBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-secondary">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["RepartidoresCardTitle"]</h5>
                    <p class="card-text">@Localizer["GestionRepartidoresEstadosDesc"]</p>
                    <a asp-controller="Repartidores" asp-action="Index" class="btn btn-secondary">@Localizer["IrARepartidoresBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-dark">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["VehiculosCardTitle"]</h5>
                    <p class="card-text">@Localizer["GestionVehiculosDesc"]</p>
                    <a asp-controller="Vehiculos" asp-action="Index" class="btn btn-dark">@Localizer["IrAVehiculosBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["CuponesCardTitle"]</h5>
                    <p class="card-text">@Localizer["AdministracionPromocionesDesc"]</p>
                    <a asp-controller="Cupones" asp-action="Index" class="btn btn-outline-primary">@Localizer["IrACuponesBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-success">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["PagosCardTitle"]</h5>
                    <p class="card-text">@Localizer["HistorialTransaccionesDesc"]</p>
                    <a asp-controller="Pagos" asp-action="Index" class="btn btn-outline-success">@Localizer["IrAPagosBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-warning">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["CalificacionesCardTitle"]</h5>
                    <p class="card-text">@Localizer["ModeracionResenasDesc"]</p>
                    <a asp-controller="Resenas" asp-action="Index" class="btn btn-outline-warning">@Localizer["IrAResenasBtn"]</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 shadow-sm border-danger">
                <div class="card-body text-center">
                    <h5 class="card-title">@Localizer["AuditoriaCardTitle"]</h5>
                    <p class="card-text">@Localizer["RegistrosAccionesDesc"]</p>
                    <a asp-controller="Auditorias" asp-action="Index" class="btn btn-outline-danger">@Localizer["IrAAuditoriaBtn"]</a>
                </div>
            </div>
        </div>
    </div>
</div>
