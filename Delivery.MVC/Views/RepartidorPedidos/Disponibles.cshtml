@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Pedidos Disponibles";
}

<h1 class="my-4">Pedidos Listos para Recoger</h1>
<hr />

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row" id="pedidos-container">
    @if (!Model.Any())
    {
        <div class="col-12" id="no-pedidos-msg">
            <div class="alert alert-info">
                No hay pedidos disponibles para asignar en este momento. Espera nuevas notificaciones.
            </div>
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            <div class="col-md-4 mb-4 pedido-card" id="pedido-@item.Id">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Pedido #@item.Id</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><strong>Restaurante:</strong> @item.Restaurante?.Nombre</p>
                        <p class="mb-1"><strong>Costo EnvÃ­o:</strong> $@item.CostoEnvio.ToString("0.00")</p>
                        <p class="mb-1"><strong>Total:</strong> $@item.Total.ToString("0.00")</p>
                    </div>
                    <div class="card-footer bg-white border-top-0">
                        <form asp-action="AceptarPedido" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-warning w-100 fw-bold btn-confirm" data-title="¿Confirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">Â¡Aceptar Pedido!</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('@(Configuration["ApiSettings:BaseUrl"] ?? Configuration["ApiUrl"] ?? "https://localhost:7087")'.replace(/\/$/, "") + "/notificacionesHub")
            .withAutomaticReconnect()
            .build();

        connection.on("NuevoPedidoDisponible", function (pedidoId) {
            // Verificar si la tarjeta ya existe para no duplicarla
            if (document.getElementById("pedido-" + pedidoId)) return;

            fetch('/RepartidorPedidos/GetPedidoInfo/' + pedidoId)
                .then(response => response.json())
                .then(data => {
                    const noPedidosMsg = document.getElementById("no-pedidos-msg");
                    if (noPedidosMsg) noPedidosMsg.remove();

                    const container = document.getElementById("pedidos-container");
                    
                    const cardHtml = `
                        <div class="col-md-4 mb-4 pedido-card" id="pedido-${data.id}">
                            <div class="card shadow-sm h-100">
                                <div class="card-header bg-success text-white">
                                    <h5 class="mb-0">Pedido #${data.id}</h5>
                                </div>
                                <div class="card-body">
                                    <p class="mb-1"><strong>Restaurante:</strong> ${data.restaurante}</p>
                                    <p class="mb-1"><strong>Costo EnvÃ­o:</strong> $${data.costoEnvio}</p>
                                    <p class="mb-1"><strong>Total:</strong> $${data.total}</p>
                                </div>
                                <div class="card-footer bg-white border-top-0">
                                    <form action="/RepartidorPedidos/AceptarPedido" method="post">
                                        <input type="hidden" name="id" value="${data.id}" />
                                        <button type="submit" class="btn btn-warning w-100 fw-bold btn-confirm" data-title="¿Confirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">Â¡Aceptar Pedido!</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    `;
                    // Agregar al principio
                    container.insertAdjacentHTML('afterbegin', cardHtml);
                })
                .catch(err => console.error("Error al obtener pedido:", err));
        });

        connection.on("PedidoAsignado", function (pedidoId) {
            // Remover el pedido del DOM porque alguien mÃ¡s lo tomÃ³
            const card = document.getElementById("pedido-" + pedidoId);
            if (card) {
                card.remove();
            }
            if (document.querySelectorAll('.pedido-card').length === 0) {
                const container = document.getElementById("pedidos-container");
                if (!document.getElementById("no-pedidos-msg")) {
                    container.innerHTML = `
                        <div class="col-12" id="no-pedidos-msg">
                            <div class="alert alert-info">
                                No hay pedidos disponibles para asignar en este momento. Espera nuevas notificaciones.
                            </div>
                        </div>`;
                }
            }
        });

        connection.start().then(function () {
            console.log("SignalR Connected!");
            connection.invoke("UnirseGrupoRepartidoresLibres").catch(function (err) {
                return console.error(err.toString());
            });
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}

