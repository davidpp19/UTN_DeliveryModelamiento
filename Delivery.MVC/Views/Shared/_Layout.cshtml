@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RayoExpres</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Delivery.MVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">RayoExpres</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @* ─── MENÚ IZQUIERDO POR ROL ─── *@
                    <ul class="navbar-nav flex-grow-1">

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @* ── CLIENTE ── *@
                            if (User.IsInRole("Cliente"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">@Localizer["Inicio"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">@Localizer["Restaurantes"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteCarrito" asp-action="Index">@Localizer["MiCarrito"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteHistorialPedidos" asp-action="Index">@Localizer["MisPedidos"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteDirecciones" asp-action="Index">@Localizer["MisDirecciones"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteCupones" asp-action="Index">@Localizer["MisCupones"]</a></li>
                            }
                            @* ── ADMINISTRADOR ── *@
                            else if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownAdmin" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        @Localizer["Administracion"]
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="navbarDropdownAdmin">
                                        <li><a class="dropdown-item" asp-controller="DashboardAdministrador" asp-action="Index">@Localizer["Dashboard"]</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminUsuarios" asp-action="Index">@Localizer["Usuarios"]</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminRestaurantes" asp-action="Index">@Localizer["Restaurantes"]</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminRepartidores" asp-action="Index">@Localizer["Repartidores"]</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminProductos" asp-action="Index">@Localizer["Productos"]</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminPedidos" asp-action="Index">@Localizer["Pedidos"]</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminCupones" asp-action="Index">@Localizer["Cupones"]</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-warning" asp-controller="AdminAprobaciones" asp-action="Repartidores">Sol. Repartidores</a></li>
                                        <li><a class="dropdown-item text-warning" asp-controller="AdminAprobaciones" asp-action="Restaurantes">Sol. Restaurantes</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Auditorias" asp-action="Index">@Localizer["Auditoria"]</a></li>
                                    </ul>
                                </li>
                            }
                            @* ── RESTAURANTE ── *@
                            else if (User.IsInRole("Restaurante"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="DashboardRestaurante" asp-action="Index">@Localizer["Dashboard"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RestauranteProductos" asp-action="Index">@Localizer["Productos"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RestaurantePedidos" asp-action="Index">@Localizer["Pedidos"]</a></li>
                            }
                            @* ── REPARTIDOR ── *@
                            else if (User.IsInRole("Repartidor"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="DashboardRepartidor" asp-action="Index">@Localizer["Dashboard"]</a></li>
                                <li class="nav-item"><a class="nav-link text-warning fw-bold" asp-controller="RepartidorPedidos" asp-action="Disponibles">@Localizer["PedidosDisponibles"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RepartidorPedidos" asp-action="Index">@Localizer["MisEntregas"]</a></li>
                            }
                        }
                        else
                        {
                            @* ── VISITANTE ── *@
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">@Localizer["Inicio"]</a></li>
                            <li class="nav-item"><a class="nav-link" href="#como-funciona">@Localizer["ComoFunciona"]</a></li>
                            <li class="nav-item"><a class="nav-link" href="#restaurantes">@Localizer["Restaurantes"]</a></li>
                        }
                    </ul>

                    @* ─── BARRA DE BÚSQUEDA — Solo visible para Clientes ─── *@
                    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Cliente"))
                    {
                        <form class="d-flex me-3" asp-controller="Home" asp-action="Buscar" method="get">
                            <input class="form-control me-2" type="search" placeholder="@Localizer["BuscarPlaceholder"]" name="q" value="@ViewBag.Query" />
                            <button class="btn btn-outline-primary" type="submit">@Localizer["BuscarBoton"]</button>
                        </form>
                    }

                    @* ─── MENÚ DERECHO (usuario / login / IDIOMA) ─── *@
                    <ul class="navbar-nav">
                        <!-- SELECTOR DE IDIOMA -->
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle" href="#" id="idiomaDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                🌐 @Localizer["Idioma"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="idiomaDropdown">
                                <li>
                                    <form asp-controller="Idioma" asp-action="SetLanguage" method="post" class="m-0 p-0">
                                        <input type="hidden" name="culture" value="es" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item">🇪🇸 @Localizer["Espanol"]</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Idioma" asp-action="SetLanguage" method="post" class="m-0 p-0">
                                        <input type="hidden" name="culture" value="en" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item">🇺🇸 @Localizer["Ingles"]</button>
                                    </form>
                                </li>
                            </ul>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold d-flex align-items-center" href="#" id="navbarUser" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @{
                                        var fotoPerfilClaim = User.FindFirst("FotoPerfilUrl")?.Value;
                                        var avatarUrl = !string.IsNullOrEmpty(fotoPerfilClaim) ? fotoPerfilClaim : "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(User.Identity.Name ?? "U") + "&background=random";
                                    }
                                    <img src="@avatarUrl" alt="Avatar" class="rounded-circle me-2" style="width: 30px; height: 30px; object-fit: cover;" />
                                    <span>@Localizer["HolaUsuario", User.Identity?.Name ?? "Usuario"]</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarUser">
                                    @if (User.IsInRole("Cliente"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="ClientePerfil" asp-action="CompletarPerfil">@Localizer["MiPerfil"]</a></li>
                                    }
                                    else if (User.IsInRole("Restaurante"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="RestaurantePerfil" asp-action="CompletarPerfil">@Localizer["PerfilRestaurante"]</a></li>
                                    }
                                    else if (User.IsInRole("Repartidor"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="RepartidorPerfil" asp-action="CompletarPerfil">@Localizer["PerfilRepartidor"]</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">@Localizer["CerrarSesion"]</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary me-2" asp-controller="Auth" asp-action="Login">@Localizer["IniciarSesion"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-controller="Auth" asp-action="SeleccionTipoRegistro">@Localizer["Registrarse"]</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 - RayoExpres - El servicio de delivery más rápido.
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
