@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model dynamic
@{
    ViewData["Title"] = Localizer["ResultadosBusquedaTitle"];
    var restaurantes = Model.Restaurantes as List<Delivery.Modelos.Entidades.Restaurante>;
    var productos = Model.Productos as List<Delivery.Modelos.Entidades.Producto>;
}

<div class="container mt-4">
    <h2>@Localizer["ResultadosPara", ViewBag.Query]</h2>
    <hr />

    <h4 class="mt-4 mb-3">@Localizer["RestaurantesEncontrados", restaurantes?.Count ?? 0]</h4>
    @if (restaurantes != null && restaurantes.Any())
    {
        <div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
            @foreach (var res in restaurantes)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@res.Nombre</h5>
                            <p class="card-text text-muted">@res.Categoria</p>
                            <a asp-action="Restaurante" asp-route-id="@res.Id" class="btn btn-primary btn-sm">@Localizer["VerMenu"]</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary">@Localizer["NoRestaurantesBusqueda"]</div>
    }

    <h4 class="mt-5 mb-3">@Localizer["ProductosEncontrados", productos?.Count ?? 0]</h4>
    @if (productos != null && productos.Any())
    {
        <div class="row row-cols-2 row-cols-md-4 g-4 mb-4">
            @foreach (var prod in productos)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body p-3">
                            <h6 class="card-title mb-1">@prod.Nombre</h6>
                            <p class="text-success fw-bold mb-2">$@prod.Precio.ToString("0.00")</p>
                            <p class="text-muted small">Restaurante ID: @prod.RestauranteId</p>
                            <form asp-controller="ClienteCarrito" asp-action="Agregar" method="post" class="d-grid">
                                <input type="hidden" name="ProductoId" value="@prod.Id" />
                                <input type="hidden" name="Cantidad" value="1" />
                                <input type="hidden" name="RestauranteId" value="@prod.RestauranteId" />
                                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-cart-plus"></i> Agregar</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary">@Localizer["NoProductosBusqueda"]</div>
    }
</div>
