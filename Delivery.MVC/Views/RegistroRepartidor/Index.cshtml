@model Delivery.Modelos.DTOs.RegistroRepartidorDto
@{
    ViewData["Title"] = "Registro de Repartidor";
}

<h1>Registro de Repartidor</h1>
<p>Completa el formulario para unirte como repartidor de RayoExpres. Tu cuenta será revisada antes de ser activada.</p>

<p><a asp-controller="Auth" asp-action="SeleccionTipoRegistro">Volver a selección de tipo de cuenta</a></p>
<hr />

<form asp-action="Index" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <h4>Datos Personales</h4>

    <div>
        <label asp-for="Nombre">Nombre</label>
        <input asp-for="Nombre" placeholder="Tu nombre" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Apellidos">Apellidos</label>
        <input asp-for="Apellidos" placeholder="Tus apellidos" />
        <span asp-validation-for="Apellidos" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Email">Correo Electrónico</label>
        <input asp-for="Email" type="email" placeholder="correo@ejemplo.com" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Telefono">Teléfono</label>
        <input asp-for="Telefono" type="tel" placeholder="0991234567" />
        <span asp-validation-for="Telefono" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Cedula">Cédula de Identidad</label>
        <input asp-for="Cedula" placeholder="1234567890" />
        <span asp-validation-for="Cedula" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Password">Contraseña</label>
        <input asp-for="Password" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="ConfirmPassword">Confirmar Contraseña</label>
        <input asp-for="ConfirmPassword" type="password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <hr />
    <h4>Datos del Vehículo</h4>

    <div>
        <label asp-for="TipoVehiculo">Tipo de Vehículo</label>
        <div class="d-flex align-items-center">
            <select asp-for="TipoVehiculo"
                    asp-items="Html.GetEnumSelectList<Delivery.Modelos.Enums.TipoVehiculoEnum>()" class="form-control" style="width: auto; margin-right: 10px;">
            </select>
            <button type="submit" name="accion" value="actualizar" formnovalidate class="btn btn-secondary btn-sm">Confirmar Tipo</button>
        </div>
        <span asp-validation-for="TipoVehiculo" class="text-danger"></span>
        <small class="text-muted d-block">Selecciona y haz clic en "Confirmar Tipo" para actualizar los campos requeridos.</small>
    </div>

    @if (Model != null && Model.TipoVehiculo != Delivery.Modelos.Enums.TipoVehiculoEnum.Bicicleta)
    {
        <hr />
        <h4>Datos de Licencia (Requerido para @Model.TipoVehiculo.ToString())</h4>
        <div>
            <label asp-for="LicenciaConducir">Número de Licencia de Conducir</label>
            <input asp-for="LicenciaConducir" placeholder="Ej: LIC-IMB-1234567" />
            <span asp-validation-for="LicenciaConducir" class="text-danger"></span>
        </div>
    }
    else
    {
        <!-- Hidden para que pase la validación del modelo que espera string -->
        <input type="hidden" asp-for="LicenciaConducir" value="N/A" />
    }

    <div>
        <label asp-for="Marca">Marca</label>
        <input asp-for="Marca" placeholder="Ej: Honda" />
        <span asp-validation-for="Marca" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Modelo">Modelo</label>
        <input asp-for="Modelo" placeholder="Ej: Wave110" />
        <span asp-validation-for="Modelo" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Color">Color</label>
        <input asp-for="Color" placeholder="Ej: Rojo" />
        <span asp-validation-for="Color" class="text-danger"></span>
    </div>

    @if (Model != null && Model.TipoVehiculo != Delivery.Modelos.Enums.TipoVehiculoEnum.Bicicleta)
    {
        <div>
            <label asp-for="Placa">Placa</label>
            <input asp-for="Placa" placeholder="Ej: PBX-1234" />
            <span asp-validation-for="Placa" class="text-danger"></span>
        </div>
    }
    else
    {
        <input type="hidden" asp-for="Placa" value="N/A" />
    }

    <div>
        <label asp-for="Anio">Año del Vehículo</label>
        <input asp-for="Anio" type="number" placeholder="Ej: 2022" min="1990" max="2030" />
    </div>

    <br />
    <button type="submit" name="accion" value="registrar" class="btn btn-primary">Registrarme como Repartidor</button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
