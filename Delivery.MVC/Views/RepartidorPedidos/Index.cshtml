@model IEnumerable<Delivery.Modelos.Entidades.Pedido>
@{ ViewData["Title"] = "Mis Entregas"; }
<h1 class="my-4">Mis Entregas</h1>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nº Pedido</th>
                <th>Cliente</th>
                <th>Restaurante</th>
                <th>Dirección</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td><strong>#@item.Id</strong></td>
                    <td>@(item.Usuario?.Nombre ?? "Cliente")</td>
                    <td>@(item.Restaurante?.Nombre ?? "Restaurante")</td>
                    <td>@(item.DireccionEntrega?.Calle ?? "Sin Dirección")</td>
                    <td><span class="badge bg-secondary">@item.EstadoPedido</span></td>
                    <td>
                        <a asp-action="CambiarEstado" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-arrow-repeat"></i> Estado
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                            <i class="bi bi-eye"></i> Mapa
                        </a>
                        <a asp-action="Cancelar" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
