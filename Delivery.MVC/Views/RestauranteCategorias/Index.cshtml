@model IEnumerable<Delivery.Modelos.Entidades.CategoriaProducto>
@{ ViewData["Title"] = "Mis CategorĂ­as"; }
<h1 class="my-4">Mis CategorĂ­as</h1>
<p><a asp-action="Create" class="btn btn-primary">Crear Nueva CategorĂ­a</a></p>
<div class="table-responsive glass-card p-4 rounded-4 shadow-lg border-0 mt-3 table-scrollable">
    <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
        <thead class="border-bottom border-secondary">
            <tr>
                <th>Restaurante</th>
                <th>Nombre</th>
                <th>DescripciĂłn</th>
                <th>Creado El</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@ViewBag.RestauranteNombre</td>
                <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                <td>@item.CreadoEn.ToLocalTime().ToString("g")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning btn-confirm" data-title="żConfirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger btn-confirm" data-title="żEliminar registro?" data-text="Esta acción no se puede deshacer" data-danger="true" data-confirm="Sí, eliminar">Eliminar</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>



