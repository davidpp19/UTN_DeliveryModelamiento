@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RayoExpres</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Delivery.MVC.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-glass mb-3 sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo.png" alt="RayoExpres Logo" style="height: 40px; object-fit: contain;" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @* ─── MENÚ IZQUIERDO POR ROL ─── *@
                    <ul class="navbar-nav flex-grow-1">

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @* ── CLIENTE ── *@
                            if (User.IsInRole("Cliente"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">@Localizer["Restaurantes"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteCarrito" asp-action="Index">@Localizer["MiCarrito"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteHistorialPedidos" asp-action="Index">@Localizer["MisPedidos"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteDirecciones" asp-action="Index">@Localizer["MisDirecciones"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ClienteCupones" asp-action="Index">@Localizer["MisCupones"]</a></li>
                            }
                            @* ── ADMINISTRADOR ── *@
                            @* Movido a la barra lateral izquierda *@
                            @* ── RESTAURANTE ── *@
                            else if (User.IsInRole("Restaurante"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="DashboardRestaurante" asp-action="Index">@Localizer["Dashboard"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RestauranteCategorias" asp-action="Index">Categorías</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RestauranteProductos" asp-action="Index">@Localizer["Productos"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RestaurantePedidos" asp-action="Index">@Localizer["Pedidos"]</a></li>
                            }
                            @* ── REPARTIDOR ── *@
                            else if (User.IsInRole("Repartidor"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="DashboardRepartidor" asp-action="Index">@Localizer["Dashboard"]</a></li>
                                <li class="nav-item"><a class="nav-link text-warning fw-bold" asp-controller="RepartidorPedidos" asp-action="Disponibles">@Localizer["PedidosDisponibles"]</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RepartidorPedidos" asp-action="Index">@Localizer["MisEntregas"]</a></li>
                            }
                        }
                        else
                        {
                            @* ── VISITANTE ── *@
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">@Localizer["Inicio"]</a></li>
                            <li class="nav-item"><a class="nav-link" href="#como-funciona">@Localizer["ComoFunciona"]</a></li>
                            <li class="nav-item"><a class="nav-link" href="#restaurantes">@Localizer["Restaurantes"]</a></li>
                        }
                    </ul>

                    @* ─── BARRA DE BÚSQUEDA — Solo visible para Clientes ─── *@
                    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Cliente"))
                    {
                        <form class="d-flex me-3" asp-controller="Home" asp-action="Buscar" method="get">
                            <input class="form-control me-2" type="search" placeholder="@Localizer["BuscarPlaceholder"]" name="q" value="@ViewBag.Query" />
                            <button class="btn btn-outline-primary" type="submit">@Localizer["BuscarBoton"]</button>
                        </form>
                    }

                    @* ─── MENÚ DERECHO (usuario / login / IDIOMA) ─── *@
                    <ul class="navbar-nav">
                        <!-- SELECTOR DE IDIOMA -->
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle" href="#" id="idiomaDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-globe"></i> @Localizer["Idioma"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="idiomaDropdown">
                                <li>
                                    <form asp-controller="Idioma" asp-action="SetLanguage" method="post" class="m-0 p-0">
                                        <input type="hidden" name="culture" value="es" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item"><i class="bi bi-translate"></i> @Localizer["Espanol"]</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Idioma" asp-action="SetLanguage" method="post" class="m-0 p-0">
                                        <input type="hidden" name="culture" value="en" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item"><i class="bi bi-translate"></i> @Localizer["Ingles"]</button>
                                    </form>
                                </li>
                            </ul>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <!-- NOTIFICACIONES -->
                            <li class="nav-item dropdown me-3 mt-1">
                                <a class="nav-link position-relative" href="#" id="navbarNotificaciones" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell fs-5"></i>
                                    <span id="notificaciones-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
                                        0
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="navbarNotificaciones" style="width: 300px; max-height: 400px; overflow-y: auto;" id="notificaciones-list">
                                    <li><span class="dropdown-item text-center text-muted small">Cargando...</span></li>
                                </ul>
                            </li>
                            <!-- FIN NOTIFICACIONES -->

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold d-flex align-items-center" href="#" id="navbarUser" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @{
                                        var fotoPerfilClaim = User.FindFirst("FotoPerfilUrl")?.Value;
                                        var avatarUrl = !string.IsNullOrEmpty(fotoPerfilClaim) ? fotoPerfilClaim : "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(User.Identity.Name ?? "U") + "&background=random";
                                    }
                                    <img src="@avatarUrl" alt="Avatar" class="rounded-circle me-2" style="width: 30px; height: 30px; object-fit: cover;" />
                                    <span>@Localizer["HolaUsuario", User.Identity?.Name ?? "Usuario"]</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarUser">
                                    @if (User.IsInRole("Cliente"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="ClientePerfil" asp-action="CompletarPerfil">@Localizer["MiPerfil"]</a></li>
                                    }
                                    else if (User.IsInRole("Restaurante"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="RestaurantePerfil" asp-action="CompletarPerfil">@Localizer["PerfilRestaurante"]</a></li>
                                    }
                                    else if (User.IsInRole("Repartidor"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="RepartidorPerfil" asp-action="CompletarPerfil">@Localizer["PerfilRepartidor"]</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">@Localizer["CerrarSesion"]</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary me-2" asp-controller="Auth" asp-action="Login">@Localizer["IniciarSesion"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-controller="Auth" asp-action="SeleccionTipoRegistro">@Localizer["Registrarse"]</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    @if (User.IsInRole("Admin"))
    {
        <div class="d-flex">
            <!-- Sidebar Administrativo -->
            <div class="bg-dark text-white p-3 shadow" style="width: 280px; min-height: calc(100vh - 70px);">
                <ul class="nav flex-column gap-2 mt-3">
                    <li class="nav-item"><a class="nav-link text-white fw-semibold" asp-controller="DashboardAdministrador" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="AdminUsuarios" asp-action="Index"><i class="bi bi-people me-2"></i> Usuarios</a></li>
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="AdminRestaurantes" asp-action="Index"><i class="bi bi-shop me-2"></i> Restaurantes</a></li>
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="AdminRepartidores" asp-action="Index"><i class="bi bi-bicycle me-2"></i> Repartidores</a></li>
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="AdminProductos" asp-action="Index"><i class="bi bi-box me-2"></i> Productos</a></li>
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="AdminPedidos" asp-action="Index"><i class="bi bi-receipt me-2"></i> Pedidos</a></li>
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="AdminCupones" asp-action="Index"><i class="bi bi-ticket-perforated me-2"></i> Cupones</a></li>
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="Auditorias" asp-action="Index"><i class="bi bi-shield-check me-2"></i> Auditoría</a></li>
                    <li><hr class="dropdown-divider border-secondary my-2"></li>
                    <li class="nav-item"><a class="nav-link text-warning" asp-controller="AdminAprobaciones" asp-action="Repartidores"><i class="bi bi-person-lines-fill me-2"></i> Solicitudes Repartidores</a></li>
                    <li class="nav-item"><a class="nav-link text-warning" asp-controller="AdminAprobaciones" asp-action="Restaurantes"><i class="bi bi-shop-window me-2"></i> Solicitudes Restaurantes</a></li>
                </ul>
            </div>
            
            <!-- Contenido Principal -->
            <div class="flex-grow-1 p-4 bg-light">
                <main role="main" class="pb-3 bg-white p-4 rounded shadow-sm">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <div class="container mt-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="border-top footer text-muted bg-light mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 - RayoExpres - El servicio de delivery más rápido.
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 800,
            once: true,
            offset: 50
        });
    </script>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                cargarNotificaciones();
                // setInterval(cargarNotificaciones, 30000); // Opcional: auto-recargar cada 30s
            });

            function cargarNotificaciones() {
                fetch('/Notificaciones/GetMisNotificaciones')
                    .then(response => response.json())
                    .then(data => {
                        const lista = document.getElementById('notificaciones-list');
                        const badge = document.getElementById('notificaciones-badge');
                        
                        lista.innerHTML = '';
                        let noLeidas = 0;

                        if (!data || data.length === 0) {
                            lista.innerHTML = '<li><span class="dropdown-item text-center text-muted small">No tienes notificaciones</span></li>';
                            badge.classList.add('d-none');
                            return;
                        }

                        data.forEach(n => {
                            if (!n.leida) noLeidas++;
                            
                            const li = document.createElement('li');
                            li.innerHTML = `
                                <a class="dropdown-item ${n.leida ? '' : 'fw-bold bg-light'}" href="#" onclick="marcarLeida(${n.id}, event)">
                                    <div class="d-flex w-100 justify-content-between">
                                        <small class="text-muted">${new Date(n.creadaEn).toLocaleDateString()}</small>
                                    </div>
                                    <p class="mb-1 text-wrap" style="font-size: 0.9rem;">${n.mensaje}</p>
                                </a>
                                <li><hr class="dropdown-divider"></li>
                            `;
                            lista.appendChild(li);
                        });

                        if (noLeidas > 0) {
                            badge.textContent = noLeidas;
                            badge.classList.remove('d-none');
                        } else {
                            badge.classList.add('d-none');
                        }
                    })
                    .catch(error => console.error('Error al cargar notificaciones:', error));
            }

            function marcarLeida(id, event) {
                event.preventDefault();
                fetch('/Notificaciones/MarcarComoLeida/' + id, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if (data.exito) {
                            cargarNotificaciones();
                        }
                    });
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
