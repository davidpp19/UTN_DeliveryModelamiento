@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Repartidor>
@{ ViewData["Title"] = Localizer["GestionRepartidores"]; }
<div class="container-fluid mt-4" data-aos="fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold m-0"><i class="bi bi-bicycle me-2"></i> @Localizer["RepartidoresRegistrados"]</h1>
    </div>

    <div class="table-responsive table-scrollable glass-card p-4 rounded-4 shadow-lg border-0">
        <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
            <thead class="border-bottom border-secondary">
                <tr>
                    <th class="text-uppercase text-muted small fw-bold">Usuario ID</th>
                    <th class="text-uppercase text-muted small fw-bold">Repartidor (Conectado a)</th>
                    <th class="text-uppercase text-muted small fw-bold">@Localizer["LicenciaTag"]</th>
                    <th class="text-uppercase text-muted small fw-bold">Estado Aprobación</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr class="glass-row">
                        <td class="text-light fw-bold">@item.UsuarioId</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-primary rounded-circle me-3 d-flex justify-content-center align-items-center text-white fw-bold" style="width: 40px; height: 40px;">
                                    <i class="bi bi-person-lines-fill"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-white">@(item.Usuario?.Nombre ?? "N/A") @(item.Usuario?.Apellidos ?? "")</div>
                                    <small class="text-muted">Email: @(item.Usuario?.Email ?? "N/A")</small>
                                </div>
                            </div>
                        </td>
                        <td class="text-light">
                            <i class="bi bi-card-heading text-info me-1"></i> @item.LicenciaConducir
                        </td>
                        <td>
                            @if (item.EstadoAprobacion == Delivery.Modelos.Enums.EstadoAprobacionEnum.Aprobado)
                            {
                                <span class="badge bg-success text-white p-2 rounded-pill shadow-sm"><i class="bi bi-check-circle me-1"></i> Aprobado</span>
                            }
                            else if (item.EstadoAprobacion == Delivery.Modelos.Enums.EstadoAprobacionEnum.Pendiente)
                            {
                                <span class="badge bg-warning text-dark p-2 rounded-pill shadow-sm"><i class="bi bi-clock-history me-1"></i> Pendiente</span>
                            }
                            else
                            {
                                <span class="badge bg-danger text-white p-2 rounded-pill shadow-sm"><i class="bi bi-x-circle me-1"></i> Rechazado</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



