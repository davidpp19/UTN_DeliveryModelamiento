@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Usuario>
@{ ViewData["Title"] = Localizer["GestionUsuarios"]; }
<div class="container-fluid mt-4" data-aos="fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold m-0"><i class="bi bi-people-fill me-2"></i> @Localizer["UsuariosSistema"]</h1>
    </div>

    <div class="table-responsive table-scrollable glass-card p-4 rounded-4 shadow-lg border-0">
        <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
            <thead class="border-bottom border-secondary">
                <tr>
                    <th class="text-uppercase text-muted small fw-bold">ID</th>
                    <th class="text-uppercase text-muted small fw-bold">@Localizer["NombreTag"]</th>
                    <th class="text-uppercase text-muted small fw-bold">@Localizer["EmailTag"]</th>
                    <th class="text-uppercase text-muted small fw-bold">Rol / Tipo</th>
                    <th class="text-uppercase text-muted small fw-bold">Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr class="glass-row">
                        <td class="text-light fw-bold">@item.Id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                @if(!string.IsNullOrEmpty(item.FotoPerfilUrl)) {
                                    <img src="@item.FotoPerfilUrl" class="rounded-circle me-3 border border-primary" style="width: 40px; height: 40px; object-fit: cover;" />
                                } else {
                                    <div class="bg-secondary rounded-circle me-3 d-flex justify-content-center align-items-center text-white fw-bold" style="width: 40px; height: 40px;">
                                        @item.Nombre.Substring(0, 1)
                                    </div>
                                }
                                <div>
                                    <div class="fw-bold text-white">@item.Nombre @item.Apellidos</div>
                                    <small class="text-muted">@item.Cedula</small>
                                </div>
                            </div>
                        </td>
                        <td class="text-light">@item.Email</td>
                        <td>
                            <span class="badge bg-primary text-white p-2 rounded-pill shadow-sm">
                                <i class="bi bi-person-badge me-1"></i> @(item.Rol?.Nombre ?? item.TipoUsuario.ToString())
                            </span>
                        </td>
                        <td>
                            @if (item.Activo)
                            {
                                <span class="badge bg-success text-white p-2 rounded-pill shadow-sm"><i class="bi bi-check-circle me-1"></i> Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger text-white p-2 rounded-pill shadow-sm"><i class="bi bi-x-circle me-1"></i> Inactivo</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



