@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["PanelRestauranteTitle"];
}

<div class="container mt-4">
    <h1 class="mb-4 text-success"><i class="bi bi-shop"></i> @Localizer["PanelRestauranteTitle"]</h1>
    
    @if (ViewBag.Estado == "Pendiente" || ViewBag.Estado == "Rechazado")
    {
        <div class="alert alert-warning">
            <h4><i class="bi bi-exclamation-triangle"></i> @string.Format(Localizer["RestauranteEstadoTitle"].Value, ViewBag.Estado)</h4>
            @if (ViewBag.Estado == "Pendiente")
            {
                <p>@Localizer["RestaurantePendienteMsg"]</p>
            }
            else
            {
                <p>@Localizer["RestauranteRechazadoMsg"]</p>
            }
        </div>
    }
    else
    {
        <p class="lead">@Localizer["BienvenidoRestauranteMsg"]</p>
        <hr />

        <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
            <div class="col">
                <div class="card h-100 shadow-sm border-info">
                    <div class="card-body text-center">
                        <h5 class="card-title">@Localizer["MisProductosTitle"]</h5>
                        <p class="card-text">@Localizer["MisProductosDesc"]</p>
                        <a asp-controller="RestauranteProductos" asp-action="Index" class="btn btn-info text-white">@Localizer["IrMisProductosBtn"]</a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm border-warning">
                    <div class="card-body text-center">
                        <h5 class="card-title">@Localizer["MisCategoriasTitle"]</h5>
                        <p class="card-text">@Localizer["MisCategoriasDesc"]</p>
                        <a asp-controller="RestauranteCategorias" asp-action="Index" class="btn btn-warning">@Localizer["IrCategoriasBtn"]</a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm border-danger">
                    <div class="card-body text-center">
                        <h5 class="card-title">@Localizer["PedidosActivosTitle"]</h5>
                        <p class="card-text">@Localizer["PedidosActivosDesc"]</p>
                        <a asp-controller="RestaurantePedidos" asp-action="Index" class="btn btn-danger">@Localizer["IrPedidosBtn"]</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
