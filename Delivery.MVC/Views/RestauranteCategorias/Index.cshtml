@model IEnumerable<Delivery.Modelos.Entidades.CategoriaProducto>
@{ ViewData["Title"] = "Mis Categorías"; }
<h1 class="my-4">Mis Categorías</h1>
<p><a asp-action="Create" class="btn btn-primary">Crear Nueva Categoría</a></p>
<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Restaurante</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Creado El</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@ViewBag.RestauranteNombre</td>
                <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                <td>@item.CreadoEn.ToLocalTime().ToString("g")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
