@model IEnumerable<Delivery.Modelos.Entidades.Repartidor>
@{
    ViewData["Title"] = "Aprobaciones de Repartidores";
}

<div class="container mt-4">
    <h2>Solicitudes de Repartidores Pendientes</h2>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">No hay solicitudes pendientes en este momento.</div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Licencia</th>
                    <th>Fecha Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Usuario?.Nombre) @(item.Usuario?.Apellidos)</td>
                        <td>@(item.Usuario?.Email)</td>
                        <td>@item.LicenciaConducir</td>
                        <td>@item.CreadoEn.ToString("dd/MM/yyyy")</td>
                        <td>
                            <form method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.UsuarioId" />
                                <button type="submit" asp-action="AprobarRepartidor" class="btn btn-sm btn-success">Aprobar</button>
                                <button type="submit" asp-action="RechazarRepartidor" class="btn btn-sm btn-danger ms-1">Rechazar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
