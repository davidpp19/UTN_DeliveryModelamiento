@model Delivery.Modelos.Entidades.Pedido
@{ ViewData["Title"] = "Detalles del Pedido"; }

<div class="container mt-4">
    <h1 class="mb-4">Pedido #@Model.Id</h1>
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Información General</h5>
                </div>
                <div class="card-body">
                    <p><strong>Estado:</strong> <span class="badge bg-secondary">@Model.EstadoPedido</span></p>
                    <p><strong>Fecha del Pedido:</strong> @Model.FechaPedido.ToLocalTime().ToString("g")</p>
                    <p><strong>Cliente:</strong> @(Model.Usuario?.Nombre) @(Model.Usuario?.Apellidos)</p>
                    <p><strong>Repartidor Asignado:</strong> @(Model.RepartidorId.HasValue ? "Asignado" : "Pendiente")</p>
                    @if (!string.IsNullOrEmpty(Model.Notas))
                    {
                        <p><strong>Notas:</strong> @Model.Notas</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-cash"></i> Resumen de Pago</h5>
                </div>
                <div class="card-body">
                    <p><strong>Método de Pago:</strong> @Model.TipoMetodoPago</p>
                    <hr />
                    <p class="d-flex justify-content-between"><span>Subtotal:</span> <span>$@Model.Subtotal.ToString("0.00")</span></p>
                    <p class="d-flex justify-content-between"><span>Costo de Envío:</span> <span>$@Model.CostoEnvio.ToString("0.00")</span></p>
                    @if (Model.MontoDescuento > 0)
                    {
                        <p class="d-flex justify-content-between text-danger"><span>Descuento:</span> <span>-$@Model.MontoDescuento.ToString("0.00")</span></p>
                    }
                    <hr />
                    <h5 class="d-flex justify-content-between fw-bold text-primary"><span>Total:</span> <span>$@Model.Total.ToString("0.00")</span></h5>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="CambiarEstado" asp-route-id="@Model.Id" class="btn btn-warning">Cambiar Estado</a>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Volver a Pedidos</a>
    </div>
</div>
