@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["PanelRepartidorTitle"];
    var repartidor = ViewBag.Repartidor as Delivery.Modelos.Entidades.Repartidor;
    var pedidosRecientes = ViewBag.PedidosRecientes as System.Collections.Generic.List<Delivery.Modelos.Entidades.Pedido>;
}

<h1>@Localizer["PanelRepartidorTitle"]</h1>
<p>@Localizer["BienvenidoRepartidorMsg"]</p>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

@if (ViewBag.Estado == "Pendiente" || ViewBag.Estado == "Rechazado")
{
    <div class="alert alert-warning mt-4">
        <h4><i class="bi bi-exclamation-triangle"></i> @string.Format(Localizer["CuentaEstadoTitle"].Value, ViewBag.Estado)</h4>
        @if (ViewBag.Estado == "Pendiente")
        {
            <p>@Localizer["CuentaPendienteMsg"]</p>
        }
        else
        {
            <p>@Localizer["CuentaRechazadaMsg"]</p>
        }
    </div>
}
else
{
    <h4>@Localizer["ResumenDashboard"]</h4>
    <table class="table table-bordered" style="max-width: 500px;">
        <tr>
            <th>@Localizer["TotalEntregasDashboard"]</th>
            <td>@ViewBag.TotalEntregados</td>
        </tr>
        <tr>
            <th>@Localizer["PedidosActivosDashboard"]</th>
            <td>@ViewBag.PedidosActivos</td>
        </tr>
        @if (repartidor != null)
        {
            <tr>
                <th>@Localizer["CalificacionDashboard"]</th>
                <td>@(repartidor.CalificacionPromedio?.ToString("0.0") ?? Localizer["SinCalificaciones"].Value)</td>
            </tr>
            <tr>
                <th>@Localizer["EstadoDashboard"]</th>
                <td>@repartidor.EstadoAprobacion</td>
            </tr>
        }
    </table>

    <hr />

    <h4>@Localizer["AccionesRapidas"]</h4>
    <a asp-controller="RepartidorPedidos" asp-action="Index">@Localizer["VerMisPedidosAsignados"]</a>

    <hr />

    <h4>@Localizer["UltimosPedidos"]</h4>
    @if (pedidosRecientes == null || !pedidosRecientes.Any())
    {
        <p>@Localizer["NoPedidosAsignados"]</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>@Localizer["PedidoNum"]</th>
                    <th>@Localizer["RestauranteTh"]</th>
                    <th>@Localizer["EstadoTh"]</th>
                    <th>@Localizer["FechaTh"]</th>
                    <th>@Localizer["AccionesTh"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pedido in pedidosRecientes)
                {
                    <tr>
                        <td>@pedido.Id</td>
                        <td>@(pedido.Restaurante?.Nombre ?? Localizer["RestauranteTh"].Value)</td>
                        <td>@pedido.EstadoPedido</td>
                        <td>@pedido.FechaPedido.ToLocalTime().ToString("g")</td>
                        <td>
                            <a asp-controller="RepartidorPedidos" asp-action="Details" asp-route-id="@pedido.Id">@Localizer["VerBtn"]</a>
                            |
                            <a asp-controller="RepartidorPedidos" asp-action="CambiarEstado" asp-route-id="@pedido.Id">@Localizer["CambiarEstadoBtn"]</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
