@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.DTOs.RegistroRepartidorDto
@{
    ViewData["Title"] = Localizer["RegRepartidorTitulo"];
}

<div class="row justify-content-center mt-5 mb-5" data-aos="fade-up">
    <div class="col-md-8 col-lg-6">
        <div class="card glass-card">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-bicycle fs-1 text-warning mb-2"></i>
                    <h3 class="fw-bold text-light">@Localizer["RegRepartidorTitulo"]</h3>
                    <p class="text-muted">@Localizer["RegRepartidorDesc"]</p>
                </div>
                <div class="text-center mb-4">
                    <a asp-controller="Auth" asp-action="SeleccionTipoRegistro" class="btn btn-sm btn-outline-info"><i class="bi bi-arrow-left"></i> @Localizer["VolverSeleccion"]</a>
                </div>
                <hr style="border-color: var(--glass-border);" />

                <form asp-action="Index" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h4 class="text-primary mt-4 mb-3"><i class="bi bi-person-badge"></i> @Localizer["DatosPersonales"]</h4>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label text-light">@Localizer["Nombres"]</label>
                            <input asp-for="Nombre" class="form-control" placeholder="@Localizer["TuNombrePlaceholder"]" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Apellidos" class="form-label text-light">@Localizer["Apellidos"]</label>
                            <input asp-for="Apellidos" class="form-control" placeholder="@Localizer["TusApellidosPlaceholder"]" />
                            <span asp-validation-for="Apellidos" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-light">@Localizer["CorreoElectronico"]</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="@Localizer["EmailPlaceholder"]" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label text-light">@Localizer["Telefono"]</label>
                        <input asp-for="Telefono" type="tel" class="form-control" placeholder="0991234567" maxlength="10" minlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Cedula" class="form-label text-light">@Localizer["Cedula"]</label>
                        <input asp-for="Cedula" class="form-control" placeholder="1234567890" maxlength="10" minlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                        <span asp-validation-for="Cedula" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label text-light">@Localizer["Contrasena"]</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label text-light">@Localizer["ConfirmarContrasena"]</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <hr style="border-color: var(--glass-border);" class="my-4" />
                    <h4 class="text-warning mb-3"><i class="bi bi-bicycle"></i> @Localizer["DatosVehiculo"]</h4>

                    <div class="mb-4 p-3 glass-card border-warning" style="background: rgba(255,193,7,0.05);">
                        <label asp-for="TipoVehiculo" class="form-label text-light">@Localizer["TipoVehiculo"]</label>
                        <div class="d-flex align-items-center gap-2">
                            <select asp-for="TipoVehiculo"
                                    asp-items="Html.GetEnumSelectList<Delivery.Modelos.Enums.TipoVehiculoEnum>()" class="form-select flex-grow-1">
                            </select>
                            <button type="submit" name="accion" value="actualizar" formnovalidate class="btn btn-outline-warning">@Localizer["ConfirmarTipo"]</button>
                        </div>
                        <span asp-validation-for="TipoVehiculo" class="text-danger"></span>
                        <small class="text-muted d-block mt-2">@Localizer["ConfirmarTipoDesc"]</small>
                    </div>

                    @if (Model != null && Model.TipoVehiculo != Delivery.Modelos.Enums.TipoVehiculoEnum.Bicicleta)
                    {
                        <h5 class="text-info mt-4 mb-3"><i class="bi bi-card-heading"></i> @Localizer["DatosLicenciaRequerido"] (@Model.TipoVehiculo.ToString())</h5>
                        <div class="mb-3">
                            <label asp-for="LicenciaConducir" class="form-label text-light">@Localizer["NumeroLicencia"]</label>
                            <input asp-for="LicenciaConducir" class="form-control" placeholder="Ej: LIC-IMB-1234567" />
                            <span asp-validation-for="LicenciaConducir" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-light">@Localizer["FotoLicencia"]</label>
                            <input type="file" name="fotoLicencia" class="form-control bg-dark text-light border-secondary" accept="image/*" required />
                            <small class="text-muted">@Localizer["FotoLicenciaDesc"]</small>
                        </div>
                    }
                    else
                    {
                        <!-- Hidden para que pase la validación del modelo que espera string -->
                        <input type="hidden" asp-for="LicenciaConducir" value="N/A" />
                    }

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Marca" class="form-label text-light">@Localizer["MarcaVehiculo"]</label>
                            <input asp-for="Marca" class="form-control" placeholder="Ej: Honda" />
                            <span asp-validation-for="Marca" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Modelo" class="form-label text-light">@Localizer["ModeloVehiculo"]</label>
                            <input asp-for="Modelo" class="form-control" placeholder="Ej: Wave110" />
                            <span asp-validation-for="Modelo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Color" class="form-label text-light">@Localizer["ColorVehiculo"]</label>
                            <input asp-for="Color" class="form-control" placeholder="Ej: Rojo" />
                            <span asp-validation-for="Color" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Anio" class="form-label text-light">@Localizer["AnioVehiculo"]</label>
                            <input asp-for="Anio" type="number" class="form-control" placeholder="Ej: 2022" min="1990" max="2030" />
                        </div>
                    </div>

                    @if (Model != null && Model.TipoVehiculo != Delivery.Modelos.Enums.TipoVehiculoEnum.Bicicleta)
                    {
                        <div class="mb-4">
                            <label asp-for="Placa" class="form-label text-light">@Localizer["PlacaVehiculo"]</label>
                            <input asp-for="Placa" class="form-control" placeholder="Ej: PBX-1234" />
                            <span asp-validation-for="Placa" class="text-danger"></span>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="Placa" value="N/A" />
                    }

                    <div class="d-grid mt-5">
                        <button type="submit" name="accion" value="registrar" class="btn btn-liquid btn-liquid-primary btn-lg">@Localizer["RegRepartidor"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
