@model IEnumerable<Delivery.Modelos.Entidades.Direccion>
@{ ViewData["Title"] = "Mis Direcciones"; }

<h1>Mis Direcciones</h1>
<p><a asp-action="Create">Agregar Nueva Dirección</a></p>
<hr />

@if (!Model.Any())
{
    <p>No tienes direcciones registradas. <a asp-action="Create">Agrega tu primera dirección</a>.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Alias</th>
                <th>Dirección</th>
                <th>Ciudad</th>
                <th>Principal</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Alias</td>
                    <td>@item.Calle @item.Numero</td>
                    <td>@item.Ciudad</td>
                    <td>@(item.EsPrincipal ? "Sí" : "No")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
