@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Producto>
@{ ViewData["Title"] = Localizer["GestionProductos"]; }
<div class="container-fluid mt-4" data-aos="fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold m-0"><i class="bi bi-box-seam me-2"></i> @Localizer["TodosLosProductos"]</h1>
    </div>

    <div class="table-responsive glass-card p-4 rounded-4 shadow-lg border-0">
        <table class="table table-dark table-hover table-borderless align-middle mb-0">
            <thead class="border-bottom border-secondary">
                <tr>
                    <th class="text-uppercase text-muted small fw-bold">ID</th>
                    <th class="text-uppercase text-muted small fw-bold">Producto</th>
                    <th class="text-uppercase text-muted small fw-bold">Restaurante</th>
                    <th class="text-uppercase text-muted small fw-bold">@Localizer["PrecioTag"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr class="glass-row">
                        <td class="text-light fw-bold">@item.Id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                @if(!string.IsNullOrEmpty(item.ImagenUrl)) {
                                    <img src="@item.ImagenUrl" class="rounded me-3 border border-secondary" style="width: 50px; height: 50px; object-fit: cover;" />
                                } else {
                                    <div class="bg-secondary rounded me-3 d-flex justify-content-center align-items-center text-white fw-bold" style="width: 50px; height: 50px;">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                                <div>
                                    <div class="fw-bold text-white">@item.Nombre</div>
                                    @if(item.Categoria != null) {
                                        <span class="badge bg-info text-dark rounded-pill mt-1" style="font-size: 0.7rem;">@item.Categoria.Nombre</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="text-info"><i class="bi bi-shop me-1"></i> @(item.Restaurante?.Nombre ?? "ID: " + item.RestauranteId)</span>
                        </td>
                        <td class="text-light fw-bold text-success">
                            $@item.Precio.ToString("0.00")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
