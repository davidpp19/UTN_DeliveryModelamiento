@model Delivery.MVC.Models.HomeViewModel
@{
    ViewData["Title"] = "Inicio";
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
    var isCliente = isAuthenticated && User.IsInRole("Cliente");
}

@if (isCliente)
{
    <!-- HOME CLIENTE -->
    <div class="container mt-4">
        <div class="alert alert-primary" role="alert">
            <h4>¡Hola, @User.Identity?.Name!</h4>
            <p>Bienvenido de vuelta a RayoExpres. ¿Qué se te antoja hoy?</p>
        </div>

        @if (Model.Cupones.Any())
        {
            <h5>Tus Cupones Activos</h5>
            <div class="d-flex flex-row overflow-auto gap-3 pb-2 mb-4">
                @foreach (var cupon in Model.Cupones)
                {
                    <div class="card border-success" style="min-width: 220px;">
                        <div class="card-body text-center">
                            <h5 class="card-title">@cupon.Codigo</h5>
                            <p>@(cupon.TipoDescuento == Delivery.Modelos.Enums.TipoDescuentoEnum.Porcentaje ? $"{cupon.ValorDescuento}%" : $"${cupon.ValorDescuento}") de descuento</p>
                        </div>
                    </div>
                }
            </div>
        }

        <h3 id="restaurantes">Restaurantes Disponibles</h3>
        @if (Model.RestaurantesDestacados.Any())
        {
            <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
                @foreach (var res in Model.RestaurantesDestacados)
                {
                    <div class="col">
                        <div class="card h-100">
                            <img src="@res.LogoUrl" class="card-img-top" alt="@res.Nombre" style="height: 160px; object-fit: cover;"
                                 onerror="this.src='https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&q=80'" />
                            <div class="card-body">
                                <h5 class="card-title">@res.Nombre</h5>
                                <p class="text-muted">@res.Categoria</p>
                                <p class="small">@res.Calle, @res.Ciudad</p>
                                @if (res.HoraApertura.HasValue && res.HoraCierre.HasValue)
                                {
                                    <p class="small">Horario: @res.HoraApertura?.ToString(@"hh\:mm") — @res.HoraCierre?.ToString(@"hh\:mm")</p>
                                }
                                <p class="small">Envío: $@res.CostoEnvioBase.ToString("0.00")</p>
                            </div>
                            <div class="card-footer">
                                <a asp-action="Restaurante" asp-route-id="@res.Id">Ver Menú</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p>No hay restaurantes disponibles en este momento.</p>
        }

        <h3 class="mb-3">Productos Populares</h3>
        @if (Model.ProductosDestacados.Any())
        {
            <div class="row row-cols-2 row-cols-md-4 g-4 mb-5">
                @foreach (var prod in Model.ProductosDestacados)
                {
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-body">
                                <h6>@prod.Nombre</h6>
                                <p class="text-success">$@prod.Precio.ToString("0.00")</p>
                                <form asp-controller="ClienteCarrito" asp-action="Agregar" method="post">
                                    <input type="hidden" name="productoId" value="@prod.Id" />
                                    <input type="hidden" name="cantidad" value="1" />
                                    <input type="hidden" name="restauranteId" value="@prod.RestauranteId" />
                                    <button type="submit">Agregar al Carrito</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <!-- HOME PÚBLICO (visitante, admin, repartidor, restaurante) -->
    <div class="p-5 mb-4 bg-light rounded-3 text-center mt-3">
        <div class="container-fluid py-5">
            <h1 class="display-4 fw-bold text-primary">RayoExpres</h1>
            <p class="col-md-8 mx-auto fs-4 text-muted">Tu comida favorita, entregada en Ibarra a la velocidad del rayo.</p>
            <p class="lead">Pide de los mejores restaurantes, con pagos seguros y entregas ultrarrápidas.</p>
            <div class="mt-4">
                @if (!isAuthenticated)
                {
                    <a asp-controller="Auth" asp-action="SeleccionTipoRegistro" class="btn btn-primary btn-lg me-2">Regístrate Ahora</a>
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-secondary btn-lg">Iniciar Sesión</a>
                }
                else
                {
                    var dashboardController = User.IsInRole("Admin") ? "DashboardAdministrador" :
                                              User.IsInRole("Repartidor") ? "DashboardRepartidor" :
                                              User.IsInRole("Restaurante") ? "DashboardRestaurante" : "Home";
                    <a asp-controller="@dashboardController" asp-action="Index" class="btn btn-primary btn-lg">Ir a mi Panel</a>
                }
            </div>
        </div>
    </div>

    <div class="container mt-5">
        <div class="row text-center mb-5" id="beneficios">
            <div class="col-md-4">
                <h4>Entregas Rápidas</h4>
                <p class="text-muted">Nuestros repartidores están siempre cerca para que tu comida llegue caliente.</p>
            </div>
            <div class="col-md-4">
                <h4>Pagos Seguros</h4>
                <p class="text-muted">Múltiples métodos de pago avalados por estrictos estándares de seguridad.</p>
            </div>
            <div class="col-md-4">
                <h4>Los Mejores Locales</h4>
                <p class="text-muted">Los mejores restaurantes de Ibarra en un solo lugar.</p>
            </div>
        </div>

        <hr />

        <div id="como-funciona" class="my-5">
            <h3 class="text-center mb-4">¿Cómo funciona RayoExpres?</h3>
            <div class="row text-center">
                <div class="col-md-3">
                    <h2 class="text-muted">1</h2>
                    <h5>Busca</h5>
                    <p class="small">Encuentra el restaurante o platillo que deseas.</p>
                </div>
                <div class="col-md-3">
                    <h2 class="text-muted">2</h2>
                    <h5>Pide</h5>
                    <p class="small">Agrega a tu carrito y aplica tus cupones.</p>
                </div>
                <div class="col-md-3">
                    <h2 class="text-muted">3</h2>
                    <h5>Paga</h5>
                    <p class="small">Usa efectivo, tarjeta o transferencia de forma segura.</p>
                </div>
                <div class="col-md-3">
                    <h2 class="text-muted">4</h2>
                    <h5>Disfruta</h5>
                    <p class="small">Recibe tu pedido en minutos.</p>
                </div>
            </div>
        </div>

        <hr />

        @* ──── TODOS LOS RESTAURANTES (vista pública) ──── *@
        <div id="restaurantes" class="my-5">
            <h3 class="mb-4 text-center">Restaurantes Aliados en Ibarra</h3>

            @if (Model.TodosRestaurantes.Any())
            {
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @foreach (var res in Model.TodosRestaurantes)
                    {
                        <div class="col">
                            <div class="card h-100">
                                <img src="@res.LogoUrl"
                                     class="card-img-top"
                                     alt="@res.Nombre"
                                     style="height: 200px; object-fit: cover;"
                                     onerror="this.src='https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&q=80'" />
                                <div class="card-body">
                                    <h5 class="card-title">@res.Nombre</h5>
                                    <p class="text-muted small">@res.Categoria</p>
                                    <p class="small">@res.Calle, @res.Ciudad</p>
                                    @if (res.HoraApertura.HasValue && res.HoraCierre.HasValue)
                                    {
                                        <p class="small">Horario: @res.HoraApertura?.ToString(@"hh\:mm") — @res.HoraCierre?.ToString(@"hh\:mm")</p>
                                    }
                                    <p class="small">Costo envío: $@res.CostoEnvioBase.ToString("0.00")</p>
                                </div>
                                <div class="card-footer text-center">
                                    <a asp-controller="Auth" asp-action="Login">Inicia sesión para ver el menú</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-secondary text-center">No hay restaurantes disponibles en este momento.</div>
            }
        </div>
    </div>
}
