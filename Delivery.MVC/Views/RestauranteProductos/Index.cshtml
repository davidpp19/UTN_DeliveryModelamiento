@model IEnumerable<Delivery.Modelos.Entidades.Producto>
@{ ViewData["Title"] = "Mis Productos"; }
<h1 class="my-4">Mis Productos</h1>
<p><a asp-action="Create" class="btn btn-primary">Crear Nuevo Producto</a></p>
<div class="table-responsive table-scrollable">
    <table class="table skeleton-loader table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Imagen</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Disponible</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImagenUrl))
                    {
                        <img src="@item.ImagenUrl" alt="Imagen de @item.Nombre" style="max-width: 80px; max-height: 80px;" class="img-thumbnail" />
                    }
                    else
                    {
                        <span class="text-muted">Sin imagen</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                <td>$@Html.DisplayFor(modelItem => item.Precio)</td>
                <td>@(item.Disponible ? "SÃ­" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning btn-confirm" data-title="¿Confirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger btn-confirm" data-title="¿Eliminar registro?" data-text="Esta acción no se puede deshacer" data-danger="true" data-confirm="Sí, eliminar">Eliminar</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>


