@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model Delivery.Modelos.Entidades.CategoriaProducto
@{ ViewData["Title"] = Localizer["EditarCategoriaProductoTitle"]; }
<h1 class="my-4">@Localizer["EditarCategoriaProductoTitle"]</h1><hr />
<div class="row"><div class="col-md-6">
<form asp-action="Edit">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" asp-for="Id" />
<div class="mb-3">
<label asp-for="RestauranteId" class="form-label"></label>
<select asp-for="RestauranteId" class="form-control" asp-items="ViewBag.RestauranteId"></select>
<span asp-validation-for="RestauranteId" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="Nombre" class="form-label"></label>
<input asp-for="Nombre" class="form-control" />
<span asp-validation-for="Nombre" class="text-danger"></span></div>
<div class="mb-3">
<label asp-for="Descripcion" class="form-label"></label>
<input asp-for="Descripcion" class="form-control" />
<span asp-validation-for="Descripcion" class="text-danger"></span></div>




<div class="mb-3"><button type="submit" class="btn btn-warning btn-confirm" data-title="żConfirmar acción?" data-text="Por favor confirma esta acción" data-confirm="Sí, continuar">@Localizer["ActualizarBtn"]</button></div>
</form></div></div>
<div><a asp-action="Index" class="btn btn-outline-secondary">@Localizer["VolverListadoBtn"]</a></div>

