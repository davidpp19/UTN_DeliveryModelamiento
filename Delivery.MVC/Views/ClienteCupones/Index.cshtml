@model IEnumerable<Delivery.Modelos.Entidades.CuponUsuario>
@{
    ViewData["Title"] = "Mis Cupones";
}

<div class="container mt-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="mb-0"><i class="bi bi-ticket-perforated text-success"></i> Mis Cupones</h2>
            <p class="text-muted">Gestiona tus cupones de descuento y códigos promocionales.</p>
        </div>
        <div class="col-md-6 text-end">
            <!-- Botón que abre el Modal -->
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#agregarCuponModal">
                ➕ Agregar Cupón
            </button>
        </div>
    </div>

    <!-- Modal Agregar Cupón -->
    <div class="modal fade" id="agregarCuponModal" tabindex="-1" aria-labelledby="agregarCuponModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="Registrar" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="agregarCuponModalLabel">Registrar Nuevo Cupón</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="codigo" class="form-label">Código del cupón</label>
                            <input type="text" id="codigo" name="codigo" class="form-control" placeholder="Ingresar código" style="text-transform:uppercase" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Agregar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
            <h5>Aún no tienes cupones registrados.</h5>
            <p>Ingresa un código en la parte superior para agregarlo a tu cuenta.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var cuponUsuario in Model.OrderByDescending(c => c.FechaRegistro))
            {
                var cupon = cuponUsuario.Cupon;
                if (cupon == null) continue;

                var isUsed = cuponUsuario.PedidoId != null;
                var isExpired = System.DateTime.UtcNow > cupon.FechaFin;
                var isActive = cupon.Activo;
                
                string cardBorder = "border-success";
                string headerBg = "bg-success";
                string statusText = "DISPONIBLE";
                string statusBadge = "bg-success";

                if (isUsed)
                {
                    cardBorder = "border-secondary";
                    headerBg = "bg-secondary";
                    statusText = "UTILIZADO";
                    statusBadge = "bg-secondary";
                }
                else if (!isActive || isExpired)
                {
                    cardBorder = "border-danger";
                    headerBg = "bg-danger";
                    statusText = "VENCIDO";
                    statusBadge = "bg-danger";
                }

                <div class="col">
                    <div class="card h-100 shadow-sm @cardBorder">
                        <div class="card-header @headerBg text-white d-flex justify-content-between align-items-center">
                            <span class="fw-bold fs-5">@cupon.Codigo</span>
                            <span class="badge @statusBadge border border-white">@statusText</span>
                        </div>
                        <div class="card-body text-center">
                            <h3 class="mb-3" style="color: var(--bs-@cardBorder.Replace("border-",""))">
                                @if(cupon.TipoDescuento == Delivery.Modelos.Enums.TipoDescuentoEnum.Porcentaje)
                                {
                                    <span>-@cupon.ValorDescuento.ToString("0.##")% OFF</span>
                                }
                                else
                                {
                                    <span>-$@cupon.ValorDescuento.ToString("0.00")</span>
                                }
                            </h3>
                            <ul class="list-unstyled small text-muted text-start mb-0">
                                @if(!string.IsNullOrEmpty(cupon.Descripcion))
                                {
                                    <li class="mb-2"><strong>Descripción:</strong> @cupon.Descripcion</li>
                                }
                                @if(cupon.TipoDescuento == Delivery.Modelos.Enums.TipoDescuentoEnum.Porcentaje && cupon.DescuentoMaximo.HasValue)
                                {
                                    <li><i class="bi bi-shield-check"></i> <strong>Tope máximo:</strong> $@cupon.DescuentoMaximo.Value.ToString("0.00")</li>
                                }
                                <li><i class="bi bi-clock"></i> <strong>Vence:</strong> @cupon.FechaFin.ToLocalTime().ToString("dd/MM/yyyy")</li>
                                @if(statusText == "DISPONIBLE")
                                {
                                    var diasRestantes = (cupon.FechaFin - System.DateTime.UtcNow).Days;
                                    <li><i class="bi bi-hourglass-split"></i> <strong>Días restantes:</strong> @(diasRestantes > 0 ? diasRestantes.ToString() : "Expira hoy")</li>
                                }
                                <li><i class="bi bi-calendar-check"></i> <strong>Registrado:</strong> @cuponUsuario.FechaRegistro.ToLocalTime().ToString("dd/MM/yyyy")</li>
                                @if(cupon.PedidoMinimo.HasValue)
                                {
                                    <li><i class="bi bi-bag-check"></i> <strong>Compra mínima:</strong> $@cupon.PedidoMinimo.Value.ToString("0.00")</li>
                                }
                            </ul>
                        </div>
                        <div class="card-footer bg-light border-top-0 d-grid">
                            @if(statusText == "DISPONIBLE")
                            {
                                <button class="btn btn-outline-success btn-sm" onclick="navigator.clipboard.writeText('@cupon.Codigo'); alert('¡Código copiado!');">
                                    <i class="bi bi-clipboard"></i> Copiar Código
                                </button>
                            }
                            else if(statusText == "UTILIZADO")
                            {
                                <small class="text-center text-muted">Utilizado el @(cuponUsuario.FechaUso?.ToLocalTime().ToString("dd/MM/yyyy") ?? "N/A")</small>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
