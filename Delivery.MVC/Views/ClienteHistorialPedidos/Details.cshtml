@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model Delivery.Modelos.Entidades.Pedido
@{
    ViewData["Title"] = Localizer["DetallePedido"];
}

<div class="container mt-4">
    <h2>@Localizer["DetallesTuPedido"] #@Model.Id</h2>
    <hr />

    <div class="row">
        <!-- Columna Izquierda: Info General -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">@Localizer["InformacionGeneralTag"]</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">@Localizer["RestauranteTag"]</dt>
                        <dd class="col-sm-8">@(Model.Restaurante?.Nombre ?? "N/A")</dd>

                        <dt class="col-sm-4">@Localizer["FechaPedidoTag"]</dt>
                        <dd class="col-sm-8">@Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-4">@Localizer["EstadoTag"]</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info text-dark">@Model.EstadoPedido.ToString()</span>
                        </dd>

                        <dt class="col-sm-4">@Localizer["DireccionTag"]</dt>
                        <dd class="col-sm-8">
                            @(Model.DireccionEntrega?.Calle) @(Model.DireccionEntrega?.Numero)
                            <br /><small class="text-muted">@(Model.DireccionEntrega?.Referencia)</small>
                        </dd>
                        
                        <dt class="col-sm-4">@Localizer["MetodoPagoTag"]</dt>
                        <dd class="col-sm-8">@Model.TipoMetodoPago.ToString()</dd>

                        @if (Model.Repartidor != null && Model.Repartidor.Usuario != null)
                        {
                            <dt class="col-sm-4">@Localizer["RepartidorTag"]</dt>
                            <dd class="col-sm-8">
                                @Model.Repartidor.Usuario.Nombre @Model.Repartidor.Usuario.Apellidos
                                <br /><small>@Localizer["LicenciaTag"]: @Model.Repartidor.LicenciaConducir</small>
                            </dd>
                        }
                        
                        @if (!string.IsNullOrWhiteSpace(Model.Notas))
                        {
                            <dt class="col-sm-4">@Localizer["NotasTag"]</dt>
                            <dd class="col-sm-8">@Model.Notas</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Resumen Financiero y Productos -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">@Localizer["ResumenPedidoTag"]</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@Localizer["ProductoCol"]</th>
                                <th>@Localizer["CantCol"]</th>
                                <th class="text-end">@Localizer["PrecioCol"]</th>
                                <th class="text-end">@Localizer["SubtotalCol"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Detalles != null && Model.Detalles.Any())
                            {
                                foreach (var detalle in Model.Detalles)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (detalle.Producto != null && !string.IsNullOrEmpty(detalle.Producto.ImagenUrl))
                                                {
                                                    <img src="@detalle.Producto.ImagenUrl" alt="Producto" class="rounded me-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                                }
                                                <span>@(detalle.Producto?.Nombre ?? Localizer["ProductoIDTag"].Value + " " + detalle.ProductoId)</span>
                                            </div>
                                        </td>
                                        <td class="align-middle">@detalle.Cantidad</td>
                                        <td class="text-end">$@detalle.PrecioUnitario.ToString("0.00")</td>
                                        <td class="text-end fw-bold">$@detalle.Subtotal.ToString("0.00")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center">No hay detalles de productos disponibles.</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end">Subtotal Productos:</td>
                                <td class="text-end">$@Model.Subtotal.ToString("0.00")</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end">Costo Envío:</td>
                                <td class="text-end">$@Model.CostoEnvio.ToString("0.00")</td>
                            </tr>
                            @if (Model.MontoDescuento > 0)
                            {
                                <tr>
                                    <td colspan="3" class="text-end text-danger">Descuento:</td>
                                    <td class="text-end text-danger">-$@Model.MontoDescuento.ToString("0.00")</td>
                                </tr>
                            }
                            <tr>
                                <td colspan="3" class="text-end fw-bold">TOTAL:</td>
                                <td class="text-end fw-bold fs-5 text-primary">$@Model.Total.ToString("0.00")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @if (Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.EnCamino || Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.ListoParaRecoger)
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow-sm border-info">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Rastreo en Tiempo Real</h5>
                        <span class="badge bg-light text-dark" id="eta-badge">Calculando...</span>
                    </div>
                    <div class="card-body p-0">
                        <div id="map" style="height: 400px; width: 100%;"></div>
                    </div>
                    <div class="card-footer bg-light d-flex justify-content-between">
                        <span><strong>Distancia Restante:</strong> <span id="distancia-lbl">-- km</span></span>
                        <span><strong>Tiempo Estimado:</strong> <span id="tiempo-lbl">-- min</span></span>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="mt-3">
        @if (Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.Entregado)
        {
            <a asp-action="Calificar" asp-route-id="@Model.Id" class="btn btn-warning me-2">Calificar Pedido</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["VolverHistorialBtn"]</a>
    </div>
</div>

@section Scripts {
    <!-- Leaflet CSS y JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // SIEMPRE conectarse a SignalR para escuchar cambios de estado
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('@(Configuration["ApiSettings:BaseUrl"] ?? Configuration["ApiUrl"] ?? "https://localhost:7087")'.replace(/\/$/, "") + "/notificacionesHub")
            .withAutomaticReconnect()
            .build();

        // Primero inicializar el mapa si existe y registrar los eventos de SignalR
        var restMarker, cliMarker, repMarker, currentRouteLine;
        var map;

        if (document.getElementById('map')) {
            map = L.map('map').setView([0.3517, -78.1222], 14);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '© OpenStreetMap'
            }).addTo(map);

            var restLat = @(Model.Restaurante?.Latitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
            var restLng = @(Model.Restaurante?.Longitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
            var cliLat = @(Model.DireccionEntrega?.Latitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
            var cliLng = @(Model.DireccionEntrega?.Longitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");

            var restMarker, cliMarker, repMarker;

            var cliIcon = L.divIcon({
                html: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="36" height="36" fill="#198754"><path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L8 2.207l6.646 6.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.707 1.5Z"/><path d="m8 3.293 6 6V13.5a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 13.5V9.293l6-6Z"/></svg>',
                className: '',
                iconSize: [36, 36],
                iconAnchor: [18, 36]
            });
            
            var restIcon = L.divIcon({
                html: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="36" height="36" fill="#dc3545"><path d="M2.97 1.35A1 1 0 0 1 3.736 1h8.528a1 1 0 0 1 .766.35l2.762 3.222A.5.5 0 0 1 15.625 5H.375a.5.5 0 0 1-.168-.428L2.97 1.35z"/><path d="M1.5 6h13v8a1 1 0 0 1-1 1H2.5a1 1 0 0 1-1-1V6zm11.5 1H3v6h10V7z"/></svg>',
                className: '',
                iconSize: [36, 36],
                iconAnchor: [18, 36]
            });

            if (restLat !== 0) {
                restMarker = L.marker([restLat, restLng], { icon: restIcon }).addTo(map).bindPopup('@Html.Raw(Model.Restaurante?.Nombre?.Replace("'", "\\'") ?? "Restaurante")');
            }
            if (cliLat !== 0) {
                cliMarker = L.marker([cliLat, cliLng], { icon: cliIcon }).addTo(map).bindPopup('Tu Dirección: @Html.Raw(Model.DireccionEntrega?.Calle?.Replace("'", "\\'") ?? "")');
            }
            
            if (restLat !== 0 && cliLat !== 0) {
                try {
                    // Encuadrar inicialmente entre restaurante y cliente de forma segura
                    var bounds = L.latLngBounds([restLat, restLng], [cliLat, cliLng]);
                    map.fitBounds(bounds);
                } catch (e) {
                    console.error("Error al encuadrar el mapa:", e);
                }
            } else if (restLat !== 0) {
                map.setView([restLat, restLng], 15);
            } else if (cliLat !== 0) {
                map.setView([cliLat, cliLng], 15);
            }

            var repIcon = L.divIcon({
                html: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="36" height="36" fill="#0d6efd"><path d="M4 4.5a.5.5 0 0 1 .5-.5H6a.5.5 0 0 1 0 1v.5h4.14l.327-.17C11.108 5.012 11.5 4.5 12 4.5h2a.5.5 0 0 1 0 1h-1.644l-2.07 1.082-.676 2.368a3 3 0 1 1-1.859-1.92l.842-2.95H5.52l-.841 2.95a3 3 0 1 1-1.859 1.92l.676-2.368L2 7.082V8.5a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5H3v-1zm-.145 5.864a2 2 0 1 0 2.87 2.158l-.842-2.95a2 2 0 0 0-2.028.792zM10.126 12.5a2 2 0 1 0 2.87-2.158l-.842 2.95a2 2 0 0 0-2.028-.792z"/></svg>',
                className: '',
                iconSize: [36, 36],
                iconAnchor: [18, 36]
            });

            // IMPORTANT: Register event handler BEFORE starting connection
            connection.on("RecibirUbicacionRepartidor", function (lat, lng) {
                if (repMarker) {
                    repMarker.setLatLng([lat, lng]);
                } else {
                    repMarker = L.marker([lat, lng], { icon: repIcon }).addTo(map).bindPopup('Repartidor: @Html.Raw(Model.Repartidor?.Usuario?.Nombre?.Replace("'", "\\'") ?? "")');
                }
                
                // Centrar forzosamente el mapa en el repartidor (setView ignora la distancia máxima)
                map.setView([lat, lng], 16);

                // Calcular ETA usando OSRM
                if (cliLat !== 0 && cliLng !== 0) {
                    fetch(`https://router.project-osrm.org/route/v1/driving/${lng},${lat};${cliLng},${cliLat}?overview=full&geometries=geojson`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.routes && data.routes.length > 0) {
                                var routeData = data.routes[0];
                                var routeCoords = routeData.geometry.coordinates;
                                var latLngs = routeCoords.map(coord => [coord[1], coord[0]]);

                                if (currentRouteLine) {
                                    map.removeLayer(currentRouteLine);
                                }

                                currentRouteLine = L.polyline(latLngs, { color: 'green', weight: 4 }).addTo(map);
                                
                                const distanciaKm = (routeData.distance / 1000).toFixed(1);
                                const tiempoMin = Math.ceil(routeData.duration / 60);

                                document.getElementById('distancia-lbl').innerText = distanciaKm + " km";
                                document.getElementById('tiempo-lbl').innerText = tiempoMin + " min";
                                document.getElementById('eta-badge').innerText = "Llega en ~" + tiempoMin + " min";
                            }
                        }).catch(err => console.error("Error en OSRM:", err));
                } else {
                    document.getElementById('distancia-lbl').innerText = "N/A";
                    document.getElementById('tiempo-lbl').innerText = "N/A";
                    document.getElementById('eta-badge').innerText = "Sin GPS de destino";
                }
            });
        }

        connection.on("EstadoPedidoCambiado", function (pedidoId, nuevoEstado) {
            if (pedidoId == @Model.Id) {
                location.reload();
            }
        });

        // DESPUES de registrar todos los .on, iniciamos la conexión
        connection.start().then(function () {
            console.log("Conectado a SignalR para tracking del pedido @Model.Id");
            connection.invoke("UnirseGrupoPedido", "@Model.Id").catch(err => console.error(err));
            connection.invoke("UnirseGrupoCliente", "@Model.UsuarioId").catch(err => console.error(err));
        }).catch(err => console.error(err));
    </script>
}
