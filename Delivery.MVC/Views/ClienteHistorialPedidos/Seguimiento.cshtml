@model Delivery.Modelos.Entidades.Pedido
@{
    ViewData["Title"] = "Track Order";
}

<div class="container mt-4">
    <h2><i class="bi bi-geo-alt text-primary"></i> Seguimiento del Pedido #@Model.Id</h2>
    <hr />

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Estado del Pedido (Get order status)</h5>
                    <h3 class="text-info">@ViewBag.OrderStatus</h3>
                    
                    @if (Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.EnCamino)
                    {
                        <p class="text-success fw-bold">In Transit [Si] -> Get driver location</p>
                        @if (ViewBag.DriverLat != null && ViewBag.DriverLng != null)
                        {
                            <div class="alert alert-secondary">
                                <strong>Request GPS coords:</strong><br />
                                Latitud: @ViewBag.DriverLat <br />
                                Longitud: @ViewBag.DriverLng
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                GPS coords no disponibles.
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">In Transit [No]</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Show status and map</h5>
                    <!-- Placeholder for Map -->
                    <div class="bg-light border p-5 mt-3 d-flex align-items-center justify-content-center" style="height: 200px;">
                        <span class="text-muted"><i class="bi bi-map display-4"></i><br/>Mapa (View result)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Volver al Detalle</a>
    </div>
</div>
