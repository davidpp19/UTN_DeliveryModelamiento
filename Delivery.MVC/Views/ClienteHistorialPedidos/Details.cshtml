@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model Delivery.Modelos.Entidades.Pedido
@{
    ViewData["Title"] = Localizer["DetallePedido"];
}

<div class="container mt-5 mb-5" data-aos="fade-up">
    <div class="d-flex align-items-center mb-4 border-bottom border-secondary pb-3">
        <i class="bi bi-receipt fs-1 text-primary me-3"></i>
        <h2 class="mb-0 text-light">@Localizer["DetallesTuPedido"] #@Model.Id</h2>
    </div>

    <div class="row">
        <!-- Columna Izquierda: Info General -->
        <div class="col-md-6 mb-4">
            <div class="card glass-card h-100 p-4">
                <h5 class="mb-4 text-info border-bottom border-secondary pb-2"><i class="bi bi-info-circle"></i> @Localizer["InformacionGeneralTag"]</h5>
                <dl class="row mb-0 text-light">
                    <dt class="col-sm-4 text-muted">@Localizer["RestauranteTag"]</dt>
                    <dd class="col-sm-8 fw-bold">@(Model.Restaurante?.Nombre ?? "N/A")</dd>

                    <dt class="col-sm-4 text-muted">@Localizer["FechaPedidoTag"]</dt>
                    <dd class="col-sm-8">@Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 text-muted">@Localizer["EstadoTag"]</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-primary text-light px-3 py-2 rounded-pill">@Model.EstadoPedido.ToString()</span>
                    </dd>

                    <dt class="col-sm-4 text-muted mt-3">@Localizer["DireccionTag"]</dt>
                    <dd class="col-sm-8 mt-3">
                        <i class="bi bi-geo-alt text-danger me-1"></i> @(Model.DireccionEntrega?.Calle) @(Model.DireccionEntrega?.Numero)
                        <br /><small class="text-muted ms-3">@(Model.DireccionEntrega?.Referencia)</small>
                    </dd>
                    
                    <dt class="col-sm-4 text-muted">@Localizer["MetodoPagoTag"]</dt>
                    <dd class="col-sm-8"><i class="bi bi-wallet2 text-warning me-1"></i> @Model.TipoMetodoPago.ToString()</dd>

                    @if (Model.Repartidor != null && Model.Repartidor.Usuario != null)
                    {
                        <dt class="col-sm-4 text-muted mt-3">@Localizer["RepartidorTag"]</dt>
                        <dd class="col-sm-8 mt-3 border-start border-info ps-3">
                            <i class="bi bi-person-badge text-info me-1"></i> @Model.Repartidor.Usuario.Nombre @Model.Repartidor.Usuario.Apellidos
                            <br /><small class="text-muted">@Localizer["LicenciaTag"]: @Model.Repartidor.LicenciaConducir</small>
                        </dd>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(Model.Notas))
                    {
                        <dt class="col-sm-4 text-muted mt-3">@Localizer["NotasTag"]</dt>
                        <dd class="col-sm-8 mt-3 font-italic">"@Model.Notas"</dd>
                    }
                </dl>
            </div>
        </div>

        <!-- Columna Derecha: Resumen Financiero y Productos -->
        <div class="col-md-6 mb-4">
            <div class="card glass-card h-100 p-4">
                <h5 class="mb-4 text-success border-bottom border-secondary pb-2"><i class="bi bi-cart-check"></i> @Localizer["ResumenPedidoTag"]</h5>
                <div class="table-responsive glass-card p-4 rounded-4 shadow-lg border-0 mt-3 table-scrollable">
                    <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
                        <thead>
                            <tr class="border-bottom border-secondary">
                                <th>@Localizer["ProductoCol"]</th>
                                <th>@Localizer["CantCol"]</th>
                                <th class="text-end">@Localizer["PrecioCol"]</th>
                                <th class="text-end">@Localizer["SubtotalCol"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Detalles != null && Model.Detalles.Any())
                            {
                                foreach (var detalle in Model.Detalles)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (detalle.Producto != null && !string.IsNullOrEmpty(detalle.Producto.ImagenUrl))
                                                {
                                                    <img src="@detalle.Producto.ImagenUrl" alt="Producto" class="rounded me-3 shadow-sm border border-secondary" style="width: 45px; height: 45px; object-fit: cover;" />
                                                }
                                                <span class="fw-bold">@(detalle.Producto?.Nombre ?? Localizer["ProductoIDTag"].Value + " " + detalle.ProductoId)</span>
                                            </div>
                                        </td>
                                        <td class="align-middle text-center"><span class="badge bg-secondary">@detalle.Cantidad</span></td>
                                        <td class="text-end align-middle">$@detalle.PrecioUnitario.ToString("0.00")</td>
                                        <td class="text-end fw-bold text-success align-middle">$@detalle.Subtotal.ToString("0.00")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">No hay detalles de productos disponibles.</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="border-top border-secondary">
                            <tr>
                                <td colspan="3" class="text-end text-muted pt-3">Subtotal Productos:</td>
                                <td class="text-end pt-3">$@Model.Subtotal.ToString("0.00")</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end text-muted">Costo Envío:</td>
                                <td class="text-end">$@Model.CostoEnvio.ToString("0.00")</td>
                            </tr>
                            @if (Model.MontoDescuento > 0)
                            {
                                <tr>
                                    <td colspan="3" class="text-end text-danger"><i class="bi bi-tag-fill me-1"></i> Descuento:</td>
                                    <td class="text-end text-danger">-$@Model.MontoDescuento.ToString("0.00")</td>
                                </tr>
                            }
                            <tr>
                                <td colspan="3" class="text-end fw-bold pt-3 fs-5">TOTAL:</td>
                                <td class="text-end fw-bold fs-4 text-primary pt-3">$@Model.Total.ToString("0.00")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @if (Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.EnCamino || Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.ListoParaRecoger)
    {
        <div class="row mt-4 mb-4">
            <div class="col-12">
                <div class="card glass-card p-4 border-info">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="mb-0 text-info"><i class="bi bi-geo-alt fs-4 me-2"></i> Rastreo en Tiempo Real</h5>
                        <span class="badge bg-primary text-light px-3 py-2 rounded-pill fs-6" id="eta-badge">Calculando...</span>
                    </div>
                    <div class="card overflow-hidden border-0 shadow-lg mb-4">
                        <div id="map" style="height: 400px; width: 100%; z-index: 1;"></div>
                    </div>
                    <div class="d-flex justify-content-between text-light px-3 py-2 rounded" style="background: rgba(13, 202, 240, 0.1); border: 1px solid rgba(13, 202, 240, 0.3);">
                        <span><i class="bi bi-signpost-split text-info me-2"></i><strong>Distancia Restante:</strong> <span id="distancia-lbl" class="ms-1 fw-bold">-- km</span></span>
                        <span><i class="bi bi-clock-history text-warning me-2"></i><strong>Tiempo Estimado:</strong> <span id="tiempo-lbl" class="ms-1 fw-bold">-- min</span></span>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="d-flex gap-3 justify-content-end mt-5 border-top border-secondary pt-4">
        @if (Model.EstadoPedido == Delivery.Modelos.Enums.EstadoPedidoEnum.Entregado && ViewBag.HasResena != true)
        {
            <a asp-action="Calificar" asp-route-id="@Model.Id" class="btn btn-liquid btn-liquid-warning px-4"><i class="bi bi-star"></i> Calificar Pedido</a>
        }
        @if (ViewBag.HasResena == true)
        {
            <div class="badge bg-success d-flex align-items-center px-3 py-2 fs-6"><i class="bi bi-star-fill text-warning me-2"></i> Pedido Calificado</div>
        }
        <a asp-action="Index" class="btn btn-outline-info rounded-pill px-4"><i class="bi bi-arrow-left"></i> @Localizer["VolverHistorialBtn"]</a>
    </div>
</div>

@section Scripts {
    <!-- Leaflet CSS y JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // SIEMPRE conectarse a SignalR para escuchar cambios de estado
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('@(Configuration["ApiSettings:BaseUrl"] ?? Configuration["ApiUrl"] ?? "https://localhost:7278")'.replace(/\/$/, "") + "/notificacionesHub")
            .withAutomaticReconnect()
            .build();

        // Primero inicializar el mapa si existe y registrar los eventos de SignalR
        var restMarker, cliMarker, repMarker, currentRouteLine;
        var map;

        if (document.getElementById('map')) {
            map = L.map('map').setView([0.3517, -78.1222], 14);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '© OpenStreetMap'
            }).addTo(map);

            var restLat = @(Model.Restaurante?.Latitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
            var restLng = @(Model.Restaurante?.Longitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
            var cliLat = @(Model.DireccionEntrega?.Latitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
            var cliLng = @(Model.DireccionEntrega?.Longitud?.ToString("0.0000000", System.Globalization.CultureInfo.InvariantCulture) ?? "0");

            var restMarker, cliMarker, repMarker;

            var cliIcon = new L.Icon({
              iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-green.png',
              shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
              iconSize: [25, 41],
              iconAnchor: [12, 41],
              popupAnchor: [1, -34],
              shadowSize: [41, 41]
            });
            
            var restIcon = new L.Icon({
              iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
              shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
              iconSize: [25, 41],
              iconAnchor: [12, 41],
              popupAnchor: [1, -34],
              shadowSize: [41, 41]
            });

            if (restLat !== 0) {
                restMarker = L.marker([restLat, restLng], { icon: restIcon }).addTo(map).bindPopup('@Html.Raw(Model.Restaurante?.Nombre?.Replace("'", "\\'") ?? "Restaurante")');
            }
            if (cliLat !== 0) {
                cliMarker = L.marker([cliLat, cliLng], { icon: cliIcon }).addTo(map).bindPopup('Tu Dirección: @Html.Raw(Model.DireccionEntrega?.Calle?.Replace("'", "\\'") ?? "")');
            }
            
            if (restLat !== 0 && cliLat !== 0) {
                try {
                    // Encuadrar inicialmente entre restaurante y cliente de forma segura
                    var bounds = L.latLngBounds([restLat, restLng], [cliLat, cliLng]);
                    map.fitBounds(bounds);
                } catch (e) {
                    console.error("Error al encuadrar el mapa:", e);
                }
            } else if (restLat !== 0) {
                map.setView([restLat, restLng], 15);
            } else if (cliLat !== 0) {
                map.setView([cliLat, cliLng], 15);
            }

            var repIcon = new L.Icon({
              iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-blue.png',
              shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
              iconSize: [25, 41],
              iconAnchor: [12, 41],
              popupAnchor: [1, -34],
              shadowSize: [41, 41]
            });

            // IMPORTANT: Register event handler BEFORE starting connection
            connection.on("RecibirUbicacionRepartidor", function (lat, lng) {
                if (repMarker) {
                    repMarker.setLatLng([lat, lng]);
                } else {
                    repMarker = L.marker([lat, lng], { icon: repIcon }).addTo(map).bindPopup('Repartidor: @Html.Raw(Model.Repartidor?.Usuario?.Nombre?.Replace("'", "\\'") ?? "")');
                }
                
                // Centrar forzosamente el mapa en el repartidor (setView ignora la distancia máxima)
                map.setView([lat, lng], 16);

                // Calcular ETA usando OSRM
                if (cliLat !== 0 && cliLng !== 0) {
                    fetch(`https://router.project-osrm.org/route/v1/driving/${lng},${lat};${cliLng},${cliLat}?overview=full&geometries=geojson`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.routes && data.routes.length > 0) {
                                var routeData = data.routes[0];
                                var routeCoords = routeData.geometry.coordinates;
                                var latLngs = routeCoords.map(coord => [coord[1], coord[0]]);

                                if (currentRouteLine) {
                                    map.removeLayer(currentRouteLine);
                                }

                                currentRouteLine = L.polyline(latLngs, { color: 'green', weight: 4 }).addTo(map);
                                
                                const distanciaKm = (routeData.distance / 1000).toFixed(1);
                                const tiempoMin = Math.ceil(routeData.duration / 60);

                                document.getElementById('distancia-lbl').innerText = distanciaKm + " km";
                                document.getElementById('tiempo-lbl').innerText = tiempoMin + " min";
                                document.getElementById('eta-badge').innerText = "Llega en ~" + tiempoMin + " min";
                            }
                        }).catch(err => console.error("Error en OSRM:", err));
                } else {
                    document.getElementById('distancia-lbl').innerText = "N/A";
                    document.getElementById('tiempo-lbl').innerText = "N/A";
                    document.getElementById('eta-badge').innerText = "Sin GPS de destino";
                }
            });
        }

        connection.on("EstadoPedidoCambiado", function (pedidoId, nuevoEstado) {
            if (pedidoId == @Model.Id) {
                location.reload();
            }
        });

        // DESPUES de registrar todos los .on, iniciamos la conexión
        connection.start().then(function () {
            console.log("Conectado a SignalR para tracking del pedido @Model.Id");
            connection.invoke("UnirseGrupoPedido", "@Model.Id").catch(err => console.error(err));
            connection.invoke("UnirseGrupoCliente", "@Model.UsuarioId").catch(err => console.error(err));
        }).catch(err => console.error(err));
    </script>
}


