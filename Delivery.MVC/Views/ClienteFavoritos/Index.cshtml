@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Favorito>
@{ ViewData["Title"] = Localizer["MisFavoritos"]; }
<h1 class="my-4">@Localizer["MisFavoritos"]</h1>
<p><a asp-action="Create" class="btn btn-primary">@Localizer["CrearNuevoBtn"]</a></p>
<div class="table-responsive">
<table class="table table-striped table-hover align-middle">
<thead class="table-dark"><tr>
<th>@Localizer["UsuarioIdTag"]</th>
<th>@Localizer["RestauranteIdTag"]</th>
<th>@Localizer["FechaAgregadoTag"]</th>
<th>@Localizer["UsuarioTag"]</th>
<th>@Localizer["RestauranteTag"]</th>
<th>@Localizer["AccionesTag"]</th></tr></thead><tbody>
@foreach (var item in Model) {<tr>
<td>@Html.DisplayFor(modelItem => item.UsuarioId)</td>
<td>@Html.DisplayFor(modelItem => item.RestauranteId)</td>
<td>@Html.DisplayFor(modelItem => item.FechaAgregado)</td>
<td>@Html.DisplayFor(modelItem => item.RestauranteId)</td>
<td>@Html.DisplayFor(modelItem => item.FechaAgregado)</td>
<td>
<a asp-action="Edit" asp-route-id="@item.RestauranteId" class="btn btn-sm btn-warning">@Localizer["EditarBtn"]</a>
<a asp-action="Details" asp-route-id="@item.RestauranteId" class="btn btn-sm btn-info text-white">@Localizer["DetallesBtn"]</a>
<a asp-action="Delete" asp-route-id="@item.RestauranteId" class="btn btn-sm btn-danger">@Localizer["EliminarBtn"]</a>
</td></tr>}
</tbody></table></div>
