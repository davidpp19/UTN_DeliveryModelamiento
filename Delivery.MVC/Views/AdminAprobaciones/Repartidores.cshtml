@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.DTOs.RepartidorPendienteDto>
@{
    ViewData["Title"] = Localizer["AprobacionesRepartidores"];
}

<div class="container-fluid mt-4" data-aos="fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold m-0"><i class="bi bi-bicycle me-2"></i> @Localizer["SolicitudesRepartidoresPendientes"]</h1>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">@Localizer["NoHaySolicitudesPendientes"]</div>
    }
    else
    {
        <div class="table-responsive table-scrollable glass-card p-4 rounded-4 shadow-lg border-0">
            <table class="table table-dark table-hover table-borderless align-middle skeleton-loader mb-0">
                <thead class="border-bottom border-secondary">
                    <tr>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["PerfilTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["NombreTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["EmailTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["CedulaTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold">@Localizer["FechaRegistroTag"]</th>
                        <th class="text-uppercase text-muted small fw-bold text-center text-nowrap" style="min-width: 280px;">@Localizer["AccionesTag"]</th>
                    </tr>
                </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var avatarUrl = !string.IsNullOrEmpty(item.FotoPerfilUrl) ? item.FotoPerfilUrl : "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(item.Nombres) + "&background=random";
                    var modalId = "modalRepartidor" + item.Id;
                    var modalRechazoId = "modalRechazo" + item.Id;

                    <tr class="glass-row">
                        <td>
                            <img src="@avatarUrl" alt="Avatar" class="rounded-circle border border-info" style="width: 40px; height: 40px; object-fit: cover;" />
                        </td>
                        <td class="text-light fw-bold">@(item.Nombres) @(item.Apellidos)</td>
                        <td class="text-light">@item.Email</td>
                        <td class="text-light">@item.Cedula</td>
                        <td class="text-light">@item.CreadoEn.ToString("dd/MM/yyyy")</td>
                        <td class="text-center text-nowrap d-flex gap-2 justify-content-center">
                            <!-- BotÃ³n Mostrar InformaciÃ³n -->
                            <button type="button" class="btn btn-sm btn-info text-white me-1" data-bs-toggle="modal" data-bs-target="#@modalId">
                                <i class="bi bi-eye"></i> Mostrar informaciÃ³n
                            </button>

                            <!-- Formulario Aprobar -->
                            <form method="post" asp-action="AprobarRepartidor" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-success me-1 btn-confirm" data-title="¿Aprobar solicitud?" data-text="Confirmar la aprobación de este registro" data-confirm="Sí, aprobar">
                                    <i class="bi bi-check-circle"></i> Aprobar
                                </button>
                            </form>
                            
                            <!-- BotÃ³n Denegar (Abre Modal de Rechazo) -->
                            <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#@modalRechazoId">
                                <i class="bi bi-x-circle"></i> Denegar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        @section Modals {
    <!-- MODALS PLACED OUTSIDE THE TABLE TO PREVENT Z-INDEX/BACKDROP BUGS -->
        @foreach (var item in Model)
        {
            var avatarUrl = !string.IsNullOrEmpty(item.FotoPerfilUrl) ? item.FotoPerfilUrl : "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(item.Nombres) + "&background=random";
            var modalId = "modalRepartidor" + item.Id;
            var modalRechazoId = "modalRechazo" + item.Id;

            <!-- Modal Mostrar InformaciÃ³n -->
                    <div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)Label" aria-hidden="true">
                      <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title" id="@(modalId)Label">@Localizer["InfoRepartidorTitle"]</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                          </div>
                          <div class="modal-body">
                            <div class="row">
                                <div class="col-md-4 text-center mb-3">
                                    <img src="@avatarUrl" alt="Avatar" class="img-thumbnail rounded-circle mb-2" style="width: 150px; height: 150px; object-fit: cover;" />
                                    <h5 class="mt-2">@item.Nombres @item.Apellidos</h5>
                                </div>
                                <div class="col-md-8">
                                    <h6>@Localizer["DatosPersonalesTitle"]</h6>
                                    <p><strong>CÃ©dula:</strong> @item.Cedula</p>
                                    <p><strong>Email:</strong> @item.Email</p>
                                    <p><strong>@Localizer["TelefonoTag"]:</strong> @item.Telefono</p>
                                    <hr />
                                    <h6>@Localizer["DatosVehiculoTitle"]</h6>
                                    <p><strong>@Localizer["TipoVehiculoTag"]:</strong> @item.TipoVehiculo</p>
                                    <p><strong>@Localizer["PlacaTag"]:</strong> @item.Placa</p>
                                    <p><strong>@Localizer["LicenciaTag"]:</strong> @item.LicenciaConducir</p>
                                    @if (!string.IsNullOrEmpty(item.FotoLicenciaUrl))
                                    {
                                        <div class="mt-2">
                                            <strong>@Localizer["FotoLicenciaTag"]:</strong><br/>
                                            <a href="@item.FotoLicenciaUrl" target="_blank">
                                                <img src="@item.FotoLicenciaUrl" class="img-fluid rounded mt-1" style="max-height: 200px;" />
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["CerrarBtn"]</button>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Modal Rechazar -->
                    <div class="modal fade" id="@modalRechazoId" tabindex="-1" aria-labelledby="@(modalRechazoId)Label" aria-hidden="true">
                      <div class="modal-dialog">
                        <div class="modal-content">
                          <form method="post" asp-action="RechazarRepartidor">
                              <div class="modal-header bg-danger text-white">
                                <h5 class="modal-title" id="@(modalRechazoId)Label">@Localizer["DenegarSolicitudTitle"]</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                              </div>
                              <div class="modal-body">
                                <p>@Localizer["SeguroDenegarSolicitud"] <strong>@item.Nombres @item.Apellidos</strong>?</p>
                                <input type="hidden" name="id" value="@item.Id" />
                                <div class="mb-3">
                                    <label class="form-label">@Localizer["MotivoRechazoObligatorio"]</label>
                                    <textarea name="motivoRechazo" class="form-control" rows="3" required></textarea>
                                </div>
                              </div>
                              <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["CancelarBtn"]</button>
                                <button type="submit" class="btn btn-danger btn-confirm" data-title="¿Eliminar registro?" data-text="Esta acción no se puede deshacer" data-danger="true" data-confirm="Sí, eliminar">@Localizer["ConfirmarDenegacionBtn"]</button>
                              </div>
                          </form>
                        </div>
                      </div>
                    </div>
                }
    }
</div>






}
