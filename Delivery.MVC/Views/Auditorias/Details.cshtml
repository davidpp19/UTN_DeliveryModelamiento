<dt class="col-sm-3">@Html.DisplayNameFor(model => model.FechaHora)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.FechaHora)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.ModuloAfectado)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.ModuloAfectado)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.TipoAccion)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.TipoAccion)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(model => model.Detalles)</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Detalles)</dd>
</dl>
<div><a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">@Localizer["EditarBtn"]</a>
<a asp-action="Index" class="btn btn-outline-secondary ms-2">@Localizer["VolverListadoBtn"]</a></div>
