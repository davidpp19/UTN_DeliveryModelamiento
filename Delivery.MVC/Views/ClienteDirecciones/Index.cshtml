@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Delivery.MVC.SharedResource> Localizer
@model IEnumerable<Delivery.Modelos.Entidades.Direccion>
@{ ViewData["Title"] = Localizer["MisDirecciones"]; }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold m-0"><i class="bi bi-geo-alt-fill"></i> @Localizer["MisDirecciones"]</h1>
        <a asp-action="Create" class="btn btn-liquid">Agregar Nueva Dirección</a>
    </div>
    <hr style="border-color: var(--glass-border);" />

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center glass-card" style="background: rgba(13, 202, 240, 0.1); border: 1px solid rgba(13, 202, 240, 0.3);">
            <i class="bi bi-compass fs-1 d-block mb-3 text-info"></i>
            <p>No tienes direcciones registradas. <a asp-action="Create" class="text-info fw-bold">Agrega tu primera dirección</a>.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
            @foreach (var item in Model)
            {
                <div class="col" data-aos="fade-up">
                    <div class="card glass-card h-100 @(item.EsPrincipal ? "border-primary" : "")">
                        <div class="card-body">
                            <h5 class="card-title text-light fw-bold">
                                @item.Alias
                                @if(item.EsPrincipal)
                                {
                                    <span class="badge bg-primary ms-2" style="font-size: 0.6rem; vertical-align: middle;">Principal</span>
                                }
                            </h5>
                            <p class="card-text text-muted mb-1"><i class="bi bi-signpost-2"></i> @item.Calle @item.Numero</p>
                            <p class="card-text text-muted"><i class="bi bi-building"></i> @item.Ciudad</p>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info flex-grow-1">@Localizer["EditarBtn"]</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger flex-grow-1">@Localizer["EliminarBtn"]</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
